# Workshop Platform - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# ===========================================
# SUPABASE
# ===========================================
PUBLIC_SUPABASE_URL=http://your-supabase-url:8000
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# APLICAÇÃO
# ===========================================
PUBLIC_APP_NAME=WORKSHOP
PUBLIC_APP_SUBTITLE=Grupo Braga & Biano
PUBLIC_SITE_URL=http://localhost:4321

# ===========================================
# AFILIAÇÃO
# ===========================================
AFFILIATE_COOKIE_DAYS=30

# ===========================================
# Vimeo (opcional)
# ===========================================
VIMEO_ACCESS_TOKEN=