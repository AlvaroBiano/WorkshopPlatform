---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { supabaseAdmin } from '../../lib/supabase-server'

const { data: students } = await supabaseAdmin
  .from('users')
  .select('*, orders(*, product:products(title))')
  .eq('role', 'student')
  .order('created_at', { ascending: false })

const { data: pendingStudents } = await supabaseAdmin
  .from('pending_registrations')
  .select('*')
  .order('created_at', { ascending: false })
---

<AdminLayout title="Alunos">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-display font-bold text-dourado">Gestão de Alunos</h1>
    <input type="text" placeholder="Buscar por nome/email..." class="input max-w-xs" id="search" />
  </div>

  {pendingStudents && pendingStudents.length > 0 && (
    <section class="card p-6 mb-6 border-l-4 border-l-dourado">
      <h2 class="text-lg font-bold text-dourado mb-4">Cadastros Pendentes ({pendingStudents.length})</h2>
      <div class="space-y-3">
        {pendingStudents.map((s: any) => (
          <div class="flex items-center justify-between p-4 bg-white/5 rounded-lg">
            <div>
              <p class="font-semibold">{s.full_name}</p>
              <p class="text-sm text-text-muted">{s.email} · CPF: {s.cpf} · WhatsApp: {s.whatsapp}</p>
              {s.payment_proof_url && (
                <a href={s.payment_proof_url} target="_blank" class="text-xs text-dourado hover:underline">Ver comprovante</a>
              )}
            </div>
            <div class="flex gap-2">
              <button onclick={`approveStudent('${s.id}')`} class="px-4 py-2 bg-verde-principal text-white rounded-lg text-sm">
                Aprovar
              </button>
              <button onclick={`rejectStudent('${s.id}')`} class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm">
                Rejeitar
              </button>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <div class="card overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-white/5 text-text-muted">
        <tr>
          <th class="text-left p-4">Aluno</th>
          <th class="text-left p-4">CPF</th>
          <th class="text-left p-4">WhatsApp</th>
          <th class="text-left p-4">Produtos</th>
          <th class="text-left p-4">Status</th>
          <th class="text-left p-4">Ações</th>
        </tr>
      </thead>
      <tbody id="studentsTable">
        {(students || []).map((s: any) => (
          <tr class="border-t border-white/5 hover:bg-white/5" data-search={`${s.full_name} ${s.email}`.toLowerCase()}>
            <td class="p-4">
              <p class="font-semibold">{s.full_name}</p>
              <p class="text-xs text-text-muted">{s.email}</p>
            </td>
            <td class="p-4 font-mono text-xs">{s.cpf_hash ? '***' : '—'}</td>
            <td class="p-4">{s.whatsapp || '—'}</td>
            <td class="p-4">{s.orders?.length || 0}</td>
            <td class="p-4">
              {s.banned_at
                ? <span class="px-2 py-1 bg-red-500/20 text-red-400 rounded text-xs">Banido</span>
                : <span class="px-2 py-1 bg-verde-claro/20 text-verde-claro rounded text-xs">Ativo</span>}
            </td>
            <td class="p-4">
              <div class="flex gap-2">
                <a href={`/admin/devices?user=${s.id}`} class="text-xs text-dourado hover:underline">Dispositivos</a>
                <button onclick={`toggleBan('${s.id}', ${!s.banned_at})`} class="text-xs text-red-400 hover:underline">
                  {s.banned_at ? 'Reativar' : 'Banir'}
                </button>
              </div>
            </td>
          </tr>
        ))}
        {(!students || students.length === 0) && (
          <tr>
            <td colspan="6" class="p-8 text-center text-text-muted">Nenhum aluno cadastrado</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>

<script>
  document.getElementById('search')?.addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.toLowerCase()
    document.querySelectorAll('#studentsTable tr').forEach(row => {
      const match = (row as HTMLElement).dataset.search?.includes(q)
      ;(row as HTMLElement).style.display = match ? '' : 'none'
    })
  })

  window.approveStudent = async (id: string) => {
    if (!confirm('Aprovar este aluno?')) return
    const res = await fetch('/admin/api/approve-student', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    })
    if (res.ok) { alert('Aluno aprovado!'); location.reload() }
    else alert('Erro: ' + await res.text())
  }

  window.rejectStudent = async (id: string) => {
    const reason = prompt('Motivo da rejeição:')
    if (!reason) return
    const res = await fetch('/admin/api/reject-student', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, reason }),
    })
    if (res.ok) location.reload()
    else alert('Erro: ' + await res.text())
  }

  window.toggleBan = async (userId: string, ban: boolean) => {
    const reason = ban ? prompt('Motivo do banimento:') : null
    if (ban && !reason) return
    const res = await fetch('/admin/api/toggle-ban', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, ban, reason }),
    })
    if (res.ok) location.reload()
    else alert('Erro: ' + await res.text())
  }
</script>
