---
interface Props {
  title?: string
  description?: string
}

const {
  title = 'WORKSHOP | Grupo Braga & Biano',
  description = 'Plataforma de Workshops Online'
} = Astro.props

const appName = import.meta.env.PUBLIC_APP_NAME || 'WORKSHOP'
const appSubtitle = import.meta.env.PUBLIC_APP_SUBTITLE || 'Grupo Braga & Biano'
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-bg-dark text-text-light min-h-screen">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-bg-dark/95 backdrop-blur-sm border-b border-white/5">
      <div class="container">
        <nav class="flex items-center justify-between h-16 md:h-20">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3">
            <span class="font-display text-2xl md:text-3xl font-bold text-dourado">
              {appName}
            </span>
            <span class="hidden sm:block text-text-muted text-sm">
              | {appSubtitle}
            </span>
          </a>

          <!-- Navigation -->
          <div class="flex items-center gap-4">
            <slot name="nav" />
          </div>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 mt-20">
      <div class="container py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="text-center md:text-left">
            <span class="font-display text-lg text-dourado">{appName}</span>
            <p class="text-text-muted text-sm mt-1">
              © 2024 {appSubtitle}. Todos os direitos reservados.
            </p>
          </div>
          <div class="flex items-center gap-6 text-sm text-text-muted">
            <a href="/termos" class="hover:text-dourado transition-colors">Termos de Uso</a>
            <a href="/privacidade" class="hover:text-dourado transition-colors">Política de Privacidade</a>
            <a href="/suporte" class="hover:text-dourado transition-colors">Suporte</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>