---
import '../styles/global.css'
import { db } from '../lib/turso'
import Icon from '../components/ui/Icon.astro'
import Toast from '../components/ui/Toast.astro'

interface Props {
  title?: string
}

const { title = 'Área do Aluno | WORKSHOP' } = Astro.props

const user = Astro.locals.user
if (!user) {
  return Astro.redirect('/login')
}

let unreadCount = 0
let notifications: any[] = []

try {
  const result = await db.execute({
    sql: 'SELECT * FROM notifications WHERE user_id = ? ORDER BY created_at DESC LIMIT 10',
    args: [user.id],
  })
  notifications = result.rows as any[]
  unreadCount = (notifications as any[]).filter((n: any) => !n.read).length
} catch (error) {
  console.error('Erro ao carregar notificações:', error)
}
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bg-dark text-text-light min-h-screen">
    <header class="sticky top-0 z-50 bg-bg-dark/95 backdrop-blur-sm border-b border-white/5">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/student" class="flex items-center gap-2">
          <span class="font-display text-2xl font-bold text-dourado">WORKSHOP</span>
          <span class="hidden md:inline text-xs text-text-muted tracking-widest">| Área do Aluno</span>
        </a>

        <div class="flex items-center gap-4">
          <div class="relative" id="notifContainer">
            <button
              id="notifBtn"
              class="relative p-2 hover:bg-white/5 rounded-lg transition-colors text-text-muted hover:text-text-light"
              aria-label="Notificações"
            >
              <Icon name="bell" size={24} />
              <span id="notifBadge" class={`absolute -top-1 -right-1 bg-dourado text-azul-profundo text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center ${unreadCount > 0 ? '' : 'hidden'}`}>
                <span id="notifCount">{unreadCount}</span>
              </span>
            </button>

            <div id="notifPanel" class="hidden absolute right-0 top-12 w-80 bg-bg-card border border-white/10 rounded-xl shadow-xl p-4 max-h-96 overflow-y-auto z-50">
              <div class="flex items-center justify-between mb-3">
                <h3 class="font-bold text-dourado">Notificações</h3>
                <button id="markAllRead" class="text-xs text-text-muted hover:text-dourado">Marcar todas</button>
              </div>
              <div id="notifList">
                {notifications.length ? notifications.map((n: any) => (
                  <a href={n.link_url || '#'} data-notif-id={n.id} class={`block py-2 border-b border-white/5 last:border-0 hover:bg-white/5 -mx-2 px-2 rounded ${!n.read ? 'bg-dourado/5' : ''}`}>
                    <div class="flex items-start gap-2">
                      {!n.read && <span class="w-2 h-2 rounded-full bg-dourado mt-1.5 flex-shrink-0"></span>}
                      <div class="flex-1 min-w-0">
                        <p class="font-semibold text-sm">{n.title}</p>
                        {n.body && <p class="text-xs text-text-muted mt-0.5">{n.body}</p>}
                        <p class="text-xs text-text-muted mt-1">{new Date(n.created_at).toLocaleDateString('pt-BR')}</p>
                      </div>
                    </div>
                  </a>
                )) : <p class="text-text-muted text-sm">Nenhuma notificação</p>}
              </div>
            </div>
          </div>

          <a href="/student/profile" class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-dourado to-dourado-claro flex items-center justify-center text-azul-profundo font-bold">
              {user?.full_name?.charAt(0).toUpperCase()}
            </div>
            <span class="hidden md:inline text-sm">{user?.full_name?.split(' ')[0]}</span>
          </a>

          <a href="/logout" class="flex items-center gap-1 text-text-muted hover:text-vermelho text-sm transition-colors">
            <Icon name="logout" size={16} />
            <span>Sair</span>
          </a>
        </div>
      </div>
    </header>
    <main class="max-w-7xl mx-auto px-4 py-8">
      <Toast />
      <slot />
    </main>
  </body>
</html>

<script>
  document.getElementById('notifBtn')?.addEventListener('click', (e) => {
    e.stopPropagation()
    document.getElementById('notifPanel')?.classList.toggle('hidden')
  })
  document.addEventListener('click', () => {
    document.getElementById('notifPanel')?.classList.add('hidden')
  })

  let lastNotifIds: string[] = []
  async function pollNotifications() {
    try {
      const res = await fetch('/student/api/notifications')
      if (!res.ok) return
      const data = await res.json()
      const notifications = data.notifications || []
      const newUnread = (notifications as any[]).filter((n: any) => !n.read).length

      const badge = document.getElementById('notifBadge')
      const count = document.getElementById('notifCount')
      if (badge && count) {
        if (newUnread > 0) {
          badge.classList.remove('hidden')
          count.textContent = String(newUnread)
        } else {
          badge.classList.add('hidden')
        }
      }

      const currentIds = notifications.map((n: any) => n.id)
      const newIds = currentIds.filter((id: string) => !lastNotifIds.includes(id))
      if (lastNotifIds.length > 0 && newIds.length > 0) {
        const newest = (notifications as any[]).find((n: any) => n.id === newIds[0])
        if (newest && (window as any).showToast) {
          ;(window as any).showToast('info', newest.title)
        }
      }
      lastNotifIds = currentIds
    } catch (e) {
      console.error('Erro no poll de notificações:', e)
    }
  }

  setInterval(pollNotifications, 30000)

  document.getElementById('markAllRead')?.addEventListener('click', async (e) => {
    e.stopPropagation()
    try {
      await fetch('/student/api/notifications', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mark_all_read: true }),
      })
      location.reload()
    } catch (e) {
      console.error('Erro ao marcar como lida:', e)
    }
  })

  document.querySelectorAll('[data-notif-id]').forEach(el => {
    el.addEventListener('click', async () => {
      const id = el.getAttribute('data-notif-id')
      if (id) {
        try {
          await fetch('/student/api/notifications', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id }),
          })
        } catch (e) {}
      }
    })
  })
</script>
