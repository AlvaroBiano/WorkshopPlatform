---
interface MenuItem {
  label: string
  href?: string
  icon?: string
  danger?: boolean
  divider?: boolean
  onClick?: string
}

interface Props {
  items: MenuItem[]
  align?: 'left' | 'right'
  trigger?: 'click' | 'hover'
  class?: string
}

const {
  items = [],
  align = 'right',
  trigger = 'click',
  class: className = '',
} = Astro.props

const alignClasses = align === 'right' ? 'right-0' : 'left-0'
---

<div class:list={['relative inline-block', className]} data-trigger={trigger}>
  <div data-dropdown-trigger>
    <slot name="trigger" />
  </div>

  <div
    data-dropdown-menu
    class:list={[
      'hidden absolute z-40 mt-2 min-w-[200px] bg-bg-card rounded-xl border border-white/10 shadow-xl py-2 transition-all duration-200',
      alignClasses,
    ]}
  >
    {items.map((item, index) => (
      item.divider ? (
        <div class="h-px bg-white/5 mx-2 my-2" />
      ) : item.href ? (
        <a
          href={item.href}
          class:list={[
            'flex items-center gap-3 px-4 py-2.5 text-sm transition-colors',
            item.danger ? 'text-vermelho hover:bg-vermelho/10' : 'text-text-light hover:bg-white/5 hover:text-dourado',
          ]}
        >
          {item.icon && <span class="w-4 h-4" set:html={item.icon} />}
          {item.label}
        </a>
      ) : (
        <button
          type="button"
          onclick={item.onClick}
          class:list={[
            'w-full flex items-center gap-3 px-4 py-2.5 text-sm text-left transition-colors',
            item.danger ? 'text-vermelho hover:bg-vermelho/10' : 'text-text-light hover:bg-white/5 hover:text-dourado',
          ]}
        >
          {item.icon && <span class="w-4 h-4" set:html={item.icon} />}
          {item.label}
        </button>
      )
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('[data-dropdown-trigger]').forEach(trigger => {
    const dropdown = trigger.closest('[data-trigger]')
    const menu = dropdown?.querySelector('[data-dropdown-menu]')
    const triggerType = dropdown?.dataset.trigger || 'click'

    const showMenu = () => {
      menu?.classList.remove('hidden')
    }

    const hideMenu = () => {
      menu?.classList.add('hidden')
    }

    if (triggerType === 'hover') {
      trigger.addEventListener('mouseenter', showMenu)
      dropdown?.addEventListener('mouseleave', hideMenu)
    } else {
      trigger.addEventListener('click', (e) => {
        e.stopPropagation()
        menu?.classList.toggle('hidden')
      })
    }
  })

  document.addEventListener('click', () => {
    document.querySelectorAll('[data-dropdown-menu]').forEach(menu => {
      menu.classList.add('hidden')
    })
  })
</script>