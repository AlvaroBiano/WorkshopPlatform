---
interface Toast {
  id: string
  type: 'success' | 'error' | 'warning' | 'info'
  message: string
  duration?: number
}

interface Props {
  toasts?: Toast[]
  class?: string
}

const {
  toasts = [],
  class: className = '',
} = Astro.props

const icons = {
  success: `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>`,
  error: `<circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>`,
  warning: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>`,
  info: `<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>`,
}

const typeClasses = {
  success: 'border-verde-principal/50 bg-verde-principal/10',
  error: 'border-vermelho/50 bg-vermelho/10',
  warning: 'border-dourado/50 bg-dourado/10',
  info: 'border-azul-accent/50 bg-azul-accent/10',
}

const iconColorClasses = {
  success: 'text-verde-claro',
  error: 'text-vermelho',
  warning: 'text-dourado',
  info: 'text-azul-accent',
}
---

<div
  id="toast-container"
  class:list={['fixed bottom-6 right-6 z-[100] flex flex-col gap-3 max-w-sm w-full pointer-events-none', className]}
>
  <slot />
</div>

<template id="toast-template">
  <div
    class="toast-item pointer-events-auto transform transition-all duration-300 translate-x-full opacity-0"
    data-toast-id
  >
    <div class="bg-bg-card border rounded-xl p-4 shadow-xl flex items-start gap-3" data-toast-inner>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="flex-shrink-0 mt-0.5"
        data-toast-icon
      ></svg>
      <p class="flex-1 text-sm text-text-light" data-toast-message></p>
      <button
        type="button"
        class="p-1 text-text-muted hover:text-text-light transition-colors"
        data-toast-close
        aria-label="Fechar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </div>
  </div>
</template>

<script is:inline>
  window.showToast = function(type, message, duration = 5000) {
    const container = document.getElementById('toast-container')
    const template = document.getElementById('toast-template')
    
    if (!container || !template) return

    const id = 'toast-' + Date.now() + '-' + Math.random().toString(36).slice(2)
    const toast = template.content.cloneNode(true).querySelector('.toast-item')
    
    if (!toast) return

    const icons = {
      success: `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>`,
      error: `<circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>`,
      warning: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>`,
      info: `<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>`,
    }

    const typeClasses = {
      success: 'border-verde-principal/50 bg-verde-principal/10',
      error: 'border-vermelho/50 bg-vermelho/10',
      warning: 'border-dourado/50 bg-dourado/10',
      info: 'border-azul-accent/50 bg-azul-accent/10',
    }

    const iconColorClasses = {
      success: 'text-verde-claro',
      error: 'text-vermelho',
      warning: 'text-dourado',
      info: 'text-azul-accent',
    }

    toast.dataset.toastId = id
    const inner = toast.querySelector('[data-toast-inner]')
    const iconEl = toast.querySelector('[data-toast-icon]')
    const messageEl = toast.querySelector('[data-toast-message]')
    const closeBtn = toast.querySelector('[data-toast-close]')

    if (inner) inner.classList.add(...typeClasses[type].split(' '))
    if (iconEl) {
      iconEl.innerHTML = icons[type]
      iconEl.classList.add(iconColorClasses[type])
    }
    if (messageEl) messageEl.textContent = message

    closeBtn?.addEventListener('click', () => removeToast(id))

    container.appendChild(toast)

    requestAnimationFrame(() => {
      toast.classList.remove('translate-x-full', 'opacity-0')
      toast.classList.add('translate-x-0', 'opacity-100')
    })

    if (duration > 0) {
      setTimeout(() => removeToast(id), duration)
    }

    return id
  }

  window.removeToast = function(id) {
    const toast = document.querySelector(`[data-toast-id="${id}"]`)
    if (!toast) return

    toast.classList.remove('translate-x-0', 'opacity-100')
    toast.classList.add('translate-x-full', 'opacity-0')

    setTimeout(() => toast.remove(), 300)
  }
</script>