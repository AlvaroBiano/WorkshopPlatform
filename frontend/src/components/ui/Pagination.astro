---
interface Props {
  currentPage: number
  totalPages: number
  totalItems: number
  itemsPerPage?: number
  showInfo?: boolean
  class?: string
  onPageChange?: string
}

const {
  currentPage,
  totalPages,
  totalItems,
  itemsPerPage = 20,
  showInfo = true,
  class: className = '',
  onPageChange,
} = Astro.props

const startItem = (currentPage - 1) * itemsPerPage + 1
const endItem = Math.min(currentPage * itemsPerPage, totalItems)

const visiblePages = () => {
  const pages: (number | string)[] = []
  const showEllipsis = totalPages > 7

  if (!showEllipsis) {
    for (let i = 1; i <= totalPages; i++) {
      pages.push(i)
    }
  } else {
    if (currentPage <= 4) {
      for (let i = 1; i <= 5; i++) pages.push(i)
      pages.push('...')
      pages.push(totalPages)
    } else if (currentPage >= totalPages - 3) {
      pages.push(1)
      pages.push('...')
      for (let i = totalPages - 4; i <= totalPages; i++) pages.push(i)
    } else {
      pages.push(1)
      pages.push('...')
      for (let i = currentPage - 1; i <= currentPage + 1; i++) pages.push(i)
      pages.push('...')
      pages.push(totalPages)
    }
  }

  return pages
}

const getPageHandler = onPageChange 
  ? `${onPageChange}(page)`
  : `window.location.href = '?page=' + page`
---

<div class:list={['flex flex-col sm:flex-row items-center justify-between gap-4', className]}>
  {showInfo && (
    <div class="text-sm text-text-muted">
      Mostrando <span class="font-semibold text-text-light">{startItem}</span> a <span class="font-semibold text-text-light">{endItem}</span> de <span class="font-semibold text-text-light">{totalItems}</span> itens
    </div>
  )}

  <div class="flex items-center gap-2">
    <button
      type="button"
      onclick={`${onPageChange ? `${onPageChange}(${currentPage - 1})` : `window.location.href = '?page=${currentPage - 1}'}`}
      disabled={currentPage <= 1}
      class:list={[
        'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
        currentPage <= 1 
          ? 'bg-white/5 text-text-muted cursor-not-allowed opacity-50' 
          : 'bg-bg-dark text-text-light hover:bg-white/10 hover:text-dourado',
      ]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline mr-1">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Anterior
    </button>

    <div class="flex items-center gap-1">
      {visiblePages().map(page => (
        page === '...' ? (
          <span class="px-3 py-2 text-text-muted">...</span>
        ) : (
          <button
            type="button"
            onclick={getPageHandler.replace('page', String(page))}
            class:list={[
              'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 min-w-[40px]',
              currentPage === page
                ? 'bg-verde-principal text-white'
                : 'bg-bg-dark text-text-light hover:bg-white/10 hover:text-dourado',
            ]}
          >
            {page}
          </button>
        )
      ))}
    </div>

    <button
      type="button"
      onclick={onPageChange ? `${onPageChange}(${currentPage + 1})` : `window.location.href = '?page=${currentPage + 1}'`}
      disabled={currentPage >= totalPages}
      class:list={[
        'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
        currentPage >= totalPages 
          ? 'bg-white/5 text-text-muted cursor-not-allowed opacity-50' 
          : 'bg-bg-dark text-text-light hover:bg-white/10 hover:text-dourado',
      ]}
    >
      Próximo
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline ml-1">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>
  </div>
</div>