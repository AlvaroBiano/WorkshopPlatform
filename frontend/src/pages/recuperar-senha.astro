---
import AuthLayout from '../layouts/AuthLayout.astro'
---

<AuthLayout title="Recuperar Senha | WORKSHOP">
  <div class="min-h-screen flex items-center justify-center px-4 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-azul-profundo via-bg-dark to-verde-principal opacity-40"></div>

    <div class="relative z-10 w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="font-display text-4xl font-bold text-dourado">WORKSHOP</h1>
        <p class="text-text-muted mt-2 tracking-widest text-sm uppercase">Grupo Braga & Biano</p>
      </div>

      <div class="card p-8">
        <h2 class="text-2xl font-display text-dourado mb-1">Recuperar Senha</h2>
        <p class="text-text-muted mb-6">
          Informe seu e-mail e CPF. Sua senha será resetada para o CPF informado.
        </p>

        <form id="recoverForm" class="space-y-5">
          <div>
            <label for="email" class="block text-sm font-medium text-text-muted mb-2">E-mail cadastrado</label>
            <input id="email" type="email" required class="input" placeholder="seu@email.com" />
          </div>

          <div>
            <label for="cpf" class="block text-sm font-medium text-text-muted mb-2">CPF (será sua nova senha)</label>
            <input id="cpf" type="text" required class="input" placeholder="00000000000" maxlength="11" />
          </div>

          <div id="errorMsg" class="hidden p-3 rounded-lg text-sm bg-vermelho/10 border border-vermelho/30 text-vermelho"></div>
          <div id="successMsg" class="hidden p-3 rounded-lg text-sm bg-verde-claro/10 border border-verde-claro/30 text-verde-claro"></div>

          <button type="submit" id="submitBtn" class="btn btn-primary w-full">
            <span id="btnText">Resetar Senha</span>
            <span id="btnLoading" class="hidden">Processando...</span>
          </button>
        </form>

        <div class="mt-6 pt-6 border-t border-white/5 text-center">
          <a href="/login" class="text-sm text-dourado hover:underline">Voltar ao login</a>
        </div>
      </div>
    </div>
  </div>
</AuthLayout>

<script>
  const form = document.getElementById('recoverForm') as HTMLFormElement
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement
  const successMsg = document.getElementById('successMsg') as HTMLDivElement
  const btnText = document.getElementById('btnText') as HTMLSpanElement
  const btnLoading = document.getElementById('btnLoading') as HTMLSpanElement
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorMsg.classList.add('hidden')
    successMsg.classList.add('hidden')
    btnText.classList.add('hidden')
    btnLoading.classList.remove('hidden')
    submitBtn.disabled = true

    const email = (document.getElementById('email') as HTMLInputElement).value.trim().toLowerCase()
    const cpf = (document.getElementById('cpf') as HTMLInputElement).value.replace(/\D/g, '')

    if (cpf.length !== 11) {
      errorMsg.textContent = 'CPF deve ter 11 dígitos'
      errorMsg.classList.remove('hidden')
      btnText.classList.remove('hidden')
      btnLoading.classList.add('hidden')
      submitBtn.disabled = false
      return
    }

    try {
      const response = await fetch('/api/recuperar-senha', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, cpf }),
      })

      const data = await response.json()

      if (!response.ok) {
        throw new Error(data.error || 'Erro ao processar')
      }

      successMsg.textContent = data.message || 'Senha resetada com sucesso! Faça login com seu CPF.'
      successMsg.classList.remove('hidden')
      form.reset()
    } catch (err: any) {
      errorMsg.textContent = err.message || 'Erro ao enviar solicitação'
      errorMsg.classList.remove('hidden')
    } finally {
      btnText.classList.remove('hidden')
      btnLoading.classList.add('hidden')
      submitBtn.disabled = false
    }
  })
</script>
