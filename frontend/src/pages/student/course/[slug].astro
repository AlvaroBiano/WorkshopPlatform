---
import StudentLayout from '../../../layouts/StudentLayout.astro'
import { db } from '@lib/turso'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const slug = Astro.params.slug
const requestedLessonId = Astro.url.searchParams.get('lesson')

const productResult = await db.execute({
  sql: 'SELECT * FROM products WHERE slug = ?',
  args: [slug],
})

if (productResult.rows.length === 0) return new Response('Não encontrado', { status: 404 })
const product = productResult.rows[0] as any

const accessResult = await db.execute({
  sql: 'SELECT * FROM product_access WHERE user_id = ? AND product_id = ?',
  args: [user.id, product.id],
})

if (accessResult.rows.length === 0) return Astro.redirect('/student?error=no_access')

const modulesResult = await db.execute({
  sql: 'SELECT * FROM modules WHERE product_id = ? ORDER BY sort_order ASC',
  args: [product.id],
})
const modulesList = modulesResult.rows as any[]

const lessonsResult = modulesList.length > 0
  ? await db.execute({
      sql: `SELECT * FROM lessons WHERE module_id IN (${modulesList.map(() => '?').join(',')}) ORDER BY sort_order ASC`,
      args: modulesList.map(m => m.id),
    })
  : { rows: [] }
const lessonsList = lessonsResult.rows as any[]

const progressResult = await db.execute({
  sql: 'SELECT * FROM progress WHERE user_id = ?',
  args: [user.id],
})
const progressList = progressResult.rows as any[]
const progressMap = Object.fromEntries(progressList.map((p: any) => [p.lesson_id, p]))

const allLessons = modulesList.flatMap((m: any) =>
  lessonsList
    .filter((l: any) => l.module_id === m.id)
    .map((l: any) => ({ ...l, moduleTitle: m.title, moduleId: m.id }))
)

let currentLesson = requestedLessonId
  ? allLessons.find((l: any) => l.id === requestedLessonId)
  : allLessons.find((l: any) => !progressMap[l.id]?.completed) || allLessons[0]

if (!currentLesson) currentLesson = allLessons[0]

const completedCount = allLessons.filter((l: any) => progressMap[l.id]?.completed).length
const totalCount = allLessons.length
---

<StudentLayout title={`${currentLesson?.title || 'Aula'} | WORKSHOP`}>
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-6">
    <div>
      <div class="aspect-video bg-black rounded-xl overflow-hidden mb-4">
        {currentLesson?.type === 'vimeo' && currentLesson?.vimeo_id ? (
          <iframe
            src={`https://player.vimeo.com/video/${currentLesson.vimeo_id}?autoplay=1`}
            class="w-full h-full"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          ></iframe>
        ) : currentLesson?.type === 'youtube' && currentLesson?.youtube_url ? (
          <iframe
            src={`https://www.youtube.com/embed/${new URL(currentLesson.youtube_url).searchParams.get('v')}?autoplay=1`}
            class="w-full h-full"
            frameborder="0"
            allow="autoplay; fullscreen"
            allowfullscreen
          ></iframe>
        ) : currentLesson?.type === 'pdf' && currentLesson?.file_url ? (
          <iframe src={currentLesson.file_url} class="w-full h-full"></iframe>
        ) : currentLesson?.video_url ? (
          <video src={currentLesson.video_url} controls autoplay class="w-full h-full"></video>
        ) : (
          <div class="w-full h-full flex items-center justify-center text-text-muted">
            <p>Conteúdo: {currentLesson?.type || 'video'}</p>
          </div>
        )}
      </div>

      <div class="card p-6">
        <h1 class="text-2xl font-display font-bold text-dourado mb-2">{currentLesson?.title}</h1>
        {currentLesson?.description && (
          <p class="text-text-muted mb-4">{currentLesson.description}</p>
        )}
        <div class="flex flex-wrap gap-3">
          <button id="markComplete" class="btn btn-primary">
            {progressMap[currentLesson?.id]?.completed ? '✓ Concluída' : '✓ Marcar como concluída'}
          </button>
          {currentLesson?.file_url && (
            <a href={currentLesson.file_url} target="_blank" class="btn btn-secondary">
              Baixar Material
            </a>
          )}
        </div>
      </div>
    </div>

    <aside class="card max-h-[calc(100vh-120px)] overflow-y-auto">
      <div class="p-4 border-b border-white/5 sticky top-0 bg-bg-card z-10">
        <h2 class="font-bold text-dourado">{product.title}</h2>
        <p class="text-xs text-text-muted mt-1">
          {completedCount} de {totalCount} aulas concluídas
        </p>
        <div class="h-1.5 bg-white/10 rounded mt-2 overflow-hidden">
          <div
            class="h-full bg-gradient-to-r from-verde-principal to-verde-claro"
            style={`width: ${totalCount ? Math.round((completedCount / totalCount) * 100) : 0}%`}
          ></div>
        </div>
      </div>

      {modulesList.map((m: any, mi: number) => (
        <div>
          <div class="px-4 py-3 bg-white/5 sticky top-[89px]">
            <h3 class="font-semibold text-sm">
              <span class="text-dourado">M{mi + 1}</span> · {m.title}
            </h3>
          </div>
          {lessonsList.filter((l: any) => l.module_id === m.id).map((l: any, li: number) => {
            const prog = progressMap[l.id]
            const isCurrent = l.id === currentLesson?.id
            return (
              <a
                href={`/student/course/${slug}?lesson=${l.id}`}
                class:list={[
                  'flex items-start gap-3 px-4 py-3 border-l-2 hover:bg-white/5 transition-colors',
                  isCurrent ? 'border-l-dourado bg-white/5' : 'border-l-transparent'
                ]}
              >
                <div class:list={[
                  'flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold',
                  prog?.completed ? 'bg-verde-claro text-white' :
                  isCurrent ? 'bg-dourado text-azul-profundo' :
                  'bg-white/10 text-text-muted'
                ]}>
                  {prog?.completed ? '✓' : li + 1}
                </div>
                <div class="flex-1 min-w-0">
                  <p class:list={['text-sm', isCurrent ? 'text-dourado font-semibold' : '']}>
                    {l.title}
                  </p>
                  <p class="text-xs text-text-muted mt-0.5">
                    {Math.floor((l.duration_sec || 0) / 60)} min
                    {prog?.watched_sec > 0 && !prog.completed && (
                      <span class="ml-2 text-dourado">
                        · {Math.floor(prog.watched_sec / 60)}min assistidos
                      </span>
                    )}
                  </p>
                </div>
              </a>
            )
          })}
        </div>
      ))}
    </aside>
  </div>

  <section class="bg-azul-profundo rounded-xl border border-white/10 p-6 mt-8" id="comments-section">
    <h2 class="text-xl font-display font-bold text-dourado mb-4">Comentários da Aula</h2>
    <form id="comment-form" class="mb-6 flex flex-col gap-3">
      <textarea id="comment-text" rows="2" placeholder="Deixe um comentário ou dúvida..." class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors resize-none"></textarea>
      <div class="flex justify-end">
        <button type="submit" class="bg-verde-principal hover:bg-verde-claro text-white px-6 py-2 rounded-lg font-semibold transition-colors text-sm">Comentar</button>
      </div>
    </form>
    <div id="comments-list" class="space-y-3">
      <p class="text-text-muted text-sm text-center py-4">Carregando...</p>
    </div>
  </section>
</StudentLayout>

<script define:vars={{ lessonId: currentLesson?.id, userId: user?.id, slug }}>
  let watchedSec = 0
  let startTime = Date.now()

  async function loadComments() {
    if (!lessonId) return
    try {
      const res = await fetch(`/api/products/comments?lesson_id=${lessonId}`)
      const data = await res.json()
      const list = document.getElementById('comments-list')
      if (!list) return
      const comments = data.comments || []
      if (comments.length === 0) {
        list.innerHTML = '<p class="text-text-muted text-sm text-center py-4">Nenhum comentário ainda. Seja o primeiro!</p>'
        return
      }
      list.innerHTML = comments.map((c: any) => `
        <div class="bg-bg-dark/50 rounded-lg p-3">
          <div class="flex items-center gap-2 mb-1">
            <span class="font-semibold text-sm text-dourado">${escapeHtml(c.full_name || 'Usuário')}</span>
            <span class="text-text-muted text-xs">${new Date(c.created_at).toLocaleString('pt-BR')}</span>
          </div>
          <p class="text-text-light text-sm whitespace-pre-wrap">${escapeHtml(c.body)}</p>
        </div>
      `).join('')
    } catch (e) {
      console.error('Erro ao carregar comentários:', e)
    }
  }

  function escapeHtml(text: any): string {
    if (text == null) return ''
    return String(text).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;')
  }

  document.getElementById('comment-form')?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!lessonId) return
    const text = (document.getElementById('comment-text') as HTMLTextAreaElement).value.trim()
    if (!text) return

    try {
      const res = await fetch('/api/products/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lesson_id: lessonId, body: text }),
      })
      if (res.ok) {
        ;(document.getElementById('comment-text') as HTMLTextAreaElement).value = ''
        await loadComments()
      } else {
        const err = await res.json().catch(() => ({}))
        window.showToast?.('error', err.error || 'Erro ao comentar')
      }
    } catch (e) {
      window.showToast?.('error', 'Erro ao comentar')
    }
  })

  loadComments()
  let watchedSec = 0
  let startTime = Date.now()

  setInterval(() => {
    watchedSec = Math.floor((Date.now() - startTime) / 1000)
    fetch('/student/api/progress', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        lessonId,
        watchedSec,
        lastPositionSec: watchedSec,
      }),
    }).catch(() => {})
  }, 15000)

  document.getElementById('markComplete')?.addEventListener('click', async () => {
    const btn = document.getElementById('markComplete') as HTMLButtonElement
    btn.disabled = true
    btn.textContent = 'Salvando...'

    const res = await fetch('/student/api/progress', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        lessonId,
        watchedSec,
        lastPositionSec: watchedSec,
        completed: true,
      }),
    })

    if (res.ok) {
      btn.textContent = '✓ Concluída'
      setTimeout(() => location.reload(), 500)
    } else {
      btn.textContent = 'Erro. Tente novamente.'
      btn.disabled = false
    }
  })

  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return

    const links = Array.from(document.querySelectorAll('aside a'))
    const currentIdx = links.findIndex(l => l.href.includes(lessonId))

    if (e.key === 'ArrowRight' && links[currentIdx + 1]) {
      location.href = links[currentIdx + 1].href
    }
    if (e.key === 'ArrowLeft' && links[currentIdx - 1]) {
      location.href = links[currentIdx - 1].href
    }
  })
</script>
