---
import StudentLayout from '../../layouts/StudentLayout.astro'
import { db } from '../../lib/turso'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const accessResult = await db.execute({
  sql: `SELECT pa.product_id, p.id, p.title, p.slug, p.description, p.cover_url, p.type
        FROM product_access pa
        JOIN products p ON pa.product_id = p.id
        WHERE pa.user_id = ?`,
  args: [user.id],
})

const accessList = accessResult.rows as any[]

const modulesResult = accessList.length > 0
  ? await db.execute({
      sql: `SELECT m.id, m.product_id, m.title, m.sort_order FROM modules m WHERE m.product_id IN (${accessList.map(() => '?').join(',')})`,
      args: accessList.map(a => a.product_id),
    })
  : { rows: [] }

const modulesList = modulesResult.rows as any[]

const lessonsResult = modulesList.length > 0
  ? await db.execute({
      sql: `SELECT l.id, l.module_id, l.duration_sec FROM lessons l WHERE l.module_id IN (${modulesList.map(() => '?').join(',')})`,
      args: modulesList.map(m => m.id),
    })
  : { rows: [] }

const lessonsList = lessonsResult.rows as any[]

const progressResult = await db.execute({
  sql: 'SELECT lesson_id, completed, watched_sec, last_seen_at FROM progress WHERE user_id = ?',
  args: [user.id],
})

const progressList = progressResult.rows as any[]
const progressMap = Object.fromEntries(progressList.map(p => [p.lesson_id, p]))

const courses = accessList.map(product => {
  const productModules = modulesList.filter(m => m.product_id === product.id)
  const allLessons = productModules.flatMap(m => lessonsList.filter(l => l.module_id === m.id))
  const totalDuration = allLessons.reduce((sum, l) => sum + (l.duration_sec || 0), 0)
  const watchedDuration = progressList
    .filter(p => allLessons.some(l => l.id === p.lesson_id))
    .reduce((sum, p) => sum + (p.watched_sec || 0), 0)
  const percent = totalDuration ? Math.round((watchedDuration / totalDuration) * 100) : 0
  return { ...product, progress: percent }
})

let continueWatching: any[] = []
try {
  const cwResult = await db.execute({
    sql: `SELECT p.lesson_id, p.watched_sec, p.last_seen_at, l.title as lesson_title, l.duration_sec,
                 m.title as module_title, m.product_id, pr.title as product_title, pr.slug, pr.cover_url
          FROM progress p
          JOIN lessons l ON p.lesson_id = l.id
          JOIN modules m ON l.module_id = m.id
          JOIN products pr ON m.product_id = pr.id
          JOIN product_access pa ON pa.user_id = p.user_id AND pa.product_id = pr.id
          WHERE p.user_id = ? AND p.completed = 0 AND p.watched_sec > 0
          ORDER BY p.last_seen_at DESC LIMIT 5`,
    args: [user.id],
  })
  continueWatching = cwResult.rows as any[]
} catch (error) {
  console.error('Erro ao carregar continue assistindo:', error)
}
---

<StudentLayout title="Meus Cursos | WORKSHOP">
  {continueWatching.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl font-display font-bold mb-4 flex items-center gap-2 text-dourado">
        Continue assistindo
      </h2>
      <div class="flex gap-4 overflow-x-auto pb-4">
        {continueWatching.map((cw: any) => (
          <a
            href={`/student/course/${cw.slug}?lesson=${cw.lesson_id}`}
            class="flex-shrink-0 w-80 card group relative overflow-hidden"
          >
            <div class="aspect-video bg-bg-card relative">
              {cw.cover_url ? (
                <img
                  src={cw.cover_url}
                  alt=""
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-azul-profundo to-verde-principal">
                  <span class="text-4xl">🎓</span>
                </div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-bg-dark/90 to-transparent flex items-end p-4">
                <div class="w-full">
                  <p class="font-bold mb-1 text-sm">{cw.product_title}</p>
                  <p class="text-xs text-text-muted mb-2">{cw.lesson_title}</p>
                  <div class="h-1 bg-white/10 rounded overflow-hidden">
                    <div
                      class="h-full bg-dourado"
                      style={`width: ${Math.min(100, ((cw.watched_sec || 0) / (cw.duration_sec || 1)) * 100)}%`}
                    ></div>
                  </div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <h2 class="text-2xl font-display font-bold mb-4 text-dourado">Meus Cursos</h2>

    {courses.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-text-muted text-lg">Nenhum curso disponível ainda.</p>
        <a href="/" class="text-dourado hover:underline mt-2 inline-block">Ver cursos disponíveis</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {courses.map((c: any) => (
          <a href={`/student/course/${c.slug}`} class="card group overflow-hidden">
            <div class="aspect-video bg-bg-card relative overflow-hidden">
              {c.cover_url ? (
                <img
                  src={c.cover_url}
                  alt={c.title}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-azul-profundo to-verde-principal">
                  <span class="text-5xl">🎓</span>
                </div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-bg-dark via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <div class="w-16 h-16 rounded-full bg-dourado/90 flex items-center justify-center text-azul-profundo text-2xl">
                  ▶
                </div>
              </div>
            </div>
            <div class="p-4">
              <span class="text-xs text-text-muted uppercase tracking-wide">{c.type}</span>
              <h3 class="font-bold mt-1 mb-3 line-clamp-2 group-hover:text-dourado transition-colors">
                {c.title}
              </h3>
              <div class="flex items-center gap-2 mb-2">
                <div class="flex-1 h-1.5 bg-white/10 rounded overflow-hidden">
                  <div class="h-full bg-gradient-to-r from-verde-principal to-verde-claro" style={`width: ${c.progress}%`}></div>
                </div>
                <span class="text-xs text-text-muted">{c.progress}%</span>
              </div>
              <p class="text-xs text-text-muted">
                {c.progress === 0 ? 'Não iniciado' : c.progress === 100 ? 'Concluído' : 'Em andamento'}
              </p>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</StudentLayout>
