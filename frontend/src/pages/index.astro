---
import Layout from '../layouts/Layout.astro'
import Icon from '../components/ui/Icon.astro'
import Button from '../components/ui/Button.astro'
import { db } from '@lib/turso'

const refCode = Astro.url.searchParams.get('ref')

let products: any[] = []
try {
  const result = await db.execute({
    sql: `SELECT p.*, 
          (SELECT COALESCE(AVG(rating), 0) FROM reviews WHERE product_id = p.id AND status = 'approved') as avg_rating,
          (SELECT COUNT(*) FROM reviews WHERE product_id = p.id AND status = 'approved') as total_reviews
          FROM products p WHERE p.status = 'published' ORDER BY p.created_at DESC`,
    args: [],
  })
  products = result.rows as any[]
} catch (error) {
  console.error('Erro ao carregar produtos:', error)
}
---

<Layout title="WORKSHOP | Grupo Braga & Biano">
  <section class="min-h-screen flex items-center justify-center px-4 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-azul-profundo via-bg-dark to-verde-principal opacity-50"></div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <h1 class="font-display text-5xl md:text-7xl text-dourado mb-4 animate-fade-in">
        WORKSHOP
      </h1>
      <p class="text-xl md:text-2xl text-text-muted mb-8 animate-slide-up">
        Grupo Braga & Biano
      </p>

      <p class="text-lg md:text-xl text-text-light max-w-2xl mx-auto mb-12 animate-slide-up" style="animation-delay: 0.1s">
        Transforme sua vida com nossos workshops premium de alta transformação.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.2s">
        <Button href="/login" variant="primary" size="lg">
          Entrar na Área de Membros
        </Button>
        <Button href={refCode ? `/cadastro?ref=${refCode}` : '/cadastro'} variant="secondary" size="lg">
          Quero Participar
        </Button>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-bg-dark to-transparent"></div>
  </section>

  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl text-dourado text-center mb-16">
        Nossos Programas
      </h2>

      {products.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-text-muted">Nenhum programa disponível no momento.</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {products.map(product => (
            <a href={`/produto/${product.slug}`} class="bg-azul-profundo rounded-xl border border-white/10 overflow-hidden hover:shadow-lg transition-shadow group">
              {product.cover_url ? (
                <img src={product.cover_url} alt={product.title} class="w-full h-48 object-cover group-hover:scale-105 transition-transform" />
              ) : (
                <div class="w-full h-48 bg-bg-dark flex items-center justify-center">
                  <Icon name="package" size={48} class="text-text-muted/30" />
                </div>
              )}
              <div class="p-6">
                <span class="text-xs text-text-muted uppercase tracking-wide">{product.type}</span>
                <h3 class="text-xl font-display font-bold text-dourado mt-1 mb-2">{product.title}</h3>
                <p class="text-text-muted text-sm mb-4 line-clamp-2">{product.description || ''}</p>
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-dourado"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <span class="text-text-muted text-sm">{Number(product.avg_rating || 0).toFixed(1)} ({product.total_reviews || 0})</span>
                  </div>
                  <span class="text-xl font-bold text-verde-claro">R$ {((product.price_cents || 0) / 100).toFixed(2)}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="py-20 px-4 bg-bg-card">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-display text-3xl md:text-4xl text-dourado mb-6">
        Pronto Para Começar?
      </h2>
      <p class="text-lg text-text-muted mb-8">
        Acesso imediato após confirmação do pagamento. Sua jornada de transformação começa hoje.
      </p>
      <Button href={refCode ? `/cadastro?ref=${refCode}` : '/cadastro'} variant="primary" size="lg">
        Garantir Minha Vaga
      </Button>
    </div>
  </section>
</Layout>
