---
import AdminLayout from '../../layouts/AdminLayout.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import Icon from '../../components/ui/Icon.astro'
import { getSessionFromCookies, isAdmin } from '../../lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Gestão de Dispositivos">
  <div class="mb-8">
    <h1 class="text-3xl font-display font-bold text-dourado mb-6">Gestão de Dispositivos</h1>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-dourado/10 flex items-center justify-center">
            <Icon name="monitor" size={20} class="text-dourado" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Total</span>
        </div>
        <p class="text-3xl font-display font-bold text-dourado" id="stat-total">0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-verde-principal/10 flex items-center justify-center">
            <Icon name="check-circle" size={20} class="text-verde-claro" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Aprovados</span>
        </div>
        <p class="text-3xl font-display font-bold text-verde-claro" id="stat-approved">0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-dourado/10 flex items-center justify-center">
            <Icon name="clock" size={20} class="text-dourado" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Pendentes</span>
        </div>
        <p class="text-3xl font-display font-bold text-dourado" id="stat-pending">0</p>
      </Card>
    </div>
  </div>

  <Card class="p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Buscar</label>
        <input 
          type="text" 
          id="search-input"
          placeholder="Nome, email ou dispositivo..."
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Status</label>
        <select 
          id="status-filter"
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
        >
          <option value="">Todos</option>
          <option value="approved">Aprovados</option>
          <option value="pending">Pendentes</option>
        </select>
      </div>
      <div class="flex items-end">
        <button 
          onclick="loadDevices()"
          class="w-full bg-verde-principal hover:bg-verde-claro text-white px-6 py-2.5 rounded-lg font-semibold transition-colors inline-flex items-center justify-center gap-2"
        >
          <Icon name="filter" size={16} />
          Filtrar
        </button>
      </div>
    </div>
  </Card>

  <Card padding="none">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-bg-dark/50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Usuário</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Dispositivo</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">IP</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Status</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Registro</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Último Acesso</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody id="devices-table">
          <tr id="loading-row">
            <td colspan="7" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center">
                <div class="animate-spin rounded-full h-10 w-10 border-2 border-dourado/20 border-t-dourado mb-4"></div>
                <p class="text-text-muted">Carregando dispositivos...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="px-6 py-4 bg-bg-dark/50 flex justify-between items-center border-t border-white/5">
      <div class="text-sm text-text-muted">
        Mostrando <span id="showing-start" class="font-semibold text-text-light">0</span> a <span id="showing-end" class="font-semibold text-text-light">0</span> de <span id="total-items" class="font-semibold text-text-light">0</span> dispositivos
      </div>
      <div class="flex gap-2" id="pagination-controls"></div>
    </div>
  </Card>
</AdminLayout>

<script>
  let currentPage = 1
  let currentSearch = ''
  let currentStatus = ''

  async function loadDevices() {
    currentSearch = document.getElementById('search-input').value
    currentStatus = document.getElementById('status-filter').value

    const params = new URLSearchParams({
      page: currentPage.toString(),
      limit: '20',
      search: currentSearch,
      status: currentStatus,
    })

    try {
      const response = await fetch(`/admin/api/devices?${params}`)
      const data = await response.json()

      if (!response.ok) throw new Error(data.error || 'Erro ao carregar')

      renderDevices(data.devices)
      renderPagination(data)
      updateStats(data)
    } catch (error: any) {
      console.error('Erro ao carregar dispositivos:', error)
      document.getElementById('devices-table').innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <Icon name="alert-circle" size={48} class="text-vermelho mb-4" />
              <p class="text-vermelho font-medium mb-2">Erro ao carregar dispositivos</p>
              <p class="text-text-muted text-sm">${error.message}</p>
              <button onclick="loadDevices()" class="mt-4 px-4 py-2 bg-dourado/10 text-dourado rounded-lg hover:bg-dourado/20 transition-colors">
                Tentar novamente
              </button>
            </div>
          </td>
        </tr>
      `
    }
  }

  function renderDevices(devices) {
    const tbody = document.getElementById('devices-table')
    
    if (!devices || devices.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <Icon name="monitor" size={48} class="text-text-muted/30 mb-4" />
              <p class="text-text-muted">Nenhum dispositivo encontrado</p>
            </div>
          </td>
        </tr>
      `
      return
    }

    tbody.innerHTML = devices.map(device => {
      const statusBadge = device.is_approved 
        ? '<Badge variant="success">Aprovado</Badge>'
        : '<Badge variant="warning">Pendente</Badge>'

      const actions = !device.is_approved 
        ? `<button onclick="approveDevice('${device.id}')" class="text-verde-claro hover:text-verde-claro/80 text-sm font-medium flex items-center gap-1">
             <Icon name="check" size={14} /> Aprovar
           </button>`
        : ''

      return `
        <tr class="border-t border-white/5 hover:bg-white/[0.02] transition-colors">
          <td class="px-6 py-4">
            <div class="font-medium text-text-light">${device.user_name || '—'}</div>
            <div class="text-text-muted text-sm">${device.user_email || '—'}</div>
          </td>
          <td class="px-6 py-4">
            <div class="text-text-light text-sm">${device.device_info || 'Desconhecido'}</div>
            <div class="text-text-muted text-xs font-mono">${(device.fingerprint || '').substring(0, 16) || '—'}...</div>
          </td>
          <td class="px-6 py-4 text-text-muted text-sm font-mono">${device.ip_address || '—'}</td>
          <td class="px-6 py-4">${statusBadge}</td>
          <td class="px-6 py-4 text-text-muted text-sm">${new Date(device.registered_at).toLocaleDateString('pt-BR')}</td>
          <td class="px-6 py-4 text-text-muted text-sm">${device.last_seen_at ? new Date(device.last_seen_at).toLocaleDateString('pt-BR') : 'Nunca'}</td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              ${actions}
              <button onclick="deleteDevice('${device.id}')" class="text-text-muted hover:text-vermelho text-sm font-medium flex items-center gap-1">
                <Icon name="trash" size={14} /> Remover
              </button>
            </div>
          </td>
        </tr>
      `
    }).join('')
  }

  function renderPagination(data) {
    const { page, totalPages, total } = data
    const start = (page - 1) * 20 + 1
    const end = Math.min(page * 20, total)

    document.getElementById('showing-start').textContent = start
    document.getElementById('showing-end').textContent = end
    document.getElementById('total-items').textContent = total

    const controls = document.getElementById('pagination-controls')
    let html = ''

    if (page > 1) {
      html += `<button onclick="goToPage(${page - 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Anterior</button>`
    }

    for (let i = 1; i <= totalPages; i++) {
      if (i === page) {
        html += `<button class="px-4 py-2 bg-verde-principal text-white rounded-lg text-sm font-medium">${i}</button>`
      } else if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
        html += `<button onclick="goToPage(${i})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">${i}</button>`
      } else if (i === page - 3 || i === page + 3) {
        html += `<span class="px-2 text-text-muted">...</span>`
      }
    }

    if (page < totalPages) {
      html += `<button onclick="goToPage(${page + 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Próximo</button>`
    }

    controls.innerHTML = html
  }

  function updateStats(data) {
    document.getElementById('stat-total').textContent = data.total
    document.getElementById('stat-approved').textContent = data.devices.filter(d => d.is_approved).length
    document.getElementById('stat-pending').textContent = data.devices.filter(d => !d.is_approved).length
  }

  function goToPage(page) {
    currentPage = page
    loadDevices()
  }

  async function approveDevice(id) {
    if (!confirm('Tem certeza que deseja aprovar este dispositivo?')) return

    try {
      const response = await fetch(`/admin/api/devices/${id}/approve`, { method: 'POST' })

      if (!response.ok) {
        const data = await response.json()
        throw new Error(data.error || 'Erro ao aprovar')
      }

      window.showToast('success', 'Dispositivo aprovado com sucesso!')
      loadDevices()
    } catch (error: any) {
      window.showToast('error', error.message)
    }
  }

  async function deleteDevice(id) {
    if (!confirm('Tem certeza que deseja remover este dispositivo? O usuário precisará fazer login novamente.')) return

    try {
      const response = await fetch(`/admin/api/devices/${id}/delete`, { method: 'DELETE' })

      if (!response.ok) {
        const data = await response.json()
        throw new Error(data.error || 'Erro ao remover')
      }

      window.showToast('success', 'Dispositivo removido com sucesso!')
      loadDevices()
    } catch (error: any) {
      window.showToast('error', error.message)
    }
  }

  let searchTimeout
  document.getElementById('search-input').addEventListener('input', () => {
    clearTimeout(searchTimeout)
    searchTimeout = setTimeout(loadDevices, 300)
  })

  document.getElementById('status-filter').addEventListener('change', loadDevices)

  loadDevices()
</script>