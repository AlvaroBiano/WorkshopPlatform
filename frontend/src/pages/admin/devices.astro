---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getSessionFromCookies, isAdmin } from '../../lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Gestão de Dispositivos">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-dourado mb-8">Gestão de Dispositivos</h1>

    <!-- Cards de Estatísticas -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-azul-profundo rounded-lg p-6">
        <div class="text-text-muted text-sm mb-2">Total de Dispositivos</div>
        <div class="text-3xl font-bold text-dourado" id="stat-total">0</div>
      </div>
      <div class="bg-azul-profundo rounded-lg p-6">
        <div class="text-text-muted text-sm mb-2">Dispositivos Aprovados</div>
        <div class="text-3xl font-bold text-verde-claro" id="stat-approved">0</div>
      </div>
      <div class="bg-azul-profundo rounded-lg p-6">
        <div class="text-text-muted text-sm mb-2">Dispositivos Pendentes</div>
        <div class="text-3xl font-bold text-dourado" id="stat-pending">0</div>
      </div>
    </div>

    <!-- Filtros -->
    <div class="bg-azul-profundo rounded-lg p-6 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-text-muted text-sm mb-2">Buscar</label>
          <input 
            type="text" 
            id="search-input"
            placeholder="Nome, email ou dispositivo..."
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
          />
        </div>
        <div>
          <label class="block text-text-muted text-sm mb-2">Status</label>
          <select 
            id="status-filter"
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
          >
            <option value="">Todos</option>
            <option value="approved">Aprovados</option>
            <option value="pending">Pendentes</option>
          </select>
        </div>
        <div class="flex items-end">
          <button 
            onclick="loadDevices()"
            class="w-full bg-verde-principal hover:bg-verde-escuro text-white px-6 py-2 rounded-lg font-semibold transition-colors"
          >
            Filtrar
          </button>
        </div>
      </div>
    </div>

    <!-- Tabela de Dispositivos -->
    <div class="bg-azul-profundo rounded-lg overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-bg-dark/50">
            <tr>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Usuário</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Dispositivo</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">IP</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Status</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Registro</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Último Acesso</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Ações</th>
            </tr>
          </thead>
          <tbody id="devices-table">
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-text-muted">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-dourado mx-auto"></div>
                <p class="mt-2">Carregando...</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Paginação -->
      <div class="px-6 py-4 bg-bg-dark/50 flex justify-between items-center">
        <div class="text-text-muted text-sm">
          Mostrando <span id="showing-start">0</span> a <span id="showing-end">0</span> de <span id="total-items">0</span> dispositivos
        </div>
        <div class="flex gap-2" id="pagination-controls">
          <!-- Botões de paginação serão inseridos via JS -->
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  let currentPage = 1
  let currentSearch = ''
  let currentStatus = ''

  async function loadDevices() {
    currentSearch = document.getElementById('search-input').value
    currentStatus = document.getElementById('status-filter').value

    const params = new URLSearchParams({
      page: currentPage.toString(),
      limit: '20',
      search: currentSearch,
      status: currentStatus,
    })

    try {
      const response = await fetch(`/admin/api/devices?${params}`)
      const data = await response.json()

      renderDevices(data.devices)
      renderPagination(data)
      updateStats(data)
    } catch (error) {
      console.error('Erro ao carregar dispositivos:', error)
      document.getElementById('devices-table').innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-8 text-center text-vermelho">
            Erro ao carregar dispositivos
          </td>
        </tr>
      `
    }
  }

  function renderDevices(devices) {
    const tbody = document.getElementById('devices-table')
    
    if (devices.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-8 text-center text-text-muted">
            Nenhum dispositivo encontrado
          </td>
        </tr>
      `
      return
    }

    tbody.innerHTML = devices.map(device => {
      const statusLabel = device.is_approved ? 'Aprovado' : 'Pendente'
      const statusColor = device.is_approved ? 'text-verde-claro' : 'text-dourado'

      return `
        <tr class="border-t border-verde-principal/10 hover:bg-bg-dark/30">
          <td class="px-6 py-4">
            <div class="text-text-light">${device.user_name || '—'}</div>
            <div class="text-text-muted text-sm">${device.user_email || '—'}</div>
          </td>
          <td class="px-6 py-4">
            <div class="text-text-light text-sm">${device.device_info || 'Desconhecido'}</div>
            <div class="text-text-muted text-xs font-mono">${device.fingerprint?.substring(0, 16) || '—'}...</div>
          </td>
          <td class="px-6 py-4 text-text-muted text-sm font-mono">${device.ip_address || '—'}</td>
          <td class="px-6 py-4">
            <span class="${statusColor} font-semibold">${statusLabel}</span>
          </td>
          <td class="px-6 py-4 text-text-muted text-sm">
            ${new Date(device.registered_at).toLocaleDateString('pt-BR')}
          </td>
          <td class="px-6 py-4 text-text-muted text-sm">
            ${device.last_seen_at ? new Date(device.last_seen_at).toLocaleDateString('pt-BR') : 'Nunca'}
          </td>
          <td class="px-6 py-4">
            <div class="flex gap-2">
              ${!device.is_approved ? `
                <button 
                  onclick="approveDevice('${device.id}')"
                  class="text-verde-claro hover:text-verde-claro/80 text-sm"
                >
                  Aprovar
                </button>
              ` : ''}
              <button 
                onclick="deleteDevice('${device.id}')"
                class="text-vermelho hover:text-vermelho/80 text-sm"
              >
                Remover
              </button>
            </div>
          </td>
        </tr>
      `
    }).join('')
  }

  function renderPagination(data) {
    const { page, totalPages, total, devices } = data
    const start = (page - 1) * 20 + 1
    const end = Math.min(page * 20, total)

    document.getElementById('showing-start').textContent = start
    document.getElementById('showing-end').textContent = end
    document.getElementById('total-items').textContent = total

    const controls = document.getElementById('pagination-controls')
    let html = ''

    if (page > 1) {
      html += `<button onclick="goToPage(${page - 1})" class="px-4 py-2 bg-bg-dark hover:bg-bg-dark/80 text-text-light rounded-lg">Anterior</button>`
    }

    for (let i = 1; i <= totalPages; i++) {
      if (i === page) {
        html += `<button class="px-4 py-2 bg-verde-principal text-white rounded-lg">${i}</button>`
      } else if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
        html += `<button onclick="goToPage(${i})" class="px-4 py-2 bg-bg-dark hover:bg-bg-dark/80 text-text-light rounded-lg">${i}</button>`
      } else if (i === page - 3 || i === page + 3) {
        html += `<span class="px-2 text-text-muted">...</span>`
      }
    }

    if (page < totalPages) {
      html += `<button onclick="goToPage(${page + 1})" class="px-4 py-2 bg-bg-dark hover:bg-bg-dark/80 text-text-light rounded-lg">Próximo</button>`
    }

    controls.innerHTML = html
  }

  function updateStats(data) {
    document.getElementById('stat-total').textContent = data.total
    document.getElementById('stat-approved').textContent = data.devices.filter(d => d.is_approved).length
    document.getElementById('stat-pending').textContent = data.devices.filter(d => !d.is_approved).length
  }

  function goToPage(page) {
    currentPage = page
    loadDevices()
  }

  async function approveDevice(id) {
    if (!confirm('Tem certeza que deseja aprovar este dispositivo?')) return

    try {
      const response = await fetch(`/admin/api/devices/${id}/approve`, {
        method: 'POST',
      })

      if (response.ok) {
        alert('Dispositivo aprovado com sucesso!')
        loadDevices()
      } else {
        const data = await response.json()
        alert(data.error || 'Erro ao aprovar dispositivo')
      }
    } catch (error) {
      alert('Erro ao aprovar dispositivo')
    }
  }

  async function deleteDevice(id) {
    if (!confirm('Tem certeza que deseja remover este dispositivo? O usuário precisará fazer login novamente.')) return

    try {
      const response = await fetch(`/admin/api/devices/${id}/delete`, {
        method: 'DELETE',
      })

      if (response.ok) {
        alert('Dispositivo removido com sucesso!')
        loadDevices()
      } else {
        const data = await response.json()
        alert(data.error || 'Erro ao remover dispositivo')
      }
    } catch (error) {
      alert('Erro ao remover dispositivo')
    }
  }

  loadDevices()
</script>
