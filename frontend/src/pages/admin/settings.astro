---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getSessionFromCookies, isAdmin } from '@lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Configurações">
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    <h1 class="text-3xl font-bold text-dourado mb-8">Configurações</h1>

    <form id="settings-form">
      <!-- Seção: Geral -->
      <div class="bg-azul-profundo rounded-lg p-6 mb-6">
        <h2 class="text-xl font-bold text-dourado mb-4">Geral</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-text-muted text-sm mb-2">Nome do Site</label>
            <input 
              type="text" 
              id="setting-site_name"
              class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
            />
            <p class="text-text-muted text-xs mt-1">Nome exibido no cabeçalho e título das páginas</p>
          </div>

          <div>
            <label class="block text-text-muted text-sm mb-2">Descrição do Site</label>
            <textarea 
              id="setting-site_description"
              rows="3"
              class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
            ></textarea>
            <p class="text-text-muted text-xs mt-1">Descrição para SEO e meta tags</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-text-muted text-sm mb-2">Email de Suporte</label>
              <input 
                type="email" 
                id="setting-support_email"
                class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
              />
              <p class="text-text-muted text-xs mt-1">Email exibido para contato</p>
            </div>

            <div>
              <label class="block text-text-muted text-sm mb-2">WhatsApp de Suporte</label>
              <input 
                type="text" 
                id="setting-support_whatsapp"
                placeholder="5511999999999"
                class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
              />
              <p class="text-text-muted text-xs mt-1">Número com código do país (apenas números)</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Seção: Acesso -->
      <div class="bg-azul-profundo rounded-lg p-6 mb-6">
        <h2 class="text-xl font-bold text-dourado mb-4">Acesso</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-text-muted text-sm mb-2">Máximo de Dispositivos por Usuário</label>
            <input 
              type="number" 
              id="setting-max_devices_per_user"
              min="1"
              max="10"
              class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
            />
            <p class="text-text-muted text-xs mt-1">Número máximo de dispositivos que um usuário pode usar simultaneamente</p>
          </div>

          <div class="flex items-center justify-between p-4 bg-bg-dark rounded-lg">
            <div>
              <div class="text-text-light font-semibold">Cadastro Aberto</div>
              <div class="text-text-muted text-sm">Permitir que novos usuários se cadastrem</div>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="setting-registration_enabled" class="sr-only peer" />
              <div class="w-11 h-6 bg-bg-dark/50 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-verde-principal"></div>
            </label>
          </div>

          <div class="flex items-center justify-between p-4 bg-bg-dark rounded-lg">
            <div>
              <div class="text-text-light font-semibold">Modo Manutenção</div>
              <div class="text-text-muted text-sm">Bloquear acesso ao site para manutenção</div>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="setting-maintenance_mode" class="sr-only peer" />
              <div class="w-11 h-6 bg-bg-dark/50 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-verde-principal"></div>
            </label>
          </div>
        </div>
      </div>

      <!-- Seção: Afiliados -->
      <div class="bg-azul-profundo rounded-lg p-6 mb-6">
        <h2 class="text-xl font-bold text-dourado mb-4">Afiliados</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-text-muted text-sm mb-2">Comissão Padrão (%)</label>
            <input 
              type="number" 
              id="setting-default_commission_pct"
              min="0"
              max="100"
              step="0.1"
              class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
            />
            <p class="text-text-muted text-xs mt-1">Comissão padrão para novos afiliados</p>
          </div>
        </div>
      </div>

      <!-- Botão Salvar -->
      <div class="flex gap-4">
        <button 
          type="button"
          onclick="loadSettings()"
          class="flex-1 bg-bg-dark hover:bg-bg-dark/80 text-text-light px-6 py-3 rounded-lg font-semibold transition-colors"
        >
          Cancelar
        </button>
        <button 
          type="submit"
          class="flex-1 bg-verde-principal hover:bg-verde-escuro text-white px-6 py-3 rounded-lg font-semibold transition-colors"
        >
          Salvar Configurações
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  async function loadSettings() {
    try {
      const response = await fetch('/admin/api/settings')
      const data = await response.json()

      const settings = data.settings

      // Preencher campos de texto
      const textFields = ['site_name', 'site_description', 'support_email', 'support_whatsapp', 'max_devices_per_user', 'default_commission_pct']
      textFields.forEach(field => {
        const input = document.getElementById(`setting-${field}`) as HTMLInputElement | HTMLTextAreaElement
        if (input && settings[field]) {
          input.value = settings[field].value
        }
      })

      // Preencher checkboxes
      const checkboxFields = ['registration_enabled', 'maintenance_mode']
      checkboxFields.forEach(field => {
        const checkbox = document.getElementById(`setting-${field}`) as HTMLInputElement
        if (checkbox && settings[field]) {
          checkbox.checked = settings[field].value === 'true' || settings[field].value === '1'
        }
      })
    } catch (error) {
      console.error('Erro ao carregar configurações:', error)
      alert('Erro ao carregar configurações')
    }
  }

  document.getElementById('settings-form').addEventListener('submit', async (e) => {
    e.preventDefault()

    const settings: Record<string, string> = {}

    // Coletar campos de texto
    const textFields = ['site_name', 'site_description', 'support_email', 'support_whatsapp', 'max_devices_per_user', 'default_commission_pct']
    textFields.forEach(field => {
      const input = document.getElementById(`setting-${field}`) as HTMLInputElement | HTMLTextAreaElement
      if (input) {
        settings[field] = input.value
      }
    })

    // Coletar checkboxes
    const checkboxFields = ['registration_enabled', 'maintenance_mode']
    checkboxFields.forEach(field => {
      const checkbox = document.getElementById(`setting-${field}`) as HTMLInputElement
      if (checkbox) {
        settings[field] = checkbox.checked ? 'true' : 'false'
      }
    })

    try {
      const response = await fetch('/admin/api/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ settings }),
      })

      if (response.ok) {
        alert('Configurações salvas com sucesso!')
      } else {
        const data = await response.json()
        alert(data.error || 'Erro ao salvar configurações')
      }
    } catch (error) {
      alert('Erro ao salvar configurações')
    }
  })

  loadSettings()
</script>
