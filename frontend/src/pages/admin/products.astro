---
import AdminLayout from '../../layouts/AdminLayout.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import Icon from '../../components/ui/Icon.astro'
import Button from '../../components/ui/Button.astro'
import { getSessionFromCookies, isAdmin } from '@lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Gestão de Produtos">
  <div class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h1 class="text-3xl font-display font-bold text-dourado">Gestão de Produtos</h1>
      <p class="text-text-muted text-sm mt-1">Crie workshops, cursos e ebooks com módulos e aulas</p>
    </div>
    <Button onclick="openCreateModal()" icon="plus" variant="primary">
      Novo Produto
    </Button>
  </div>

  <div id="products-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <div class="col-span-full text-center py-12">
      <div class="animate-spin rounded-full h-12 w-12 border-2 border-dourado/20 border-t-dourado mx-auto mb-4"></div>
      <p class="text-text-muted">Carregando produtos...</p>
    </div>
  </div>

  <div id="product-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 overflow-y-auto">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeProductModal()"></div>
    <div class="relative bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-2xl my-8">
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
        <h2 id="product-modal-title" class="text-xl font-display font-bold text-dourado">Novo Produto</h2>
        <button onclick="closeProductModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
          <Icon name="x" size={20} />
        </button>
      </div>
      <form id="product-form" class="p-6 space-y-4">
        <input type="hidden" id="product-id" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-text-muted mb-2">Título *</label>
            <input type="text" id="product-title" required class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-muted mb-2">Tipo *</label>
            <select id="product-type" required class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors">
              <option value="course">Curso</option>
              <option value="workshop">Workshop</option>
              <option value="ebook">E-book</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Descrição</label>
          <textarea id="product-description" rows="3" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"></textarea>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-text-muted mb-2">Preço (R$) *</label>
            <input type="number" id="product-price" step="0.01" min="0" required class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-text-muted mb-2">URL da Capa</label>
            <input type="url" id="product-cover" placeholder="https://..." class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors" />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-text-muted mb-2">Status</label>
            <select id="product-status" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors">
              <option value="draft">Rascunho</option>
              <option value="published">Publicado</option>
              <option value="archived">Arquivado</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-muted mb-2">Comissão Afiliado (%)</label>
            <input type="number" id="product-commission" min="0" max="100" step="0.01" value="40" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors" />
          </div>
        </div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="product-affiliable" checked class="w-4 h-4 accent-verde-principal" />
          <span class="text-text-light text-sm">Disponível para afiliados</span>
        </label>
        <div id="product-form-error" class="hidden p-3 rounded-lg text-sm bg-vermelho/10 border border-vermelho/30 text-vermelho"></div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="closeProductModal()" class="flex-1 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">Cancelar</button>
          <button type="submit" class="flex-1 bg-verde-principal hover:bg-verde-claro text-white px-4 py-3 rounded-lg font-semibold transition-colors">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <div id="content-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 overflow-y-auto">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeContentModal()"></div>
    <div class="relative bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-4xl my-8">
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/5 sticky top-0 bg-azul-profundo z-10">
        <div>
          <h2 id="content-modal-title" class="text-xl font-display font-bold text-dourado">Editor de Conteúdo</h2>
          <p class="text-text-muted text-sm mt-0.5" id="content-modal-subtitle"></p>
        </div>
        <button onclick="closeContentModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
          <Icon name="x" size={20} />
        </button>
      </div>

      <div class="p-6 space-y-3" id="modules-container">
      </div>

      <div class="px-6 pb-6">
        <button onclick="addModule()" class="w-full bg-bg-dark hover:bg-white/5 text-dourado px-6 py-3 rounded-lg font-semibold transition-colors border-2 border-dashed border-dourado/30">
          + Adicionar Módulo
        </button>
        <button onclick="closeContentModal()" class="w-full mt-3 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">
          Fechar
        </button>
      </div>
    </div>
  </div>

  <div id="lesson-modal" class="fixed inset-0 z-[60] hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeLessonModal()"></div>
    <div class="relative bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-lg">
      <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
        <h2 id="lesson-modal-title" class="text-xl font-display font-bold text-dourado">Nova Aula</h2>
        <button onclick="closeLessonModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
          <Icon name="x" size={20} />
        </button>
      </div>
      <form id="lesson-form" class="p-6 space-y-4">
        <input type="hidden" id="lesson-module-id" />
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Título da aula *</label>
          <input type="text" id="lesson-title" required class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-text-muted mb-2">Tipo</label>
            <select id="lesson-type" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors">
              <option value="video">Vídeo (URL)</option>
              <option value="vimeo">Vimeo</option>
              <option value="youtube">YouTube</option>
              <option value="pdf">PDF</option>
              <option value="text">Texto</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-text-muted mb-2">Duração (seg)</label>
            <input type="number" id="lesson-duration" min="0" value="600" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">URL do conteúdo</label>
          <input type="url" id="lesson-url" placeholder="https://..." class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors" />
          <p class="text-xs text-text-muted mt-1">Vimeo ID, YouTube URL, MP4, PDF ou link externo</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Descrição</label>
          <textarea id="lesson-description" rows="2" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"></textarea>
        </div>
        <div id="lesson-form-error" class="hidden p-3 rounded-lg text-sm bg-vermelho/10 border border-vermelho/30 text-vermelho"></div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="closeLessonModal()" class="flex-1 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">Cancelar</button>
          <button type="submit" class="flex-1 bg-verde-principal hover:bg-verde-claro text-white px-4 py-3 rounded-lg font-semibold transition-colors">Salvar</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    for (const id of ['product-modal', 'content-modal', 'lesson-modal']) {
      const el = document.getElementById(id)
      if (el) document.body.appendChild(el)
    }
  })

  let currentProductId = ''
  let currentProductSlug = ''
  let products: any[] = []

  async function loadProducts() {
    try {
      const response = await fetch('/admin/api/products')
      if (!response.ok) throw new Error('Erro ao carregar')
      const data = await response.json()
      products = data.products || []
      renderProducts()
    } catch (error) {
      document.getElementById('products-grid').innerHTML = `
        <div class="col-span-full text-center py-12">
          <p class="text-vermelho">Erro ao carregar produtos</p>
        </div>
      `
    }
  }

  function renderProducts() {
    const grid = document.getElementById('products-grid')

    if (!products || products.length === 0) {
      grid.innerHTML = `
        <div class="col-span-full text-center py-12">
          <p class="text-text-muted">Nenhum produto cadastrado. Clique em "Novo Produto" para começar.</p>
        </div>
      `
      return
    }

    const statusMap = {
      draft: { label: 'Rascunho', color: 'bg-white/10 text-text-muted' },
      published: { label: 'Publicado', color: 'bg-verde-claro/10 text-verde-claro' },
      archived: { label: 'Arquivado', color: 'bg-vermelho/10 text-vermelho' },
    }

    grid.innerHTML = products.map(p => {
      const status = statusMap[p.status] || { label: p.status, color: 'bg-white/10 text-text-muted' }
      return `
        <div class="bg-azul-profundo rounded-xl border border-white/10 overflow-hidden hover:border-dourado/30 transition-colors">
          ${p.cover_url
            ? `<img src="${p.cover_url}" alt="${p.title}" class="w-full h-48 object-cover" />`
            : `<div class="w-full h-48 bg-bg-dark flex items-center justify-center text-text-muted/30 text-5xl">📦</div>`
          }
          <div class="p-6">
            <div class="flex justify-between items-start mb-2 gap-2">
              <h3 class="text-lg font-display font-bold text-dourado line-clamp-2">${escapeHtml(p.title)}</h3>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium whitespace-nowrap ${status.color}">${status.label}</span>
            </div>
            <p class="text-text-muted text-sm mb-4 line-clamp-2">${escapeHtml(p.description || 'Sem descrição')}</p>
            <div class="grid grid-cols-3 gap-2 mb-4 text-center">
              <div>
                <div class="text-xl font-display font-bold text-text-light">${p.modules_count || 0}</div>
                <div class="text-xs text-text-muted">Módulos</div>
              </div>
              <div>
                <div class="text-xl font-display font-bold text-text-light">${p.lessons_count || 0}</div>
                <div class="text-xs text-text-muted">Aulas</div>
              </div>
              <div>
                <div class="text-xl font-display font-bold text-verde-claro">R$ ${((p.price_cents || 0) / 100).toFixed(0)}</div>
                <div class="text-xs text-text-muted">Preço</div>
              </div>
            </div>
            <div class="flex gap-2">
              <button onclick="openEditModal('${p.id}')" class="flex-1 bg-bg-dark hover:bg-white/10 text-text-light px-3 py-2 rounded-lg text-sm transition-colors">Editar</button>
              <button onclick="openContentEditor('${p.id}')" class="flex-1 bg-dourado/20 hover:bg-dourado/30 text-dourado px-3 py-2 rounded-lg text-sm transition-colors">Conteúdo</button>
              ${p.status === 'published'
                ? `<button onclick="changeStatus('${p.id}', 'draft')" class="bg-vermelho/20 hover:bg-vermelho/30 text-vermelho px-3 py-2 rounded-lg text-sm transition-colors">Despublicar</button>`
                : `<button onclick="changeStatus('${p.id}', 'published')" class="bg-verde-principal/20 hover:bg-verde-principal/30 text-verde-claro px-3 py-2 rounded-lg text-sm transition-colors">Publicar</button>`
              }
              <button onclick="deleteProduct('${p.id}')" class="bg-vermelho/20 hover:bg-vermelho/30 text-vermelho px-3 py-2 rounded-lg text-sm transition-colors">Excluir</button>
            </div>
          </div>
        </div>
      `
    }).join('')
  }

  function escapeHtml(text: any): string {
    if (text == null) return ''
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
  }

  function openCreateModal() {
    document.getElementById('product-modal-title').textContent = 'Novo Produto'
    document.getElementById('product-id').value = ''
    document.getElementById('product-title').value = ''
    document.getElementById('product-type').value = 'course'
    document.getElementById('product-description').value = ''
    document.getElementById('product-price').value = ''
    document.getElementById('product-cover').value = ''
    document.getElementById('product-status').value = 'draft'
    document.getElementById('product-commission').value = '40'
    ;(document.getElementById('product-affiliable') as HTMLInputElement).checked = true
    hideError('product-form-error')
    showModal('product-modal')
  }

  async function openEditModal(id: string) {
    try {
      const response = await fetch(`/admin/api/products/${id}`)
      if (!response.ok) throw new Error('Erro ao carregar produto')
      const data = await response.json()
      const p = data.product

      document.getElementById('product-modal-title').textContent = 'Editar Produto'
      document.getElementById('product-id').value = p.id
      document.getElementById('product-title').value = p.title
      document.getElementById('product-type').value = p.type
      document.getElementById('product-description').value = p.description || ''
      document.getElementById('product-price').value = ((p.price_cents || 0) / 100).toFixed(2)
      document.getElementById('product-cover').value = p.cover_url || ''
      document.getElementById('product-status').value = p.status
      document.getElementById('product-commission').value = p.affiliate_commission_pct || 40
      ;(document.getElementById('product-affiliable') as HTMLInputElement).checked = Boolean(p.is_affiliable)
      hideError('product-form-error')
      showModal('product-modal')
    } catch (error) {
      window.showToast('error', 'Erro ao carregar produto')
    }
  }

  function showModal(id: string) {
    const el = document.getElementById(id)
    if (!el) return
    el.classList.remove('hidden')
    el.classList.add('flex')
  }

  function closeProductModal() {
    const el = document.getElementById('product-modal')
    el.classList.add('hidden')
    el.classList.remove('flex')
  }

  function closeContentModal() {
    const el = document.getElementById('content-modal')
    el.classList.add('hidden')
    el.classList.remove('flex')
  }

  function closeLessonModal() {
    const el = document.getElementById('lesson-modal')
    el.classList.add('hidden')
    el.classList.remove('flex')
  }

  function showError(id: string, message: string) {
    const el = document.getElementById(id)
    if (!el) return
    el.textContent = message
    el.classList.remove('hidden')
  }

  function hideError(id: string) {
    const el = document.getElementById(id)
    if (!el) return
    el.classList.add('hidden')
  }

  document.getElementById('product-form').addEventListener('submit', async (e) => {
    e.preventDefault()
    hideError('product-form-error')

    const id = (document.getElementById('product-id') as HTMLInputElement).value
    const data = {
      title: (document.getElementById('product-title') as HTMLInputElement).value.trim(),
      description: (document.getElementById('product-description') as HTMLTextAreaElement).value.trim(),
      price_cents: Math.round(parseFloat((document.getElementById('product-price') as HTMLInputElement).value || '0') * 100),
      type: (document.getElementById('product-type') as HTMLSelectElement).value,
      cover_url: (document.getElementById('product-cover') as HTMLInputElement).value.trim() || null,
      status: (document.getElementById('product-status') as HTMLSelectElement).value,
      is_affiliable: (document.getElementById('product-affiliable') as HTMLInputElement).checked,
      affiliate_commission_pct: parseFloat((document.getElementById('product-commission') as HTMLInputElement).value || '40'),
    }

    if (!data.title) {
      showError('product-form-error', 'Título é obrigatório')
      return
    }

    try {
      const url = id ? `/admin/api/products/${id}` : '/admin/api/products'
      const method = id ? 'PUT' : 'POST'
      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (response.ok) {
        window.showToast('success', id ? 'Produto atualizado!' : 'Produto criado!')
        closeProductModal()
        await loadProducts()
      } else {
        const err = await response.json().catch(() => ({ error: 'Erro ao salvar' }))
        showError('product-form-error', err.error || 'Erro ao salvar')
      }
    } catch (error) {
      showError('product-form-error', 'Erro ao salvar produto')
    }
  })

  async function deleteProduct(id: string) {
    if (!confirm('Excluir este produto? Todos os módulos, aulas e acessos serão removidos.')) return
    try {
      const response = await fetch(`/admin/api/products/${id}`, { method: 'DELETE' })
      if (response.ok) {
        window.showToast('success', 'Produto excluído!')
        await loadProducts()
      } else {
        window.showToast('error', 'Erro ao excluir')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao excluir produto')
    }
  }

  async function changeStatus(id: string, status: string) {
    try {
      const response = await fetch(`/admin/api/products/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      })
      if (response.ok) {
        window.showToast('success', status === 'published' ? 'Produto publicado!' : 'Produto despublicado!')
        await loadProducts()
      } else {
        window.showToast('error', 'Erro ao alterar status')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao alterar status')
    }
  }

  async function openContentEditor(id: string) {
    if (!id) {
      window.showToast('error', 'Produto inválido')
      return
    }
    currentProductId = id
    try {
      const response = await fetch(`/admin/api/products/${id}`)
      if (!response.ok) throw new Error('Erro ao carregar produto')
      const data = await response.json()
      const product = data.product
      currentProductSlug = product.slug

      document.getElementById('content-modal-title').textContent = product.title
      document.getElementById('content-modal-subtitle').textContent = `${(product.modules || []).length} módulos · ${(product.modules || []).reduce((s: number, m: any) => s + (m.lessons || []).length, 0)} aulas`
      renderModules(product.modules || [])
      showModal('content-modal')
    } catch (error) {
      window.showToast('error', 'Erro ao carregar conteúdo')
    }
  }

  function renderModules(modules: any[]) {
    const container = document.getElementById('modules-container')

    if (!modules || modules.length === 0) {
      container.innerHTML = `
        <div class="text-center py-8 text-text-muted border-2 border-dashed border-white/10 rounded-lg">
          <p>Nenhum módulo cadastrado ainda</p>
          <p class="text-sm mt-1">Clique em "Adicionar Módulo" abaixo para começar</p>
        </div>
      `
      return
    }

    container.innerHTML = modules
      .sort((a, b) => a.sort_order - b.sort_order)
      .map((m: any) => `
        <div class="bg-bg-dark rounded-lg p-4 border border-white/5 cursor-move" data-module-id="${m.id}" draggable="true" ondragstart="moduleDragStart(event)" ondragover="event.preventDefault()" ondrop="moduleDrop(event)" ondragend="moduleDragEnd(event)">
          <div class="flex items-center gap-3 mb-3">
            <span class="drag-handle text-text-muted cursor-grab">⋮⋮</span>
            <span class="w-8 h-8 rounded-full bg-dourado/20 text-dourado flex items-center justify-center font-bold text-sm">${m.sort_order}</span>
            <input
              type="text"
              value="${escapeHtml(m.title)}"
              data-module-id="${m.id}"
              class="module-title-input flex-1 bg-transparent text-dourado font-bold text-lg focus:outline-none focus:bg-white/5 rounded px-2 py-1 transition-colors"
              onchange="updateModuleTitle('${m.id}', this.value)"
            />
            <button onclick="addLesson('${m.id}')" class="text-verde-claro hover:text-verde-claro/80 text-sm font-medium inline-flex items-center gap-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg> Aula
            </button>
            <button onclick="removeModule('${m.id}')" class="text-vermelho hover:text-vermelho/80 text-sm font-medium inline-flex items-center gap-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg> Remover
            </button>
          </div>
          <div class="ml-4 space-y-1 lessons-list" data-module-id="${m.id}">
            ${(m.lessons || []).length === 0
              ? '<p class="text-xs text-text-muted italic py-2">Nenhuma aula cadastrada</p>'
              : (m.lessons || []).sort((a: any, b: any) => a.sort_order - b.sort_order).map((l: any) => renderLesson(l)).join('')
            }
          </div>
        </div>
      `).join('')

    initLessonDragDrop()
  }

  let draggedModuleId: string | null = null

  function moduleDragStart(e: DragEvent) {
    const el = (e.target as HTMLElement).closest('[data-module-id]') as HTMLElement
    if (!el) return
    draggedModuleId = el.dataset.moduleId || null
    e.dataTransfer!.effectAllowed = 'move'
    el.classList.add('opacity-50')
  }

  function moduleDragEnd(e: DragEvent) {
    const el = (e.target as HTMLElement).closest('[data-module-id]') as HTMLElement
    if (el) el.classList.remove('opacity-50')
    draggedModuleId = null
  }

  async function moduleDrop(e: DragEvent) {
    e.preventDefault()
    const target = (e.target as HTMLElement).closest('[data-module-id]') as HTMLElement
    if (!target || !draggedModuleId || target.dataset.moduleId === draggedModuleId) return

    const container = document.getElementById('modules-container')
    if (!container) return
    target.parentNode?.insertBefore(document.querySelector(`[data-module-id="${draggedModuleId}"]`)!, target)

    const newOrder = Array.from(container.querySelectorAll('[data-module-id]'))
      .filter(el => !el.querySelector('.lessons-list'))
      .map(el => (el as HTMLElement).dataset.moduleId)
      .filter(Boolean) as string[]

    try {
      const response = await fetch(`/admin/api/products/${currentProductId}/modules/reorder`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ module_ids: newOrder }),
      })
      if (response.ok) {
        window.showToast('success', 'Ordem atualizada!')
        await openContentEditor(currentProductId)
      } else {
        window.showToast('error', 'Erro ao reordenar')
      }
    } catch (err) {
      window.showToast('error', 'Erro ao reordenar')
    }
  }

  function initLessonDragDrop() {
    document.querySelectorAll('.lessons-list').forEach(list => {
      let draggedId: string | null = null

      list.querySelectorAll('[data-lesson-id]').forEach(el => {
        ;(el as HTMLElement).draggable = true
        el.addEventListener('dragstart', (e: any) => {
          draggedId = (e.target as HTMLElement).dataset.lessonId || null
          e.dataTransfer.effectAllowed = 'move'
          ;(e.target as HTMLElement).classList.add('opacity-50')
        })
        el.addEventListener('dragend', (e: any) => {
          ;(e.target as HTMLElement).classList.remove('opacity-50')
        })
        el.addEventListener('dragover', (e: any) => e.preventDefault())
        el.addEventListener('drop', async (e: any) => {
          e.preventDefault()
          e.stopPropagation()
          const targetEl = e.target.closest('[data-lesson-id]') as HTMLElement
          if (!targetEl || !draggedId) return
          const moduleId = (list as HTMLElement).dataset.moduleId
          if (!moduleId) return

          targetEl.parentNode?.insertBefore(list.querySelector(`[data-lesson-id="${draggedId}"]`)!, targetEl)

          const newOrder = Array.from(list.querySelectorAll('[data-lesson-id]'))
            .map(el => (el as HTMLElement).dataset.lessonId)
            .filter(Boolean) as string[]

          try {
            const response = await fetch(`/admin/api/products/${currentProductId}/modules/${moduleId}/reorder`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ lesson_ids: newOrder }),
            })
            if (response.ok) {
              window.showToast('success', 'Ordenação atualizada!')
            } else {
              window.showToast('error', 'Erro ao reordenar')
            }
          } catch (err) {
            window.showToast('error', 'Erro ao reordenar')
          }
        })
      })
    })
  }

  function renderLesson(l: any): string {
    const url = l.video_url || l.vimeo_id || l.youtube_url || l.file_url || ''
    const urlLabel = l.type === 'vimeo' ? 'Vimeo' : l.type === 'youtube' ? 'YouTube' : l.type === 'pdf' ? 'PDF' : l.type === 'text' ? 'Texto' : 'Vídeo'
    return `
      <div class="flex items-center gap-2 text-sm bg-azul-profundo p-2 rounded border border-white/5" data-lesson-id="${l.id}">
        <span class="text-text-muted text-xs w-6">${l.sort_order}.</span>
        <span class="flex-1 truncate">${escapeHtml(l.title)}</span>
        <span class="text-xs text-text-muted whitespace-nowrap">${urlLabel}${url ? ' · ' + escapeHtml(url.substring(0, 30)) : ''}</span>
        <span class="text-xs text-text-muted">${Math.floor((l.duration_sec || 0) / 60)}min</span>
        <button onclick="removeLesson('${l.module_id}', '${l.id}')" class="text-vermelho hover:text-vermelho/80 text-sm">×</button>
      </div>
    `
  }

  async function addModule() {
    if (!currentProductId) {
      window.showToast('error', 'Produto não identificado')
      return
    }
    const title = prompt('Título do novo módulo:')
    if (!title || !title.trim()) return

    try {
      const response = await fetch(`/admin/api/products/${currentProductId}/modules`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: title.trim() }),
      })

      if (response.ok) {
        window.showToast('success', 'Módulo criado!')
        await openContentEditor(currentProductId)
      } else {
        const err = await response.json().catch(() => ({ error: 'Erro' }))
        window.showToast('error', err.error || 'Erro ao criar módulo')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao criar módulo')
    }
  }

  async function updateModuleTitle(moduleId: string, title: string) {
    if (!currentProductId || !title.trim()) return
    try {
      const response = await fetch(`/admin/api/products/${currentProductId}/modules/${moduleId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: title.trim() }),
      })
      if (!response.ok) {
        const err = await response.json().catch(() => ({ error: 'Erro' }))
        window.showToast('error', err.error || 'Erro ao atualizar módulo')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao atualizar módulo')
    }
  }

  async function removeModule(moduleId: string) {
    if (!currentProductId) return
    if (!confirm('Remover este módulo e todas as suas aulas?')) return
    try {
      const response = await fetch(`/admin/api/products/${currentProductId}/modules/${moduleId}`, {
        method: 'DELETE',
      })
      if (response.ok) {
        window.showToast('success', 'Módulo removido!')
        await openContentEditor(currentProductId)
      } else {
        window.showToast('error', 'Erro ao remover módulo')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao remover módulo')
    }
  }

  function addLesson(moduleId: string) {
    if (!currentProductId || !moduleId) {
      window.showToast('error', 'Módulo não identificado')
      return
    }
    ;(document.getElementById('lesson-module-id') as HTMLInputElement).value = moduleId
    ;(document.getElementById('lesson-title') as HTMLInputElement).value = ''
    ;(document.getElementById('lesson-type') as HTMLSelectElement).value = 'video'
    ;(document.getElementById('lesson-duration') as HTMLInputElement).value = '600'
    ;(document.getElementById('lesson-url') as HTMLInputElement).value = ''
    ;(document.getElementById('lesson-description') as HTMLTextAreaElement).value = ''
    hideError('lesson-form-error')
    showModal('lesson-modal')
  }

  document.getElementById('lesson-form').addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!currentProductId) {
      window.showToast('error', 'Produto não identificado')
      return
    }
    const moduleId = (document.getElementById('lesson-module-id') as HTMLInputElement).value
    if (!moduleId) {
      window.showToast('error', 'Módulo não identificado')
      return
    }

    const title = (document.getElementById('lesson-title') as HTMLInputElement).value.trim()
    if (!title) {
      showError('lesson-form-error', 'Título é obrigatório')
      return
    }

    const type = (document.getElementById('lesson-type') as HTMLSelectElement).value
    const duration = parseInt((document.getElementById('lesson-duration') as HTMLInputElement).value || '0')
    const url = (document.getElementById('lesson-url') as HTMLInputElement).value.trim()
    const description = (document.getElementById('lesson-description') as HTMLTextAreaElement).value.trim()

    const payload: any = { title, type, duration_sec: duration, description }
    if (type === 'vimeo') {
      payload.vimeo_id = url
    } else if (type === 'youtube') {
      payload.youtube_url = url
    } else {
      payload.video_url = url
    }

    try {
      const response = await fetch(`/admin/api/products/${currentProductId}/modules/${moduleId}/lessons`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
      if (response.ok) {
        window.showToast('success', 'Aula criada!')
        closeLessonModal()
        await openContentEditor(currentProductId)
      } else {
        const err = await response.json().catch(() => ({ error: 'Erro' }))
        showError('lesson-form-error', err.error || 'Erro ao criar aula')
      }
    } catch (error) {
      showError('lesson-form-error', 'Erro ao criar aula')
    }
  })

  async function removeLesson(moduleId: string, lessonId: string) {
    if (!currentProductId) return
    if (!confirm('Remover esta aula?')) return
    try {
      const response = await fetch(`/admin/api/products/${currentProductId}/modules/${moduleId}/lessons/${lessonId}`, {
        method: 'DELETE',
      })
      if (response.ok) {
        window.showToast('success', 'Aula removida!')
        await openContentEditor(currentProductId)
      } else {
        window.showToast('error', 'Erro ao remover aula')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao remover aula')
    }
  }

  window.openCreateModal = openCreateModal
  window.openEditModal = openEditModal
  window.openContentEditor = openContentEditor
  window.closeProductModal = closeProductModal
  window.closeContentModal = closeContentModal
  window.closeLessonModal = closeLessonModal
  window.addModule = addModule
  window.addLesson = addLesson
  window.removeModule = removeModule
  window.removeLesson = removeLesson
  window.updateModuleTitle = updateModuleTitle
  window.deleteProduct = deleteProduct
  window.changeStatus = changeStatus
  window.moduleDragStart = moduleDragStart
  window.moduleDragEnd = moduleDragEnd
  window.moduleDrop = moduleDrop

  loadProducts()
</script>
