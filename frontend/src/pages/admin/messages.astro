---
import AdminLayout from '../../layouts/AdminLayout.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import Icon from '../../components/ui/Icon.astro'
import Button from '../../components/ui/Button.astro'
import { getSessionFromCookies, isAdmin } from '../../lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Mensagens">
  <div class="mb-8">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-display font-bold text-dourado">Mensagens</h1>
      <Button onclick="openSendModal()" icon="send" variant="primary">
        Nova Mensagem
      </Button>
    </div>
  </div>

  <Card class="p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Buscar</label>
        <input 
          type="text" 
          id="search-input"
          placeholder="Título, corpo ou destinatário..."
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Tipo</label>
        <select 
          id="type-filter"
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
        >
          <option value="">Todos</option>
          <option value="info">Informação</option>
          <option value="success">Sucesso</option>
          <option value="warning">Aviso</option>
          <option value="error">Erro</option>
        </select>
      </div>
      <div class="flex items-end">
        <button 
          onclick="loadNotifications()"
          class="w-full bg-verde-principal hover:bg-verde-claro text-white px-6 py-2.5 rounded-lg font-semibold transition-colors inline-flex items-center justify-center gap-2"
        >
          <Icon name="filter" size={16} />
          Filtrar
        </button>
      </div>
    </div>
  </Card>

  <Card padding="none">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-bg-dark/50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Destinatário</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Título</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Tipo</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Lida</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Data</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody id="notifications-table">
          <tr>
            <td colspan="6" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center">
                <div class="animate-spin rounded-full h-10 w-10 border-2 border-dourado/20 border-t-dourado mb-4"></div>
                <p class="text-text-muted">Carregando...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="px-6 py-4 bg-bg-dark/50 flex justify-between items-center border-t border-white/5">
      <div class="text-sm text-text-muted">
        Mostrando <span id="showing-start" class="font-semibold text-text-light">0</span> a <span id="showing-end" class="font-semibold text-text-light">0</span> de <span id="total-items" class="font-semibold text-text-light">0</span> mensagens
      </div>
      <div class="flex gap-2" id="pagination-controls"></div>
    </div>
  </Card>

  <div id="send-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeSendModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4 overflow-y-auto">
      <div class="bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-2xl my-8 transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
          <h2 class="text-xl font-display font-bold text-dourado">Nova Mensagem</h2>
          <button onclick="closeSendModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
            <Icon name="x" size={20} />
          </button>
        </div>

        <form id="send-form" class="p-6">
          <div class="mb-4">
            <label class="block text-sm font-medium text-text-muted mb-2">Destinatários</label>
            <div class="flex gap-6 mb-3">
              <label class="flex items-center gap-2 cursor-pointer">
                <input 
                  type="radio" 
                  name="recipient-type" 
                  value="specific" 
                  checked
                  class="accent-verde-principal"
                  onchange="toggleRecipientType()"
                />
                <span class="text-text-light text-sm">Usuários específicos</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input 
                  type="radio" 
                  name="recipient-type" 
                  value="all"
                  class="accent-verde-principal"
                  onchange="toggleRecipientType()"
                />
                <span class="text-text-light text-sm">Todos os alunos</span>
              </label>
            </div>
            <select 
              id="notification-users"
              multiple
              class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors h-32"
            >
            </select>
            <p class="text-text-muted text-xs mt-1">Segure Ctrl/Cmd para selecionar múltiplos usuários</p>
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-text-muted mb-2">Título *</label>
            <input 
              type="text" 
              id="notification-title"
              required
              class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
            />
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-text-muted mb-2">Mensagem *</label>
            <textarea 
              id="notification-body"
              required
              rows="4"
              class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
            ></textarea>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div>
              <label class="block text-sm font-medium text-text-muted mb-2">Tipo</label>
              <select 
                id="notification-type"
                class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
              >
                <option value="info">Informação</option>
                <option value="success">Sucesso</option>
                <option value="warning">Aviso</option>
                <option value="error">Erro</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-text-muted mb-2">Link (opcional)</label>
              <input 
                type="url" 
                id="notification-link"
                placeholder="https://..."
                class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors"
              />
            </div>
          </div>

          <div class="flex gap-4">
            <button type="button" onclick="closeSendModal()" class="flex-1 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">
              Cancelar
            </button>
            <button type="submit" class="flex-1 bg-verde-principal hover:bg-verde-claro text-white px-4 py-3 rounded-lg font-semibold transition-colors">
              Enviar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  let currentPage = 1
  let currentSearch = ''
  let currentType = ''

  async function loadNotifications() {
    currentSearch = document.getElementById('search-input').value
    currentType = document.getElementById('type-filter').value

    const params = new URLSearchParams({
      page: currentPage.toString(),
      limit: '20',
      search: currentSearch,
      type: currentType,
    })

    try {
      const response = await fetch(`/admin/api/notifications?${params}`)
      const data = await response.json()

      renderNotifications(data.notifications)
      renderPagination(data)
    } catch (error) {
      document.getElementById('notifications-table').innerHTML = `
        <tr>
          <td colspan="6" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <Icon name="alert-circle" size={48} class="text-vermelho mb-4" />
              <p class="text-vermelho font-medium">Erro ao carregar mensagens</p>
            </div>
          </td>
        </tr>
      `
    }
  }

  function renderNotifications(notifications) {
    const tbody = document.getElementById('notifications-table')
    
    if (!notifications || notifications.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="6" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <Icon name="mail" size={48} class="text-text-muted/30 mb-4" />
              <p class="text-text-muted">Nenhuma mensagem encontrada</p>
            </div>
          </td>
        </tr>
      `
      return
    }

    const typeMap = {
      info: { label: 'Informação', variant: 'neutral' },
      success: { label: 'Sucesso', variant: 'success' },
      warning: { label: 'Aviso', variant: 'warning' },
      error: { label: 'Erro', variant: 'error' },
    }

    tbody.innerHTML = notifications.map(notification => {
      const type = typeMap[notification.type] || { label: notification.type, variant: 'neutral' }
      const readBadge = notification.read 
        ? '<Badge variant="success">Sim</Badge>'
        : '<Badge variant="neutral">Não</Badge>'

      return `
        <tr class="border-t border-white/5 hover:bg-white/[0.02] transition-colors">
          <td class="px-6 py-4">
            <div class="text-text-light">${notification.user_name || '—'}</div>
            <div class="text-text-muted text-sm">${notification.user_email || '—'}</div>
          </td>
          <td class="px-6 py-4">
            <div class="text-text-light font-semibold">${notification.title}</div>
            <div class="text-text-muted text-sm line-clamp-2">${notification.body}</div>
          </td>
          <td class="px-6 py-4">
            <Badge variant={type.variant}>{type.label}</Badge>
          </td>
          <td class="px-6 py-4">
            ${readBadge}
          </td>
          <td class="px-6 py-4 text-text-muted text-sm">
            ${new Date(notification.created_at).toLocaleString('pt-BR')}
          </td>
          <td class="px-6 py-4">
            <button onclick="deleteNotification('${notification.id}')" class="text-vermelho hover:text-vermelho/80 text-sm font-medium flex items-center gap-1">
              <Icon name="trash-2" size={14} /> Remover
            </button>
          </td>
        </tr>
      `
    }).join('')
  }

  function renderPagination(data) {
    const { page, totalPages, total } = data
    const start = (page - 1) * 20 + 1
    const end = Math.min(page * 20, total)

    document.getElementById('showing-start').textContent = start
    document.getElementById('showing-end').textContent = end
    document.getElementById('total-items').textContent = total

    const controls = document.getElementById('pagination-controls')
    let html = ''

    if (page > 1) {
      html += `<button onclick="goToPage(${page - 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Anterior</button>`
    }

    for (let i = 1; i <= totalPages; i++) {
      if (i === page) {
        html += `<button class="px-4 py-2 bg-verde-principal text-white rounded-lg text-sm font-medium">${i}</button>`
      } else if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
        html += `<button onclick="goToPage(${i})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">${i}</button>`
      } else if (i === page - 3 || i === page + 3) {
        html += `<span class="px-2 text-text-muted">...</span>`
      }
    }

    if (page < totalPages) {
      html += `<button onclick="goToPage(${page + 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Próximo</button>`
    }

    controls.innerHTML = html
  }

  function goToPage(page) {
    currentPage = page
    loadNotifications()
  }

  async function openSendModal() {
    try {
      const response = await fetch('/admin/api/students?limit=100')
      const data = await response.json()

      const select = document.getElementById('notification-users')
      select.innerHTML = ''
      
      data.students.forEach(student => {
        select.innerHTML += `<option value="${student.id}">${student.full_name} (${student.email})</option>`
      })

      document.getElementById('notification-title').value = ''
      document.getElementById('notification-body').value = ''
      document.getElementById('notification-type').value = 'info'
      document.getElementById('notification-link').value = ''
      document.querySelector('input[name="recipient-type"][value="specific"]').checked = true
      toggleRecipientType()

      document.getElementById('send-modal').classList.remove('hidden')
      document.getElementById('send-modal').classList.add('flex')
    } catch (error) {
      window.showToast('error', 'Erro ao carregar lista de usuários')
    }
  }

  function closeSendModal() {
    document.getElementById('send-modal').classList.add('hidden')
    document.getElementById('send-modal').classList.remove('flex')
  }

  function toggleRecipientType() {
    const recipientType = document.querySelector('input[name="recipient-type"]:checked').value
    const usersSelect = document.getElementById('notification-users')
    
    if (recipientType === 'all') {
      usersSelect.classList.add('hidden')
      usersSelect.required = false
    } else {
      usersSelect.classList.remove('hidden')
      usersSelect.required = true
    }
  }

  async function deleteNotification(id) {
    if (!confirm('Remover esta mensagem?')) return

    try {
      const response = await fetch(`/admin/api/notifications/${id}/delete`, { method: 'DELETE' })

      if (response.ok) {
        window.showToast('success', 'Mensagem removida!')
        loadNotifications()
      } else {
        const data = await response.json()
        window.showToast('error', data.error || 'Erro ao remover')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao remover mensagem')
    }
  }

  document.getElementById('send-form').addEventListener('submit', async (e) => {
    e.preventDefault()

    const recipientType = document.querySelector('input[name="recipient-type"]:checked').value
    const title = document.getElementById('notification-title').value
    const body = document.getElementById('notification-body').value
    const type = document.getElementById('notification-type').value
    const link_url = document.getElementById('notification-link').value

    try {
      let url, data

      if (recipientType === 'all') {
        url = '/admin/api/notifications/broadcast'
        data = { title, body, type, link_url }
      } else {
        const usersSelect = document.getElementById('notification-users')
        const user_ids = Array.from(usersSelect.selectedOptions).map(opt => opt.value)
        
        if (user_ids.length === 0) {
          window.showToast('error', 'Selecione pelo menos um usuário')
          return
        }

        url = '/admin/api/notifications'
        data = { user_ids, title, body, type, link_url }
      }

      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (response.ok) {
        const result = await response.json()
        window.showToast('success', result.message)
        closeSendModal()
        loadNotifications()
      } else {
        const errorData = await response.json()
        window.showToast('error', errorData.error || 'Erro ao enviar')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao enviar mensagem')
    }
  })

  loadNotifications()
</script>