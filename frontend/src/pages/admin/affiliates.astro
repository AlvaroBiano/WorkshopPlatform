---
import AdminLayout from '../../layouts/AdminLayout.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import Icon from '../../components/ui/Icon.astro'
import Button from '../../components/ui/Button.astro'
import { getSessionFromCookies, isAdmin } from '@lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Gestão de Afiliados">
  <div class="mb-8">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-display font-bold text-dourado">Gestão de Afiliados</h1>
      <Button onclick="openCreateModal()" icon="plus" variant="primary">
        Novo Afiliado
      </Button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-dourado/10 flex items-center justify-center">
            <Icon name="users" size={20} class="text-dourado" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Total</span>
        </div>
        <p class="text-3xl font-display font-bold text-dourado" id="stat-total">0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-verde-principal/10 flex items-center justify-center">
            <Icon name="trending-up" size={20} class="text-verde-claro" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Ativos</span>
        </div>
        <p class="text-3xl font-display font-bold text-verde-claro" id="stat-active">0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-dourado/10 flex items-center justify-center">
            <Icon name="banknote" size={20} class="text-dourado" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Receita</span>
        </div>
        <p class="text-3xl font-display font-bold text-dourado" id="stat-earnings">R$ 0</p>
      </Card>
    </div>
  </div>

  <Card class="p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Buscar</label>
        <input 
          type="text" 
          id="search-input"
          placeholder="Nome, email ou código..."
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Status</label>
        <select 
          id="status-filter"
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
        >
          <option value="">Todos</option>
          <option value="active">Ativos</option>
          <option value="inactive">Inativos</option>
        </select>
      </div>
      <div class="flex items-end">
        <button 
          onclick="loadAffiliates()"
          class="w-full bg-verde-principal hover:bg-verde-claro text-white px-6 py-2.5 rounded-lg font-semibold transition-colors inline-flex items-center justify-center gap-2"
        >
          <Icon name="filter" size={16} />
          Filtrar
        </button>
      </div>
    </div>
  </Card>

  <Card padding="none">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-bg-dark/50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Afiliado</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Código</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Comissão</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Cliques</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Conversões</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Ganhos</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Status</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody id="affiliates-table">
          <tr>
            <td colspan="8" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center">
                <div class="animate-spin rounded-full h-10 w-10 border-2 border-dourado/20 border-t-dourado mb-4"></div>
                <p class="text-text-muted">Carregando afiliados...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="px-6 py-4 bg-bg-dark/50 flex justify-between items-center border-t border-white/5">
      <div class="text-sm text-text-muted">
        Mostrando <span id="showing-start" class="font-semibold text-text-light">0</span> a <span id="showing-end" class="font-semibold text-text-light">0</span> de <span id="total-items" class="font-semibold text-text-light">0</span> afiliados
      </div>
      <div class="flex gap-2" id="pagination-controls"></div>
    </div>
  </Card>

  <div id="affiliate-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeAffiliateModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-md transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
          <h2 id="modal-title" class="text-xl font-display font-bold text-dourado">Novo Afiliado</h2>
          <button onclick="closeAffiliateModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
            <Icon name="x" size={20} />
          </button>
        </div>
        <form id="affiliate-form" class="p-6">
          <input type="hidden" id="affiliate-id" />
          
          <div class="mb-4">
            <label class="block text-sm font-medium text-text-muted mb-2">Usuário *</label>
            <select 
              id="affiliate-user"
              required
              class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
            >
              <option value="">Selecione um usuário...</option>
            </select>
          </div>

          <div class="mb-6">
            <label class="block text-sm font-medium text-text-muted mb-2">Comissão (%)</label>
            <input 
              type="number" 
              id="affiliate-commission"
              min="0"
              max="100"
              value="40"
              class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
            />
          </div>

          <div class="flex gap-4">
            <button type="button" onclick="closeAffiliateModal()" class="flex-1 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">
              Cancelar
            </button>
            <button type="submit" class="flex-1 bg-verde-principal hover:bg-verde-claro text-white px-4 py-3 rounded-lg font-semibold transition-colors">
              Salvar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div id="details-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeDetailsModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4 overflow-y-auto">
      <div class="bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-4xl my-8 transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
          <h2 id="details-title" class="text-xl font-display font-bold text-dourado">Detalhes do Afiliado</h2>
          <button onclick="closeDetailsModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
            <Icon name="x" size={20} />
          </button>
        </div>

        <div class="px-6 pt-4">
          <div class="flex gap-4 border-b border-white/10">
            <button onclick="switchTab('overview')" class="tab-btn px-4 py-2 text-dourado border-b-2 border-dourado font-medium" data-tab="overview">Visão Geral</button>
            <button onclick="switchTab('clicks')" class="tab-btn px-4 py-2 text-text-muted hover:text-text-light font-medium" data-tab="clicks">Cliques</button>
            <button onclick="switchTab('conversions')" class="tab-btn px-4 py-2 text-text-muted hover:text-text-light font-medium" data-tab="conversions">Conversões</button>
          </div>
        </div>

        <div class="p-6">
          <div id="tab-overview" class="tab-content">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <Card class="p-4 text-center">
                <div class="text-text-muted text-sm mb-1">Cliques</div>
                <div class="text-2xl font-display font-bold text-dourado" id="stat-clicks">0</div>
              </Card>
              <Card class="p-4 text-center">
                <div class="text-text-muted text-sm mb-1">Conversões</div>
                <div class="text-2xl font-display font-bold text-verde-claro" id="stat-conversions">0</div>
              </Card>
              <Card class="p-4 text-center">
                <div class="text-text-muted text-sm mb-1">Taxa</div>
                <div class="text-2xl font-display font-bold text-dourado" id="stat-rate">0%</div>
              </Card>
              <Card class="p-4 text-center">
                <div class="text-text-muted text-sm mb-1">Ganhos</div>
                <div class="text-2xl font-display font-bold text-verde-claro" id="stat-earned">R$ 0</div>
              </Card>
            </div>
          </div>

          <div id="tab-clicks" class="tab-content hidden">
            <table class="w-full">
              <thead class="bg-bg-dark/50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">Data</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">IP</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">User Agent</th>
                </tr>
              </thead>
              <tbody id="clicks-table" class="divide-y divide-white/5">
                <tr><td colspan="3" class="px-4 py-8 text-center text-text-muted">Carregando...</td></tr>
              </tbody>
            </table>
          </div>

          <div id="tab-conversions" class="tab-content hidden">
            <table class="w-full">
              <thead class="bg-bg-dark/50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">Data</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">Pedido</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">Cliente</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">Produto</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">Comissão</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-text-muted uppercase">Status</th>
                </tr>
              </thead>
              <tbody id="conversions-table" class="divide-y divide-white/5">
                <tr><td colspan="6" class="px-4 py-8 text-center text-text-muted">Carregando...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="px-6 pb-6">
          <button onclick="closeDetailsModal()" class="w-full bg-bg-dark hover:bg-white/5 text-text-light px-6 py-3 rounded-lg font-semibold transition-colors">
            Fechar
          </button>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const affiliateModal = document.getElementById('affiliate-modal')
    const detailsModal = document.getElementById('details-modal')
    if (affiliateModal) document.body.appendChild(affiliateModal)
    if (detailsModal) document.body.appendChild(detailsModal)
  })

  let currentPage = 1
  let currentSearch = ''
  let currentStatus = ''
  let currentAffiliateId = ''

  async function loadAffiliates() {
    currentSearch = document.getElementById('search-input').value
    currentStatus = document.getElementById('status-filter').value

    const params = new URLSearchParams({
      page: currentPage.toString(),
      limit: '20',
      search: currentSearch,
      status: currentStatus,
    })

    try {
      const response = await fetch(`/admin/api/affiliates?${params}`)
      const data = await response.json()

      if (!response.ok) throw new Error(data.error || 'Erro ao carregar')

      renderAffiliates(data.affiliates)
      renderPagination(data)
      updateStats(data)
    } catch (error: any) {
      document.getElementById('affiliates-table').innerHTML = `
        <tr>
          <td colspan="8" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <Icon name="alert-circle" size={48} class="text-vermelho mb-4" />
              <p class="text-vermelho font-medium mb-2">Erro ao carregar afiliados</p>
              <p class="text-text-muted text-sm">${error.message}</p>
            </div>
          </td>
        </tr>
      `
    }
  }

  function renderAffiliates(affiliates) {
    const tbody = document.getElementById('affiliates-table')
    
    if (!affiliates || affiliates.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="8" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <Icon name="users" size={48} class="text-text-muted/30 mb-4" />
              <p class="text-text-muted">Nenhum afiliado encontrado</p>
            </div>
          </td>
        </tr>
      `
      return
    }

    tbody.innerHTML = affiliates.map(affiliate => {
      const statusBadge = affiliate.is_active 
        ? '<Badge variant="success">Ativo</Badge>'
        : '<Badge variant="error">Inativo</Badge>'
      const conversionRate = affiliate.clicks_count > 0 
        ? ((affiliate.conversions_count / affiliate.clicks_count) * 100).toFixed(1)
        : '0.0'

      return `
        <tr class="border-t border-white/5 hover:bg-white/[0.02] transition-colors">
          <td class="px-6 py-4">
            <div class="font-medium text-text-light">${affiliate.user_name || '—'}</div>
            <div class="text-text-muted text-sm">${affiliate.user_email || '—'}</div>
          </td>
          <td class="px-6 py-4 text-dourado font-mono font-bold">${affiliate.code}</td>
          <td class="px-6 py-4 text-text-light">${affiliate.commission_pct}%</td>
          <td class="px-6 py-4 text-text-muted">${affiliate.clicks_count || 0}</td>
          <td class="px-6 py-4">
            <div class="text-text-light">${affiliate.conversions_count || 0}</div>
            <div class="text-text-muted text-xs">${conversionRate}%</div>
          </td>
          <td class="px-6 py-4">
            <div class="text-verde-claro font-semibold">R$ ${(((affiliate.total_paid_cents || 0) + (affiliate.total_pending_cents || 0)) / 100).toFixed(2)}</div>
            <div class="text-text-muted text-xs">Pago: R$ ${((affiliate.total_paid_cents || 0) / 100).toFixed(2)}</div>
          </td>
          <td class="px-6 py-4">${statusBadge}</td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <button onclick="openDetailsModal('${affiliate.id}')" class="text-dourado hover:text-dourado/80 text-sm font-medium flex items-center gap-1">
                <Icon name="eye" size={14} /> Detalhes
              </button>
              ${affiliate.is_active ? `
                <button onclick="deactivateAffiliate('${affiliate.id}')" class="text-vermelho hover:text-vermelho/80 text-sm font-medium flex items-center gap-1">
                  <Icon name="x" size={14} /> Desativar
                </button>
              ` : ''}
            </div>
          </td>
        </tr>
      `
    }).join('')
  }

  function renderPagination(data) {
    const { page, totalPages, total } = data
    const start = (page - 1) * 20 + 1
    const end = Math.min(page * 20, total)

    document.getElementById('showing-start').textContent = start
    document.getElementById('showing-end').textContent = end
    document.getElementById('total-items').textContent = total

    const controls = document.getElementById('pagination-controls')
    let html = ''

    if (page > 1) {
      html += `<button onclick="goToPage(${page - 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Anterior</button>`
    }

    for (let i = 1; i <= totalPages; i++) {
      if (i === page) {
        html += `<button class="px-4 py-2 bg-verde-principal text-white rounded-lg text-sm font-medium">${i}</button>`
      } else if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
        html += `<button onclick="goToPage(${i})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">${i}</button>`
      } else if (i === page - 3 || i === page + 3) {
        html += `<span class="px-2 text-text-muted">...</span>`
      }
    }

    if (page < totalPages) {
      html += `<button onclick="goToPage(${page + 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Próximo</button>`
    }

    controls.innerHTML = html
  }

  function updateStats(data) {
    document.getElementById('stat-total').textContent = data.total
    document.getElementById('stat-active').textContent = data.affiliates.filter(a => a.is_active).length
    const totalEarnings = data.affiliates.reduce((sum, a) => sum + ((a.total_paid_cents || 0) + (a.total_pending_cents || 0)), 0)
    document.getElementById('stat-earnings').textContent = `R$ ${(totalEarnings / 100).toFixed(0)}`
  }

  function goToPage(page) {
    currentPage = page
    loadAffiliates()
  }

  async function openCreateModal() {
    try {
      const response = await fetch('/admin/api/students?limit=100')
      const data = await response.json()

      const select = document.getElementById('affiliate-user')
      select.innerHTML = '<option value="">Selecione um usuário...</option>'
      
      data.students.forEach(student => {
        select.innerHTML += `<option value="${student.id}">${student.full_name} (${student.email})</option>`
      })

      document.getElementById('modal-title').textContent = 'Novo Afiliado'
      document.getElementById('affiliate-id').value = ''
      document.getElementById('affiliate-user').value = ''
      document.getElementById('affiliate-commission').value = '40'
      document.getElementById('affiliate-modal').classList.remove('hidden')
      document.getElementById('affiliate-modal').classList.add('flex')
    } catch (error: any) {
      window.showToast('error', 'Erro ao carregar lista de usuários')
    }
  }

  function closeAffiliateModal() {
    document.getElementById('affiliate-modal').classList.add('hidden')
    document.getElementById('affiliate-modal').classList.remove('flex')
  }

  async function openDetailsModal(id) {
    currentAffiliateId = id
    try {
      const response = await fetch(`/admin/api/affiliates/${id}/stats`)
      const stats = await response.json()

      if (!response.ok) throw new Error(stats.error || 'Erro ao carregar')

      document.getElementById('stat-clicks').textContent = stats.clicks
      document.getElementById('stat-conversions').textContent = stats.conversions
      document.getElementById('stat-rate').textContent = `${stats.conversion_rate}%`
      document.getElementById('stat-earned').textContent = `R$ ${(stats.total_earned_cents / 100).toFixed(2)}`

      switchTab('overview')
      document.getElementById('details-modal').classList.remove('hidden')
      document.getElementById('details-modal').classList.add('flex')
    } catch (error: any) {
      window.showToast('error', error.message)
    }
  }

  function closeDetailsModal() {
    document.getElementById('details-modal').classList.add('hidden')
    document.getElementById('details-modal').classList.remove('flex')
  }

  function switchTab(tab) {
    document.querySelectorAll('.tab-btn').forEach(btn => {
      if (btn.dataset.tab === tab) {
        btn.classList.add('text-dourado', 'border-b-2', 'border-dourado')
        btn.classList.remove('text-text-muted')
      } else {
        btn.classList.remove('text-dourado', 'border-b-2', 'border-dourado')
        btn.classList.add('text-text-muted')
      }
    })

    document.querySelectorAll('.tab-content').forEach(content => {
      content.classList.add('hidden')
    })

    document.getElementById(`tab-${tab}`).classList.remove('hidden')

    if (tab === 'clicks') {
      loadClicks()
    } else if (tab === 'conversions') {
      loadConversions()
    }
  }

  async function loadClicks() {
    try {
      const response = await fetch(`/admin/api/affiliates/${currentAffiliateId}/clicks`)
      const data = await response.json()

      const tbody = document.getElementById('clicks-table')
      if (!data.clicks || data.clicks.length === 0) {
        tbody.innerHTML = '<tr><td colspan="3" class="px-4 py-8 text-center text-text-muted">Nenhum clique registrado</td></tr>'
        return
      }

      tbody.innerHTML = data.clicks.map(click => `
        <tr class="border-t border-white/5">
          <td class="px-4 py-3 text-text-light text-sm">${new Date(click.clicked_at).toLocaleString('pt-BR')}</td>
          <td class="px-4 py-3 text-text-muted text-sm font-mono">${click.ip_address || '—'}</td>
          <td class="px-4 py-3 text-text-muted text-xs">${click.user_agent || '—'}</td>
        </tr>
      `).join('')
    } catch (error: any) {
      window.showToast('error', 'Erro ao carregar cliques')
    }
  }

  async function loadConversions() {
    try {
      const response = await fetch(`/admin/api/affiliates/${currentAffiliateId}/conversions`)
      const data = await response.json()

      const tbody = document.getElementById('conversions-table')
      if (!data.conversions || data.conversions.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-text-muted">Nenhuma conversão registrada</td></tr>'
        return
      }

      tbody.innerHTML = data.conversions.map(conv => {
        const statusBadge = {
          pending: '<Badge variant="warning">Pendente</Badge>',
          paid: '<Badge variant="success">Pago</Badge>',
          cancelled: '<Badge variant="error">Cancelado</Badge>',
        }[conv.status] || '<Badge variant="neutral">—</Badge>'

        return `
          <tr class="border-t border-white/5">
            <td class="px-4 py-3 text-text-light text-sm">${new Date(conv.created_at).toLocaleDateString('pt-BR')}</td>
            <td class="px-4 py-3 text-text-muted text-sm font-mono">${conv.order_number || '—'}</td>
            <td class="px-4 py-3">
              <div class="text-text-light text-sm">${conv.user_name || '—'}</div>
              <div class="text-text-muted text-xs">${conv.user_email || '—'}</div>
            </td>
            <td class="px-4 py-3 text-text-muted text-sm">${conv.product_title || '—'}</td>
            <td class="px-4 py-3 text-verde-claro font-semibold text-sm">R$ ${(conv.commission_cents / 100).toFixed(2)}</td>
            <td class="px-4 py-3">${statusBadge}</td>
          </tr>
        `
      }).join('')
    } catch (error: any) {
      window.showToast('error', 'Erro ao carregar conversões')
    }
  }

  async function deactivateAffiliate(id) {
    if (!confirm('Tem certeza que deseja desativar este afiliado? Ele perderá acesso ao painel de afiliados.')) return

    try {
      const response = await fetch(`/admin/api/affiliates/${id}`, { method: 'DELETE' })

      if (!response.ok) {
        const data = await response.json()
        throw new Error(data.error || 'Erro ao desativar')
      }

      window.showToast('success', 'Afiliado desativado com sucesso!')
      loadAffiliates()
    } catch (error: any) {
      window.showToast('error', error.message)
    }
  }

  document.getElementById('affiliate-form').addEventListener('submit', async (e) => {
    e.preventDefault()

    const data = {
      user_id: document.getElementById('affiliate-user').value,
      commission_pct: parseFloat(document.getElementById('affiliate-commission').value),
    }

    try {
      const response = await fetch('/admin/api/affiliates', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (!response.ok) {
        const errorData = await response.json()
        throw new Error(errorData.error || 'Erro ao criar')
      }

      window.showToast('success', 'Afiliado criado com sucesso!')
      closeAffiliateModal()
      loadAffiliates()
    } catch (error: any) {
      window.showToast('error', error.message)
    }
  })

  let searchTimeout
  document.getElementById('search-input').addEventListener('input', () => {
    clearTimeout(searchTimeout)
    searchTimeout = setTimeout(loadAffiliates, 300)
  })

  document.getElementById('status-filter').addEventListener('change', loadAffiliates)

  // Expor funções para escopo global (onclick inline)
  window.loadAffiliates = loadAffiliates
  window.goToPage = goToPage
  window.openCreateModal = openCreateModal
  window.closeAffiliateModal = closeAffiliateModal
  window.openDetailsModal = openDetailsModal
  window.closeDetailsModal = closeDetailsModal
  window.switchTab = switchTab
  window.deactivateAffiliate = deactivateAffiliate

  loadAffiliates()
</script>