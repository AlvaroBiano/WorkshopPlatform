---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { db } from '../../../lib/turso'

const productId = Astro.params.id

const productRow = await db.execute({
  sql: 'SELECT * FROM products WHERE id = ?',
  args: [productId],
})
const product = productRow.rows[0]
if (!product) return Astro.redirect('/admin/products')

const modulesRows = await db.execute({
  sql: 'SELECT * FROM modules WHERE product_id = ? ORDER BY sort_order ASC',
  args: [productId],
})
const modules = modulesRows.rows

for (const mod of modules) {
  const lessonsRows = await db.execute({
    sql: 'SELECT * FROM lessons WHERE module_id = ? ORDER BY sort_order ASC',
    args: [mod.id],
  })
  mod.lessons = lessonsRows.rows
}

product.modules = modules
---

<AdminLayout title={`Editar: ${product.title}`}>
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-display font-bold text-dourado">Editar Produto</h1>
    <a href="/admin/products" class="bg-bg-dark hover:bg-white/10 text-text-light px-4 py-2 rounded-lg font-medium transition-colors">Voltar</a>
  </div>

  <form id="productForm" class="space-y-6">
    <div class="bg-azul-profundo rounded-xl border border-white/10 p-6">
      <h2 class="font-bold text-dourado mb-4">Informações Básicas</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Título</label>
          <input type="text" id="title" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors" value={product.title} required />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Slug</label>
          <input type="text" id="slug" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors" value={product.slug} required />
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-text-muted mb-2">Descrição</label>
          <textarea id="description" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors" rows="3">{product.description}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Preço (centavos)</label>
          <input type="number" id="price_cents" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors" value={product.price_cents} required />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Tipo</label>
          <select id="type" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors">
            <option value="workshop" selected={product.type === 'workshop'}>Workshop</option>
            <option value="course" selected={product.type === 'course'}>Curso</option>
            <option value="ebook" selected={product.type === 'ebook'}>Ebook</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Status</label>
          <select id="status" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors">
            <option value="draft" selected={product.status === 'draft'}>Rascunho</option>
            <option value="published" selected={product.status === 'published'}>Publicado</option>
            <option value="archived" selected={product.status === 'archived'}>Arquivado</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">URL da Capa</label>
          <input type="url" id="cover_url" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors" value={product.cover_url || ''} />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Comissão Afiliado (%)</label>
          <input type="number" id="affiliate_commission_pct" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors" value={product.affiliate_commission_pct} step="0.01" />
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="is_affiliable" checked={product.is_affiliable} />
          <label for="is_affiliable" class="text-sm text-text-muted">Disponível para afiliados</label>
        </div>
      </div>
    </div>

    <div class="bg-azul-profundo rounded-xl border border-white/10 p-6">
      <div class="flex justify-between items-center mb-4">
        <h2 class="font-bold text-dourado">Módulos ({product.modules?.length || 0})</h2>
        <button type="button" onclick="addModule()" class="bg-bg-dark hover:bg-white/10 text-text-light px-4 py-2 rounded-lg font-medium transition-colors text-sm">+ Adicionar Módulo</button>
      </div>
      <div id="modulesList" class="space-y-4">
        {(product.modules || []).sort((a: any, b: any) => a.sort_order - b.sort_order).map((m: any, i: number) => (
          <div class="bg-white/5 p-4 rounded-lg" data-module-id={m.id}>
            <div class="flex justify-between items-center mb-3">
              <input type="text" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors max-w-md" value={m.title} placeholder="Título do módulo" />
              <button type="button" onclick={`deleteModule('${m.id}')`} class="text-red-400 hover:text-red-300 text-sm">Remover</button>
            </div>
            <div class="ml-4 space-y-2">
              <p class="text-sm text-text-muted font-semibold">Aulas ({m.lessons?.length || 0})</p>
              {(m.lessons || []).sort((a: any, b: any) => a.sort_order - b.sort_order).map((l: any) => (
                <div class="flex items-center gap-2 text-sm bg-white/5 p-2 rounded">
                  <span class="text-dourado font-mono">{l.sort_order}.</span>
                  <span class="flex-1">{l.title}</span>
                  <span class="text-xs text-text-muted">{l.type} · {Math.floor((l.duration_sec || 0) / 60)}min</span>
                </div>
              ))}
              <button type="button" onclick={`addLesson('${m.id}')`} class="text-xs text-dourado hover:underline">+ Adicionar Aula</button>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div id="errorMsg" class="hidden p-3 rounded-lg text-sm bg-red-500/10 border border-red-500/30 text-red-400"></div>
    <div id="successMsg" class="hidden p-3 rounded-lg text-sm bg-verde-claro/10 border border-verde-claro/30 text-verde-claro"></div>

    <div class="flex justify-end gap-4">
      <a href="/admin/products" class="bg-bg-dark hover:bg-white/10 text-text-light px-4 py-2 rounded-lg font-medium transition-colors">Cancelar</a>
      <button type="submit" class="bg-verde-principal hover:bg-verde-claro text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200 hover:scale-[1.02]">Salvar Alterações</button>
    </div>
  </form>
</AdminLayout>

<script define:vars={{ productId }}>
  const form = document.getElementById('productForm') as HTMLFormElement
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement
  const successMsg = document.getElementById('successMsg') as HTMLDivElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorMsg.classList.add('hidden')
    successMsg.classList.add('hidden')

    const data = {
      title: (document.getElementById('title') as HTMLInputElement).value,
      slug: (document.getElementById('slug') as HTMLInputElement).value,
      description: (document.getElementById('description') as HTMLTextAreaElement).value,
      price_cents: parseInt((document.getElementById('price_cents') as HTMLInputElement).value),
      type: (document.getElementById('type') as HTMLSelectElement).value,
      status: (document.getElementById('status') as HTMLSelectElement).value,
      cover_url: (document.getElementById('cover_url') as HTMLInputElement).value || null,
      affiliate_commission_pct: parseFloat((document.getElementById('affiliate_commission_pct') as HTMLInputElement).value),
      is_affiliable: (document.getElementById('is_affiliable') as HTMLInputElement).checked,
    }

    const res = await fetch(`/admin/api/products/${productId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    })

    if (res.ok) {
      successMsg.textContent = 'Produto atualizado com sucesso!'
      successMsg.classList.remove('hidden')
      setTimeout(() => successMsg.classList.add('hidden'), 3000)
    } else {
      errorMsg.textContent = 'Erro: ' + await res.text()
      errorMsg.classList.remove('hidden')
    }
  })

  window.addModule = async () => {
    const title = prompt('Título do novo módulo:')
    if (!title) return

    const res = await fetch(`/admin/api/products/${productId}/modules`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title }),
    })

    if (res.ok) location.reload()
    else alert('Erro: ' + await res.text())
  }

  window.deleteModule = async (moduleId: string) => {
    if (!confirm('Remover este módulo e todas as suas aulas?')) return

    const res = await fetch(`/admin/api/products/${productId}/modules/${moduleId}`, {
      method: 'DELETE',
    })

    if (res.ok) location.reload()
    else alert('Erro: ' + await res.text())
  }

  window.addLesson = async (moduleId: string) => {
    const title = prompt('Título da nova aula:')
    if (!title) return

    const type = prompt('Tipo (vimeo, youtube, pdf, text):') || 'vimeo'
    const durationSec = parseInt(prompt('Duração em segundos:') || '600')

    const res = await fetch(`/admin/api/modules/${moduleId}/lessons`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, type, duration_sec: durationSec }),
    })

    if (res.ok) location.reload()
    else alert('Erro: ' + await res.text())
  }
</script>
