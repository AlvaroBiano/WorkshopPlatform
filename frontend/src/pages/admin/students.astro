---
import AdminLayout from '../../layouts/AdminLayout.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import Icon from '../../components/ui/Icon.astro'
import Toast from '../../components/ui/Toast.astro'
import { getSessionFromCookies, isAdmin } from '../../lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Gestão de Alunos">
  <Toast />

  <div class="mb-8">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-display font-bold text-dourado">Gestão de Alunos</h1>
      <button 
        onclick="openCreateModal()"
        class="inline-flex items-center gap-2 bg-verde-principal hover:bg-verde-claro text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200 hover:scale-[1.02]"
      >
        <Icon name="plus" size={18} />
        Novo Aluno
      </button>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-dourado/10 flex items-center justify-center">
            <Icon name="users" size={20} class="text-dourado" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Total</span>
        </div>
        <p class="text-3xl font-display font-bold text-dourado" id="stat-total">0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-verde-principal/10 flex items-center justify-center">
            <Icon name="user-check" size={20} class="text-verde-claro" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Ativos</span>
        </div>
        <p class="text-3xl font-display font-bold text-verde-claro" id="stat-active">0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
            <Icon name="user" size={20} class="text-text-muted" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Inativos</span>
        </div>
        <p class="text-3xl font-display font-bold text-text-muted" id="stat-inactive">0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-vermelho/10 flex items-center justify-center">
            <Icon name="user-x" size={20} class="text-vermelho" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Banidos</span>
        </div>
        <p class="text-3xl font-display font-bold text-vermelho" id="stat-banned">0</p>
      </Card>
    </div>
  </div>

  <Card class="p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Buscar</label>
        <input 
          type="text" 
          id="search-input"
          placeholder="Nome ou email..."
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Status</label>
        <select 
          id="status-filter"
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
        >
          <option value="">Todos</option>
          <option value="active">Ativos</option>
          <option value="inactive">Inativos</option>
          <option value="banned">Banidos</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Ordenar por</label>
        <select 
          id="sort-select"
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
        >
          <option value="created_at-desc">Mais recentes</option>
          <option value="created_at-asc">Mais antigos</option>
          <option value="full_name-asc">Nome (A-Z)</option>
          <option value="full_name-desc">Nome (Z-A)</option>
          <option value="email-asc">Email (A-Z)</option>
          <option value="last_login_at-desc">Último login</option>
        </select>
      </div>
    </div>
  </Card>

  <Card padding="none">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-bg-dark/50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Nome</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Email</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Status</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Produtos</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Último Login</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Cadastro</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody id="students-table">
          <tr id="loading-row">
            <td colspan="7" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center">
                <div class="animate-spin rounded-full h-10 w-10 border-2 border-dourado/20 border-t-dourado mb-4"></div>
                <p class="text-text-muted">Carregando alunos...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="px-6 py-4 bg-bg-dark/50 flex justify-between items-center border-t border-white/5">
      <div class="text-sm text-text-muted">
        Mostrando <span id="showing-start" class="font-semibold text-text-light">0</span> a <span id="showing-end" class="font-semibold text-text-light">0</span> de <span id="total-items" class="font-semibold text-text-light">0</span> alunos
      </div>
      <div class="flex gap-2" id="pagination-controls"></div>
    </div>
  </Card>

  <div id="student-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-md transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
          <h2 id="modal-title" class="text-xl font-display font-bold text-dourado">Novo Aluno</h2>
          <button onclick="closeModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
            <Icon name="x" size={20} />
          </button>
        </div>
        <form id="student-form" class="p-6">
          <input type="hidden" id="student-id" />
          
          <div class="mb-4">
            <label class="block text-sm font-medium text-text-muted mb-2">Nome Completo *</label>
            <input type="text" id="student-name" required class="input" placeholder="Seu nome completo" />
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-text-muted mb-2">Email *</label>
            <input type="email" id="student-email" required class="input" placeholder="seu@email.com" />
          </div>

          <div class="mb-4">
            <label class="block text-sm font-medium text-text-muted mb-2">Senha <span id="password-required">*</span></label>
            <input type="password" id="student-password" class="input" placeholder="Mínimo 8 caracteres" />
            <p class="text-xs text-text-muted mt-1" id="password-hint">Mínimo 8 caracteres</p>
          </div>

          <div class="mb-6">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" id="student-must-change-password" checked class="w-4 h-4 rounded border-white/20 bg-bg-dark accent-verde-principal" />
              <span class="text-sm text-text-light">Forçar troca de senha no primeiro login</span>
            </label>
          </div>

          <div class="flex gap-4">
            <button type="button" onclick="closeModal()" class="flex-1 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">
              Cancelar
            </button>
            <button type="submit" id="submit-btn" class="flex-1 bg-verde-principal hover:bg-verde-claro text-white px-4 py-3 rounded-lg font-semibold transition-colors inline-flex items-center justify-center gap-2">
              <span id="btn-text">Salvar</span>
              <span id="btn-loading" class="hidden">
                <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" />
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                </svg>
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div id="ban-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeBanModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-azul-profundo rounded-xl border border-vermelho/20 shadow-2xl w-full max-w-md transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
          <h2 class="text-xl font-display font-bold text-vermelho flex items-center gap-2">
            <Icon name="alert-triangle" size={20} />
            Banir Aluno
          </h2>
          <button onclick="closeBanModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
            <Icon name="x" size={20} />
          </button>
        </div>
        <form id="ban-form" class="p-6">
          <input type="hidden" id="ban-student-id" />
          
          <div class="mb-6">
            <label class="block text-sm font-medium text-text-muted mb-2">Motivo do Banimento *</label>
            <textarea 
              id="ban-reason"
              required
              rows="4"
              class="input"
              placeholder="Descreva o motivo do banimento..."
            ></textarea>
          </div>

          <div class="flex gap-4">
            <button type="button" onclick="closeBanModal()" class="flex-1 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">
              Cancelar
            </button>
            <button type="submit" class="flex-1 bg-vermelho hover:bg-vermelho/80 text-white px-4 py-3 rounded-lg font-semibold transition-colors">
              Banir Aluno
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  // Move modais para o body para evitar problemas com stacking context
  document.addEventListener('DOMContentLoaded', () => {
    const studentModal = document.getElementById('student-modal')
    const banModal = document.getElementById('ban-modal')
    if (studentModal) document.body.appendChild(studentModal)
    if (banModal) document.body.appendChild(banModal)
  })

  let currentPage = 1
  let currentSearch = ''
  let currentStatus = ''
  let currentSort = 'created_at'
  let currentOrder = 'desc'

  async function loadStudents() {
    const params = new URLSearchParams({
      page: currentPage.toString(),
      limit: '20',
      search: currentSearch,
      status: currentStatus,
      sort: currentSort,
      order: currentOrder,
    })

    try {
      const response = await fetch(`/admin/api/students?${params}`)
      const data = await response.json()

      if (!response.ok) throw new Error(data.error || 'Erro ao carregar')

      renderStudents(data.students)
      renderPagination(data)
      updateStats(data)
    } catch (error: any) {
      console.error('Erro ao carregar alunos:', error)
      document.getElementById('students-table').innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-vermelho mb-4"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
              <p class="text-vermelho font-medium mb-2">Erro ao carregar alunos</p>
              <p class="text-text-muted text-sm">${error.message}</p>
              <button onclick="loadStudents()" class="mt-4 px-4 py-2 bg-dourado/10 text-dourado rounded-lg hover:bg-dourado/20 transition-colors">
                Tentar novamente
              </button>
            </div>
          </td>
        </tr>
      `
    }
  }

  function renderStudents(students) {
    const tbody = document.getElementById('students-table')
    
    if (!students || students.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted/30 mb-4"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <p class="text-text-muted">Nenhum aluno encontrado</p>
            </div>
          </td>
        </tr>
      `
      return
    }

    tbody.innerHTML = students.map(student => {
      const status = student.banned_at ? 'banned' : (student.is_active ? 'active' : 'inactive')
      const statusBadge = {
        active: '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-verde-claro/10 text-verde-claro">Ativo</span>',
        inactive: '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-white/10 text-text-muted">Inativo</span>',
        banned: '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-vermelho/10 text-vermelho">Banido</span>',
      }[status]

      const banReasonNote = student.ban_reason ? `<p class="text-xs text-vermelho mt-1">${student.ban_reason}</p>` : ''

      const actions = status === 'banned' 
        ? `<button onclick="unbanStudent('${student.id}')" class="text-verde-claro hover:text-verde-claro/80 text-sm font-medium">Desbanir</button>`
        : `<button onclick="openBanModal('${student.id}')" class="text-vermelho hover:text-vermelho/80 text-sm font-medium">Banir</button>`

      return `
        <tr class="border-t border-white/5 hover:bg-white/[0.02] transition-colors">
          <td class="px-6 py-4">
            <div class="font-medium text-text-light">${student.full_name}</div>
          </td>
          <td class="px-6 py-4 text-text-muted">${student.email}</td>
          <td class="px-6 py-4">
            <div class="flex flex-col">
              ${statusBadge}
              ${banReasonNote}
            </div>
          </td>
          <td class="px-6 py-4 text-text-muted">${student.products_count || 0}</td>
          <td class="px-6 py-4 text-text-muted">${student.last_login_at ? new Date(student.last_login_at).toLocaleDateString('pt-BR') : 'Nunca'}</td>
          <td class="px-6 py-4 text-text-muted">${new Date(student.created_at).toLocaleDateString('pt-BR')}</td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-3">
              <button onclick="openEditModal('${student.id}')" class="text-dourado hover:text-dourado/80 text-sm font-medium">Editar</button>
              ${actions}
              <button onclick="deleteStudent('${student.id}')" class="text-text-muted hover:text-vermelho text-sm font-medium">Remover</button>
            </div>
          </td>
        </tr>
      `
    }).join('')
  }

  function renderPagination(data) {
    const { page, totalPages, total } = data
    const start = (page - 1) * 20 + 1
    const end = Math.min(page * 20, total)

    document.getElementById('showing-start').textContent = start
    document.getElementById('showing-end').textContent = end
    document.getElementById('total-items').textContent = total

    const controls = document.getElementById('pagination-controls')
    let html = ''

    if (page > 1) {
      html += `<button onclick="goToPage(${page - 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Anterior</button>`
    }

    for (let i = 1; i <= totalPages; i++) {
      if (i === page) {
        html += `<button class="px-4 py-2 bg-verde-principal text-white rounded-lg text-sm font-medium">${i}</button>`
      } else if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
        html += `<button onclick="goToPage(${i})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">${i}</button>`
      } else if (i === page - 3 || i === page + 3) {
        html += `<span class="px-2 text-text-muted">...</span>`
      }
    }

    if (page < totalPages) {
      html += `<button onclick="goToPage(${page + 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Próximo</button>`
    }

    controls.innerHTML = html
  }

  function updateStats(data) {
    document.getElementById('stat-total').textContent = data.total
    if (data.stats) {
      document.getElementById('stat-active').textContent = data.stats.active || 0
      document.getElementById('stat-inactive').textContent = data.stats.inactive || 0
      document.getElementById('stat-banned').textContent = data.stats.banned || 0
    }
  }

  function goToPage(page) {
    currentPage = page
    loadStudents()
  }

  function openCreateModal() {
    document.getElementById('modal-title').textContent = 'Novo Aluno'
    document.getElementById('student-id').value = ''
    document.getElementById('student-name').value = ''
    document.getElementById('student-email').value = ''
    document.getElementById('student-password').value = ''
    document.getElementById('student-password').required = true
    document.getElementById('password-required').style.display = 'inline'
    document.getElementById('password-hint').textContent = 'Mínimo 8 caracteres'
    document.getElementById('student-must-change-password').checked = true
    document.getElementById('student-modal').classList.remove('hidden')
    document.getElementById('student-modal').classList.add('flex')
  }

  async function openEditModal(id) {
    try {
      const response = await fetch(`/admin/api/students/${id}`)
      const data = await response.json()

      if (!response.ok) throw new Error(data.error)

      const student = data.student

      document.getElementById('modal-title').textContent = 'Editar Aluno'
      document.getElementById('student-id').value = student.id
      document.getElementById('student-name').value = student.full_name
      document.getElementById('student-email').value = student.email
      document.getElementById('student-password').value = ''
      document.getElementById('student-password').required = false
      document.getElementById('password-required').style.display = 'none'
      document.getElementById('password-hint').textContent = 'Deixe em branco para manter a senha atual'
      document.getElementById('student-must-change-password').checked = student.must_change_password
      document.getElementById('student-modal').classList.remove('hidden')
      document.getElementById('student-modal').classList.add('flex')
    } catch (error: any) {
      window.showToast('error', error.message || 'Erro ao carregar dados do aluno')
    }
  }

  function closeModal() {
    document.getElementById('student-modal').classList.add('hidden')
    document.getElementById('student-modal').classList.remove('flex')
  }

  function openBanModal(id) {
    document.getElementById('ban-student-id').value = id
    document.getElementById('ban-reason').value = ''
    document.getElementById('ban-modal').classList.remove('hidden')
    document.getElementById('ban-modal').classList.add('flex')
  }

  function closeBanModal() {
    document.getElementById('ban-modal').classList.add('hidden')
    document.getElementById('ban-modal').classList.remove('flex')
  }

  async function unbanStudent(id) {
    if (!confirm('Tem certeza que deseja desbanir este aluno?')) return

    try {
      const response = await fetch(`/admin/api/students/${id}/unban`, { method: 'POST' })

      if (!response.ok) {
        const data = await response.json()
        throw new Error(data.error || 'Erro ao desbanir')
      }

      window.showToast('success', 'Aluno desbanido com sucesso!')
      loadStudents()
    } catch (error: any) {
      window.showToast('error', error.message)
    }
  }

  async function deleteStudent(id) {
    if (!confirm('Tem certeza que deseja remover este aluno? Esta ação não pode ser desfeita.')) return

    try {
      const response = await fetch(`/admin/api/students/${id}/delete`, { method: 'DELETE' })

      if (!response.ok) {
        const data = await response.json()
        throw new Error(data.error || 'Erro ao remover')
      }

      window.showToast('success', 'Aluno removido com sucesso!')
      loadStudents()
    } catch (error: any) {
      window.showToast('error', error.message)
    }
  }

  document.getElementById('student-form').addEventListener('submit', async (e) => {
    e.preventDefault()

    const btnText = document.getElementById('btn-text')
    const btnLoading = document.getElementById('btn-loading')
    const submitBtn = document.getElementById('submit-btn')

    btnText.classList.add('hidden')
    btnLoading.classList.remove('hidden')
    submitBtn.disabled = true

    const id = document.getElementById('student-id').value
    const data = {
      full_name: document.getElementById('student-name').value,
      email: document.getElementById('student-email').value,
      password: document.getElementById('student-password').value,
      must_change_password: document.getElementById('student-must-change-password').checked,
    }

    try {
      const url = id ? `/admin/api/students/${id}` : '/admin/api/students/create'
      const method = id ? 'PUT' : 'POST'

      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (!response.ok) {
        const errorData = await response.json()
        throw new Error(errorData.error || 'Erro ao salvar')
      }

      window.showToast('success', id ? 'Aluno atualizado com sucesso!' : 'Aluno criado com sucesso!')
      closeModal()
      loadStudents()
    } catch (error: any) {
      window.showToast('error', error.message)
    } finally {
      btnText.classList.remove('hidden')
      btnLoading.classList.add('hidden')
      submitBtn.disabled = false
    }
  })

  document.getElementById('ban-form').addEventListener('submit', async (e) => {
    e.preventDefault()

    const id = document.getElementById('ban-student-id').value
    const reason = document.getElementById('ban-reason').value

    try {
      const response = await fetch(`/admin/api/students/${id}/ban`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason }),
      })

      if (!response.ok) {
        const data = await response.json()
        throw new Error(data.error || 'Erro ao banir')
      }

      window.showToast('success', 'Aluno banido com sucesso!')
      closeBanModal()
      loadStudents()
    } catch (error: any) {
      window.showToast('error', error.message)
    }
  })

  let searchTimeout
  document.getElementById('search-input').addEventListener('input', (e) => {
    clearTimeout(searchTimeout)
    searchTimeout = setTimeout(() => {
      currentSearch = e.target.value
      currentPage = 1
      loadStudents()
    }, 300)
  })

  document.getElementById('status-filter').addEventListener('change', (e) => {
    currentStatus = e.target.value
    currentPage = 1
    loadStudents()
  })

  document.getElementById('sort-select').addEventListener('change', (e) => {
    const [sort, order] = e.target.value.split('-')
    currentSort = sort
    currentOrder = order
    loadStudents()
  })

  // Expor funções para escopo global (onclick inline)
  window.openCreateModal = openCreateModal
  window.openEditModal = openEditModal
  window.closeModal = closeModal
  window.openBanModal = openBanModal
  window.closeBanModal = closeBanModal
  window.unbanStudent = unbanStudent
  window.deleteStudent = deleteStudent
  window.goToPage = goToPage

  loadStudents()
</script>