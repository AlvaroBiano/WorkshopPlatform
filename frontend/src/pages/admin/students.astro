---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getSessionFromCookies, isAdmin } from '../../lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Gestão de Alunos">
  <div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold text-dourado">Gestão de Alunos</h1>
      <button 
        onclick="openCreateModal()"
        class="bg-verde-principal hover:bg-verde-escuro text-white px-6 py-3 rounded-lg font-semibold transition-colors"
      >
        + Novo Aluno
      </button>
    </div>

    <!-- Cards de Estatísticas -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-azul-profundo rounded-lg p-6">
        <div class="text-text-muted text-sm mb-2">Total de Alunos</div>
        <div class="text-3xl font-bold text-dourado" id="stat-total">0</div>
      </div>
      <div class="bg-azul-profundo rounded-lg p-6">
        <div class="text-text-muted text-sm mb-2">Alunos Ativos</div>
        <div class="text-3xl font-bold text-verde-claro" id="stat-active">0</div>
      </div>
      <div class="bg-azul-profundo rounded-lg p-6">
        <div class="text-text-muted text-sm mb-2">Alunos Inativos</div>
        <div class="text-3xl font-bold text-text-muted" id="stat-inactive">0</div>
      </div>
      <div class="bg-azul-profundo rounded-lg p-6">
        <div class="text-text-muted text-sm mb-2">Alunos Banidos</div>
        <div class="text-3xl font-bold text-vermelho" id="stat-banned">0</div>
      </div>
    </div>

    <!-- Filtros -->
    <div class="bg-azul-profundo rounded-lg p-6 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label class="block text-text-muted text-sm mb-2">Buscar</label>
          <input 
            type="text" 
            id="search-input"
            placeholder="Nome ou email..."
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
          />
        </div>
        <div>
          <label class="block text-text-muted text-sm mb-2">Status</label>
          <select 
            id="status-filter"
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
          >
            <option value="">Todos</option>
            <option value="active">Ativos</option>
            <option value="inactive">Inativos</option>
            <option value="banned">Banidos</option>
          </select>
        </div>
        <div>
          <label class="block text-text-muted text-sm mb-2">Ordenar por</label>
          <select 
            id="sort-select"
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
          >
            <option value="created_at-desc">Mais recentes</option>
            <option value="created_at-asc">Mais antigos</option>
            <option value="full_name-asc">Nome (A-Z)</option>
            <option value="full_name-desc">Nome (Z-A)</option>
            <option value="email-asc">Email (A-Z)</option>
            <option value="last_login_at-desc">Último login</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Tabela de Alunos -->
    <div class="bg-azul-profundo rounded-lg overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-bg-dark/50">
            <tr>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Nome</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Email</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Status</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Produtos</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Último Login</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Cadastro</th>
              <th class="px-6 py-4 text-left text-text-muted font-semibold">Ações</th>
            </tr>
          </thead>
          <tbody id="students-table">
            <tr>
              <td colspan="7" class="px-6 py-8 text-center text-text-muted">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-dourado mx-auto"></div>
                <p class="mt-2">Carregando...</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Paginação -->
      <div class="px-6 py-4 bg-bg-dark/50 flex justify-between items-center">
        <div class="text-text-muted text-sm">
          Mostrando <span id="showing-start">0</span> a <span id="showing-end">0</span> de <span id="total-items">0</span> alunos
        </div>
        <div class="flex gap-2" id="pagination-controls">
          <!-- Botões de paginação serão inseridos via JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- Modal de Criar/Editar Aluno -->
  <div id="student-modal" class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50">
    <div class="bg-azul-profundo rounded-lg p-8 max-w-md w-full mx-4">
      <h2 id="modal-title" class="text-2xl font-bold text-dourado mb-6">Novo Aluno</h2>
      <form id="student-form">
        <input type="hidden" id="student-id" />
        
        <div class="mb-4">
          <label class="block text-text-muted text-sm mb-2">Nome Completo *</label>
          <input 
            type="text" 
            id="student-name"
            required
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
          />
        </div>

        <div class="mb-4">
          <label class="block text-text-muted text-sm mb-2">Email *</label>
          <input 
            type="email" 
            id="student-email"
            required
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
          />
        </div>

        <div class="mb-4">
          <label class="block text-text-muted text-sm mb-2">Senha <span id="password-required">*</span></label>
          <input 
            type="password" 
            id="student-password"
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
          />
          <p class="text-text-muted text-xs mt-1" id="password-hint">Mínimo 8 caracteres</p>
        </div>

        <div class="mb-6">
          <label class="flex items-center gap-2 cursor-pointer">
            <input 
              type="checkbox" 
              id="student-must-change-password"
              checked
              class="w-4 h-4 accent-verde-principal"
            />
            <span class="text-text-light text-sm">Forçar troca de senha no primeiro login</span>
          </label>
        </div>

        <div class="flex gap-4">
          <button 
            type="button"
            onclick="closeModal()"
            class="flex-1 bg-bg-dark hover:bg-bg-dark/80 text-text-light px-6 py-3 rounded-lg font-semibold transition-colors"
          >
            Cancelar
          </button>
          <button 
            type="submit"
            class="flex-1 bg-verde-principal hover:bg-verde-escuro text-white px-6 py-3 rounded-lg font-semibold transition-colors"
          >
            Salvar
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal de Banimento -->
  <div id="ban-modal" class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50">
    <div class="bg-azul-profundo rounded-lg p-8 max-w-md w-full mx-4">
      <h2 class="text-2xl font-bold text-vermelho mb-6">Banir Aluno</h2>
      <form id="ban-form">
        <input type="hidden" id="ban-student-id" />
        
        <div class="mb-6">
          <label class="block text-text-muted text-sm mb-2">Motivo do Banimento *</label>
          <textarea 
            id="ban-reason"
            required
            rows="4"
            class="w-full bg-bg-dark border border-verde-principal/30 rounded-lg px-4 py-2 text-text-light focus:outline-none focus:border-verde-principal"
            placeholder="Descreva o motivo do banimento..."
          ></textarea>
        </div>

        <div class="flex gap-4">
          <button 
            type="button"
            onclick="closeBanModal()"
            class="flex-1 bg-bg-dark hover:bg-bg-dark/80 text-text-light px-6 py-3 rounded-lg font-semibold transition-colors"
          >
            Cancelar
          </button>
          <button 
            type="submit"
            class="flex-1 bg-vermelho hover:bg-vermelho/80 text-white px-6 py-3 rounded-lg font-semibold transition-colors"
          >
            Banir
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  let currentPage = 1
  let currentSearch = ''
  let currentStatus = ''
  let currentSort = 'created_at'
  let currentOrder = 'desc'

  async function loadStudents() {
    const params = new URLSearchParams({
      page: currentPage.toString(),
      limit: '20',
      search: currentSearch,
      status: currentStatus,
      sort: currentSort,
      order: currentOrder,
    })

    try {
      const response = await fetch(`/admin/api/students?${params}`)
      const data = await response.json()

      renderStudents(data.students)
      renderPagination(data)
      updateStats(data)
    } catch (error) {
      console.error('Erro ao carregar alunos:', error)
      document.getElementById('students-table').innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-8 text-center text-vermelho">
            Erro ao carregar alunos
          </td>
        </tr>
      `
    }
  }

  function renderStudents(students) {
    const tbody = document.getElementById('students-table')
    
    if (students.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-8 text-center text-text-muted">
            Nenhum aluno encontrado
          </td>
        </tr>
      `
      return
    }

    tbody.innerHTML = students.map(student => {
      const status = student.banned_at ? 'banned' : (student.is_active ? 'active' : 'inactive')
      const statusLabel = {
        active: 'Ativo',
        inactive: 'Inativo',
        banned: 'Banido'
      }[status]
      const statusColor = {
        active: 'text-verde-claro',
        inactive: 'text-text-muted',
        banned: 'text-vermelho'
      }[status]

      return `
        <tr class="border-t border-verde-principal/10 hover:bg-bg-dark/30">
          <td class="px-6 py-4 text-text-light">${student.full_name}</td>
          <td class="px-6 py-4 text-text-muted">${student.email}</td>
          <td class="px-6 py-4">
            <span class="${statusColor} font-semibold">${statusLabel}</span>
            ${student.ban_reason ? `<br><small class="text-vermelho text-xs">${student.ban_reason}</small>` : ''}
          </td>
          <td class="px-6 py-4 text-text-muted">${student.products_count || 0}</td>
          <td class="px-6 py-4 text-text-muted">
            ${student.last_login_at ? new Date(student.last_login_at).toLocaleDateString('pt-BR') : 'Nunca'}
          </td>
          <td class="px-6 py-4 text-text-muted">
            ${new Date(student.created_at).toLocaleDateString('pt-BR')}
          </td>
          <td class="px-6 py-4">
            <div class="flex gap-2">
              <button 
                onclick="openEditModal('${student.id}')"
                class="text-dourado hover:text-dourado/80 text-sm"
              >
                Editar
              </button>
              ${status === 'banned' ? `
                <button 
                  onclick="unbanStudent('${student.id}')"
                  class="text-verde-claro hover:text-verde-claro/80 text-sm"
                >
                  Desbanir
                </button>
              ` : `
                <button 
                  onclick="openBanModal('${student.id}')"
                  class="text-vermelho hover:text-vermelho/80 text-sm"
                >
                  Banir
                </button>
              `}
              <button 
                onclick="deleteStudent('${student.id}')"
                class="text-text-muted hover:text-vermelho text-sm"
              >
                Remover
              </button>
            </div>
          </td>
        </tr>
      `
    }).join('')
  }

  function renderPagination(data) {
    const { page, totalPages, total, students } = data
    const start = (page - 1) * 20 + 1
    const end = Math.min(page * 20, total)

    document.getElementById('showing-start').textContent = start
    document.getElementById('showing-end').textContent = end
    document.getElementById('total-items').textContent = total

    const controls = document.getElementById('pagination-controls')
    let html = ''

    if (page > 1) {
      html += `<button onclick="goToPage(${page - 1})" class="px-4 py-2 bg-bg-dark hover:bg-bg-dark/80 text-text-light rounded-lg">Anterior</button>`
    }

    for (let i = 1; i <= totalPages; i++) {
      if (i === page) {
        html += `<button class="px-4 py-2 bg-verde-principal text-white rounded-lg">${i}</button>`
      } else if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
        html += `<button onclick="goToPage(${i})" class="px-4 py-2 bg-bg-dark hover:bg-bg-dark/80 text-text-light rounded-lg">${i}</button>`
      } else if (i === page - 3 || i === page + 3) {
        html += `<span class="px-2 text-text-muted">...</span>`
      }
    }

    if (page < totalPages) {
      html += `<button onclick="goToPage(${page + 1})" class="px-4 py-2 bg-bg-dark hover:bg-bg-dark/80 text-text-light rounded-lg">Próximo</button>`
    }

    controls.innerHTML = html
  }

  function updateStats(data) {
    // Por enquanto, vamos usar os dados da página atual
    // Em produção, você pode adicionar um endpoint separado para estatísticas
    document.getElementById('stat-total').textContent = data.total
    document.getElementById('stat-active').textContent = data.students.filter(s => s.is_active && !s.banned_at).length
    document.getElementById('stat-inactive').textContent = data.students.filter(s => !s.is_active && !s.banned_at).length
    document.getElementById('stat-banned').textContent = data.students.filter(s => s.banned_at).length
  }

  function goToPage(page) {
    currentPage = page
    loadStudents()
  }

  function openCreateModal() {
    document.getElementById('modal-title').textContent = 'Novo Aluno'
    document.getElementById('student-id').value = ''
    document.getElementById('student-name').value = ''
    document.getElementById('student-email').value = ''
    document.getElementById('student-password').value = ''
    document.getElementById('student-password').required = true
    document.getElementById('password-required').style.display = 'inline'
    document.getElementById('student-must-change-password').checked = true
    document.getElementById('student-modal').classList.remove('hidden')
    document.getElementById('student-modal').classList.add('flex')
  }

  async function openEditModal(id) {
    try {
      const response = await fetch(`/admin/api/students/${id}`)
      const data = await response.json()
      const student = data.student

      document.getElementById('modal-title').textContent = 'Editar Aluno'
      document.getElementById('student-id').value = student.id
      document.getElementById('student-name').value = student.full_name
      document.getElementById('student-email').value = student.email
      document.getElementById('student-password').value = ''
      document.getElementById('student-password').required = false
      document.getElementById('password-required').style.display = 'none'
      document.getElementById('password-hint').textContent = 'Deixe em branco para manter a senha atual'
      document.getElementById('student-must-change-password').checked = student.must_change_password
      document.getElementById('student-modal').classList.remove('hidden')
      document.getElementById('student-modal').classList.add('flex')
    } catch (error) {
      alert('Erro ao carregar dados do aluno')
    }
  }

  function closeModal() {
    document.getElementById('student-modal').classList.add('hidden')
    document.getElementById('student-modal').classList.remove('flex')
  }

  function openBanModal(id) {
    document.getElementById('ban-student-id').value = id
    document.getElementById('ban-reason').value = ''
    document.getElementById('ban-modal').classList.remove('hidden')
    document.getElementById('ban-modal').classList.add('flex')
  }

  function closeBanModal() {
    document.getElementById('ban-modal').classList.add('hidden')
    document.getElementById('ban-modal').classList.remove('flex')
  }

  async function unbanStudent(id) {
    if (!confirm('Tem certeza que deseja desbanir este aluno?')) return

    try {
      const response = await fetch(`/admin/api/students/${id}/unban`, {
        method: 'POST',
      })

      if (response.ok) {
        alert('Aluno desbanido com sucesso!')
        loadStudents()
      } else {
        const data = await response.json()
        alert(data.error || 'Erro ao desbanir aluno')
      }
    } catch (error) {
      alert('Erro ao desbanir aluno')
    }
  }

  async function deleteStudent(id) {
    if (!confirm('Tem certeza que deseja remover este aluno? Esta ação não pode ser desfeita.')) return

    try {
      const response = await fetch(`/admin/api/students/${id}/delete`, {
        method: 'DELETE',
      })

      if (response.ok) {
        alert('Aluno removido com sucesso!')
        loadStudents()
      } else {
        const data = await response.json()
        alert(data.error || 'Erro ao remover aluno')
      }
    } catch (error) {
      alert('Erro ao remover aluno')
    }
  }

  document.getElementById('student-form').addEventListener('submit', async (e) => {
    e.preventDefault()

    const id = document.getElementById('student-id').value
    const data = {
      full_name: document.getElementById('student-name').value,
      email: document.getElementById('student-email').value,
      password: document.getElementById('student-password').value,
      must_change_password: document.getElementById('student-must-change-password').checked,
    }

    try {
      const url = id ? `/admin/api/students/${id}` : '/admin/api/students/create'
      const method = id ? 'PUT' : 'POST'

      const response = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (response.ok) {
        alert(id ? 'Aluno atualizado com sucesso!' : 'Aluno criado com sucesso!')
        closeModal()
        loadStudents()
      } else {
        const errorData = await response.json()
        alert(errorData.error || 'Erro ao salvar aluno')
      }
    } catch (error) {
      alert('Erro ao salvar aluno')
    }
  })

  document.getElementById('ban-form').addEventListener('submit', async (e) => {
    e.preventDefault()

    const id = document.getElementById('ban-student-id').value
    const reason = document.getElementById('ban-reason').value

    try {
      const response = await fetch(`/admin/api/students/${id}/ban`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason }),
      })

      if (response.ok) {
        alert('Aluno banido com sucesso!')
        closeBanModal()
        loadStudents()
      } else {
        const data = await response.json()
        alert(data.error || 'Erro ao banir aluno')
      }
    } catch (error) {
      alert('Erro ao banir aluno')
    }
  })

  document.getElementById('search-input').addEventListener('input', (e) => {
    currentSearch = e.target.value
    currentPage = 1
    loadStudents()
  })

  document.getElementById('status-filter').addEventListener('change', (e) => {
    currentStatus = e.target.value
    currentPage = 1
    loadStudents()
  })

  document.getElementById('sort-select').addEventListener('change', (e) => {
    const [sort, order] = e.target.value.split('-')
    currentSort = sort
    currentOrder = order
    loadStudents()
  })

  loadStudents()
</script>
