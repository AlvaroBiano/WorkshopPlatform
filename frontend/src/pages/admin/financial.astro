---
import AdminLayout from '../../layouts/AdminLayout.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import Icon from '../../components/ui/Icon.astro'
import Button from '../../components/ui/Button.astro'
import { getSessionFromCookies, isAdmin } from '../../lib/auth'

const session = await getSessionFromCookies(Astro.cookies)
if (!session?.profile || !isAdmin(session.profile)) {
  return Astro.redirect('/login')
}
---

<AdminLayout title="Financeiro">
  <div class="mb-8">
    <h1 class="text-3xl font-display font-bold text-dourado mb-8">Financeiro</h1>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-verde-principal/10 flex items-center justify-center">
            <Icon name="trending-up" size={20} class="text-verde-claro" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Total</span>
        </div>
        <p class="text-3xl font-display font-bold text-verde-claro" id="stat-total-revenue">R$ 0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-verde-principal/10 flex items-center justify-center">
            <Icon name="calendar" size={20} class="text-verde-claro" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Mês</span>
        </div>
        <p class="text-3xl font-display font-bold text-verde-claro" id="stat-month-revenue">R$ 0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-dourado/10 flex items-center justify-center">
            <Icon name="clock" size={20} class="text-dourado" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Pendentes</span>
        </div>
        <p class="text-3xl font-display font-bold text-dourado" id="stat-pending-count">0</p>
        <p class="text-text-muted text-sm mt-1" id="stat-pending-amount">R$ 0</p>
      </Card>
      <Card class="p-5">
        <div class="flex items-center justify-between mb-2">
          <div class="w-10 h-10 rounded-lg bg-verde-principal/10 flex items-center justify-center">
            <Icon name="check-circle" size={20} class="text-verde-claro" />
          </div>
          <span class="text-xs uppercase tracking-wider text-text-muted">Hoje</span>
        </div>
        <p class="text-3xl font-display font-bold text-verde-claro" id="stat-approved-today">0</p>
        <p class="text-text-muted text-sm mt-1" id="stat-approved-today-amount">R$ 0</p>
      </Card>
    </div>
  </div>

  <Card class="p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Buscar</label>
        <input 
          type="text" 
          id="search-input"
          placeholder="Nome, email ou número..."
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-text-muted mb-2">Status</label>
        <select 
          id="status-filter"
          class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
        >
          <option value="">Todos</option>
          <option value="pending">Pendentes</option>
          <option value="approved">Aprovados</option>
          <option value="rejected">Rejeitados</option>
        </select>
      </div>
      <div class="flex items-end">
        <button 
          onclick="loadOrders()"
          class="w-full bg-verde-principal hover:bg-verde-claro text-white px-6 py-2.5 rounded-lg font-semibold transition-colors inline-flex items-center justify-center gap-2"
        >
          <Icon name="filter" size={16} />
          Filtrar
        </button>
      </div>
    </div>
  </Card>

  <Card padding="none">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-bg-dark/50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Número</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Aluno</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Produto</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Valor</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Status</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Data</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-text-muted uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody id="orders-table">
          <tr>
            <td colspan="7" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center">
                <div class="animate-spin rounded-full h-10 w-10 border-2 border-dourado/20 border-t-dourado mb-4"></div>
                <p class="text-text-muted">Carregando pedidos...</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="px-6 py-4 bg-bg-dark/50 flex justify-between items-center border-t border-white/5">
      <div class="text-sm text-text-muted">
        Mostrando <span id="showing-start" class="font-semibold text-text-light">0</span> a <span id="showing-end" class="font-semibold text-text-light">0</span> de <span id="total-items" class="font-semibold text-text-light">0</span> pedidos
      </div>
      <div class="flex gap-2" id="pagination-controls"></div>
    </div>
  </Card>

  <div id="order-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeOrderModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4 overflow-y-auto">
      <div class="bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-2xl my-8 transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
          <h2 class="text-xl font-display font-bold text-dourado">Detalhes do Pedido</h2>
          <button onclick="closeOrderModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
            <Icon name="x" size={20} />
          </button>
        </div>

        <div id="order-details" class="p-6"></div>

        <div class="px-6 pb-6 flex gap-4">
          <button onclick="closeOrderModal()" class="flex-1 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">
            Fechar
          </button>
          <button id="approve-btn" onclick="approveOrder()" class="flex-1 bg-verde-principal hover:bg-verde-claro text-white px-4 py-3 rounded-lg font-semibold transition-colors">
            Aprovar
          </button>
          <button id="reject-btn" onclick="openRejectModal()" class="flex-1 bg-vermelho hover:bg-vermelho/80 text-white px-4 py-3 rounded-lg font-semibold transition-colors">
            Rejeitar
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="reject-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeRejectModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="bg-azul-profundo rounded-xl border border-white/10 shadow-2xl w-full max-w-md transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-white/5">
          <h2 class="text-xl font-display font-bold text-vermelho">Rejeitar Pedido</h2>
          <button onclick="closeRejectModal()" class="p-2 text-text-muted hover:text-text-light hover:bg-white/5 rounded-lg transition-colors">
            <Icon name="x" size={20} />
          </button>
        </div>

        <form id="reject-form" class="p-6">
          <div class="mb-6">
            <label class="block text-sm font-medium text-text-muted mb-2">Motivo da Rejeição *</label>
            <textarea 
              id="reject-reason"
              required
              rows="4"
              class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light focus:outline-none focus:border-dourado transition-colors"
              placeholder="Descreva o motivo..."
            ></textarea>
          </div>

          <div class="flex gap-4">
            <button type="button" onclick="closeRejectModal()" class="flex-1 bg-bg-dark hover:bg-white/5 text-text-light px-4 py-3 rounded-lg font-semibold transition-colors">
              Cancelar
            </button>
            <button type="submit" class="flex-1 bg-vermelho hover:bg-vermelho/80 text-white px-4 py-3 rounded-lg font-semibold transition-colors">
              Rejeitar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const orderModal = document.getElementById('order-modal')
    const rejectModal = document.getElementById('reject-modal')
    if (orderModal) document.body.appendChild(orderModal)
    if (rejectModal) document.body.appendChild(rejectModal)
  })

  let currentPage = 1
  let currentSearch = ''
  let currentStatus = ''
  let currentOrderId = ''

  async function loadOverview() {
    try {
      const response = await fetch('/admin/api/financial/overview')
      const data = await response.json()

      document.getElementById('stat-total-revenue').textContent = `R$ ${(data.total_revenue_cents / 100).toFixed(2)}`
      document.getElementById('stat-month-revenue').textContent = `R$ ${(data.month_revenue_cents / 100).toFixed(2)}`
      document.getElementById('stat-pending-count').textContent = data.pending_orders_count
      document.getElementById('stat-pending-amount').textContent = `R$ ${(data.pending_amount_cents / 100).toFixed(2)}`
      document.getElementById('stat-approved-today').textContent = data.approved_today_count
      document.getElementById('stat-approved-today-amount').textContent = `R$ ${(data.approved_today_amount_cents / 100).toFixed(2)}`
    } catch (error) {
      console.error('Erro ao carregar:', error)
    }
  }

  async function loadOrders() {
    currentSearch = document.getElementById('search-input').value
    currentStatus = document.getElementById('status-filter').value

    const params = new URLSearchParams({
      page: currentPage.toString(),
      limit: '20',
      search: currentSearch,
      status: currentStatus,
    })

    try {
      const response = await fetch(`/admin/api/financial/orders?${params}`)
      const data = await response.json()

      renderOrders(data.orders)
      renderPagination(data)
    } catch (error) {
      document.getElementById('orders-table').innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <Icon name="alert-circle" size={48} class="text-vermelho mb-4" />
              <p class="text-vermelho font-medium">Erro ao carregar pedidos</p>
            </div>
          </td>
        </tr>
      `
    }
  }

  function renderOrders(orders) {
    const tbody = document.getElementById('orders-table')
    
    if (!orders || orders.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center">
              <Icon name="shopping-bag" size={48} class="text-text-muted/30 mb-4" />
              <p class="text-text-muted">Nenhum pedido encontrado</p>
            </div>
          </td>
        </tr>
      `
      return
    }

    tbody.innerHTML = orders.map(order => {
      const statusMap = {
        pending: { label: 'Pendente', variant: 'warning' },
        approved: { label: 'Aprovado', variant: 'success' },
        rejected: { label: 'Rejeitado', variant: 'error' },
      }
      const status = statusMap[order.status] || { label: order.status, variant: 'neutral' }

      return `
        <tr class="border-t border-white/5 hover:bg-white/[0.02] transition-colors">
          <td class="px-6 py-4">
            <span class="font-mono text-sm text-dourado font-semibold">${order.order_number}</span>
          </td>
          <td class="px-6 py-4">
            <div class="text-text-light">${order.user_name || '—'}</div>
            <div class="text-text-muted text-sm">${order.user_email || '—'}</div>
          </td>
          <td class="px-6 py-4 text-text-muted">${order.product_title || '—'}</td>
          <td class="px-6 py-4 text-verde-claro font-semibold">
            R$ ${((order.amount_cents || 0) / 100).toFixed(2)}
          </td>
          <td class="px-6 py-4">
            <Badge variant={status.variant}>{status.label}</Badge>
          </td>
          <td class="px-6 py-4 text-text-muted text-sm">
            ${new Date(order.created_at).toLocaleDateString('pt-BR')}
          </td>
          <td class="px-6 py-4">
            <button onclick="openOrderModal('${order.id}')" class="text-dourado hover:text-dourado/80 text-sm font-medium flex items-center gap-1">
              <Icon name="eye" size={14} /> Ver
            </button>
          </td>
        </tr>
      `
    }).join('')
  }

  function renderPagination(data) {
    const { page, totalPages, total } = data
    const start = (page - 1) * 20 + 1
    const end = Math.min(page * 20, total)

    document.getElementById('showing-start').textContent = start
    document.getElementById('showing-end').textContent = end
    document.getElementById('total-items').textContent = total

    const controls = document.getElementById('pagination-controls')
    let html = ''

    if (page > 1) {
      html += `<button onclick="goToPage(${page - 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Anterior</button>`
    }

    for (let i = 1; i <= totalPages; i++) {
      if (i === page) {
        html += `<button class="px-4 py-2 bg-verde-principal text-white rounded-lg text-sm font-medium">${i}</button>`
      } else if (i === 1 || i === totalPages || (i >= page - 2 && i <= page + 2)) {
        html += `<button onclick="goToPage(${i})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">${i}</button>`
      } else if (i === page - 3 || i === page + 3) {
        html += `<span class="px-2 text-text-muted">...</span>`
      }
    }

    if (page < totalPages) {
      html += `<button onclick="goToPage(${page + 1})" class="px-4 py-2 bg-bg-dark hover:bg-white/10 text-text-light rounded-lg text-sm font-medium transition-colors">Próximo</button>`
    }

    controls.innerHTML = html
  }

  function goToPage(page) {
    currentPage = page
    loadOrders()
  }

  async function openOrderModal(id) {
    currentOrderId = id
    try {
      const response = await fetch(`/admin/api/financial/orders/${id}`)
      const data = await response.json()
      const order = data.order

      const statusMap = {
        pending: { label: 'Pendente', variant: 'warning' },
        approved: { label: 'Aprovado', variant: 'success' },
        rejected: { label: 'Rejeitado', variant: 'error' },
      }
      const status = statusMap[order.status] || { label: order.status, variant: 'neutral' }

      document.getElementById('order-details').innerHTML = `
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <div class="text-text-muted text-sm mb-1">Número</div>
              <div class="text-text-light font-mono font-semibold">${order.order_number}</div>
            </div>
            <div>
              <div class="text-text-muted text-sm mb-1">Status</div>
              <Badge variant={status.variant}>{status.label}</Badge>
            </div>
          </div>
          <div>
            <div class="text-text-muted text-sm mb-1">Aluno</div>
            <div class="text-text-light">${order.user_name}</div>
            <div class="text-text-muted text-sm">${order.user_email}</div>
            ${order.user_whatsapp ? `<div class="text-text-muted text-sm">${order.user_whatsapp}</div>` : ''}
          </div>
          <div>
            <div class="text-text-muted text-sm mb-1">Produto</div>
            <div class="text-text-light">${order.product_title}</div>
          </div>
          <div>
            <div class="text-text-muted text-sm mb-1">Valor</div>
            <div class="text-verde-claro text-2xl font-display font-bold">R$ ${((order.amount_cents || 0) / 100).toFixed(2)}</div>
          </div>
          ${order.payment_proof_url ? `
            <div>
              <div class="text-text-muted text-sm mb-2">Comprovante</div>
              <img src="${order.payment_proof_url}" alt="Comprovante" class="w-full rounded-lg border border-white/10" />
            </div>
          ` : ''}
          <div>
            <div class="text-text-muted text-sm mb-1">Data</div>
            <div class="text-text-light">${new Date(order.created_at).toLocaleString('pt-BR')}</div>
          </div>
          ${order.approved_at ? `
            <div>
              <div class="text-text-muted text-sm mb-1">Aprovado em</div>
              <div class="text-verde-claro">${new Date(order.approved_at).toLocaleString('pt-BR')}</div>
            </div>
          ` : ''}
          ${order.rejected_at ? `
            <div class="p-4 bg-vermelho/10 rounded-lg border border-vermelho/20">
              <div class="text-text-muted text-sm mb-1">Rejeitado em</div>
              <div class="text-vermelho">${new Date(order.rejected_at).toLocaleString('pt-BR')}</div>
              <div class="text-text-muted text-sm mt-2">Motivo: ${order.rejection_reason}</div>
            </div>
          ` : ''}
        </div>
      `

      const approveBtn = document.getElementById('approve-btn')
      const rejectBtn = document.getElementById('reject-btn')

      if (order.status === 'pending') {
        approveBtn.classList.remove('hidden')
        rejectBtn.classList.remove('hidden')
      } else {
        approveBtn.classList.add('hidden')
        rejectBtn.classList.add('hidden')
      }

      document.getElementById('order-modal').classList.remove('hidden')
      document.getElementById('order-modal').classList.add('flex')
    } catch (error) {
      window.showToast('error', 'Erro ao carregar detalhes')
    }
  }

  function closeOrderModal() {
    document.getElementById('order-modal').classList.add('hidden')
    document.getElementById('order-modal').classList.remove('flex')
  }

  async function approveOrder() {
    if (!confirm('Aprovar este pedido? O aluno receberá acesso imediato.')) return

    try {
      const response = await fetch(`/admin/api/financial/orders/${currentOrderId}/approve`, { method: 'POST' })
      if (response.ok) {
        window.showToast('success', 'Pedido aprovado!')
        closeOrderModal()
        loadOverview()
        loadOrders()
      } else {
        const data = await response.json()
        window.showToast('error', data.error || 'Erro ao aprovar')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao aprovar pedido')
    }
  }

  function openRejectModal() {
    document.getElementById('reject-reason').value = ''
    document.getElementById('reject-modal').classList.remove('hidden')
    document.getElementById('reject-modal').classList.add('flex')
  }

  function closeRejectModal() {
    document.getElementById('reject-modal').classList.add('hidden')
    document.getElementById('reject-modal').classList.remove('flex')
  }

  document.getElementById('reject-form').addEventListener('submit', async (e) => {
    e.preventDefault()
    const reason = document.getElementById('reject-reason').value

    try {
      const response = await fetch(`/admin/api/financial/orders/${currentOrderId}/reject`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason }),
      })

      if (response.ok) {
        window.showToast('success', 'Pedido rejeitado')
        closeRejectModal()
        closeOrderModal()
        loadOverview()
        loadOrders()
      } else {
        const data = await response.json()
        window.showToast('error', data.error || 'Erro ao rejeitar')
      }
    } catch (error) {
      window.showToast('error', 'Erro ao rejeitar pedido')
    }
  })

  // Expor funções para escopo global (onclick inline)
  window.loadOrders = loadOrders
  window.goToPage = goToPage
  window.openOrderModal = openOrderModal
  window.closeOrderModal = closeOrderModal
  window.approveOrder = approveOrder
  window.openRejectModal = openRejectModal
  window.closeRejectModal = closeRejectModal

  loadOverview()
  loadOrders()
</script>