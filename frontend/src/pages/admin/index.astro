---
import AdminLayout from '../../layouts/AdminLayout.astro'
import Icon from '../../components/ui/Icon.astro'
import Card from '../../components/ui/Card.astro'
import Badge from '../../components/ui/Badge.astro'
import { db } from '@lib/turso'

const user = Astro.locals.user

const [studentsResult, productsResult, ordersResult, pendingResult, revenueResult, pendingRegResult] = await Promise.all([
  db.execute("SELECT COUNT(*) as count FROM users WHERE role = 'student'"),
  db.execute('SELECT COUNT(*) as count FROM products'),
  db.execute(`SELECT o.*, u.full_name as user_name, p.title as product_name
              FROM orders o
              JOIN users u ON o.user_id = u.id
              JOIN products p ON o.product_id = p.id
              ORDER BY o.created_at DESC LIMIT 10`),
  db.execute("SELECT COUNT(*) as count FROM orders WHERE status = 'pending'"),
  db.execute("SELECT COALESCE(SUM(amount_cents), 0) as total FROM orders WHERE status = 'approved' AND strftime('%m', created_at) = strftime('%m', 'now')"),
  db.execute("SELECT COUNT(*) as count, pr.* FROM pending_registrations pr WHERE status IN ('awaiting_proof', 'pending') ORDER BY pr.created_at DESC LIMIT 5"),
])

const totalStudents = Number(studentsResult.rows[0]?.count || 0)
const totalProducts = Number(productsResult.rows[0]?.count || 0)
const recentOrders = ordersResult.rows || []
const monthRevenue = Number(revenueResult.rows[0]?.total || 0)
const pendingCount = Number(pendingResult.rows[0]?.count || 0)
const pendingRegsCount = Number(pendingRegResult.rows[0]?.count || 0)
const pendingRegs = (pendingRegResult.rows || []).slice(1) as any[]
---

<AdminLayout title="Dashboard">
  <h1 class="text-2xl font-display font-bold mb-6 text-dourado">
    Olá, {user?.full_name?.split(' ')[0]}
  </h1>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <Card class="p-5">
      <div class="flex items-center justify-between mb-2">
        <div class="w-10 h-10 rounded-lg bg-dourado/10 flex items-center justify-center">
          <Icon name="users" size={20} class="text-dourado" />
        </div>
        <span class="text-xs uppercase tracking-wider text-text-muted">Alunos</span>
      </div>
      <p class="text-3xl font-display font-bold text-dourado">{totalStudents || 0}</p>
    </Card>
    <Card class="p-5">
      <div class="flex items-center justify-between mb-2">
        <div class="w-10 h-10 rounded-lg bg-verde-principal/10 flex items-center justify-center">
          <Icon name="banknote" size={20} class="text-verde-claro" />
        </div>
        <span class="text-xs uppercase tracking-wider text-text-muted">Receita Mês</span>
      </div>
      <p class="text-3xl font-display font-bold text-verde-claro">R$ {(monthRevenue / 100).toFixed(0)}</p>
    </Card>
    <Card class="p-5">
      <div class="flex items-center justify-between mb-2">
        <div class="w-10 h-10 rounded-lg bg-dourado/10 flex items-center justify-center">
          <Icon name="clock" size={20} class="text-dourado" />
        </div>
        <span class="text-xs uppercase tracking-wider text-text-muted">Pendentes</span>
      </div>
      <p class="text-3xl font-display font-bold text-dourado">{pendingCount || 0}</p>
    </Card>
    <Card class="p-5">
      <div class="flex items-center justify-between mb-2">
        <div class="w-10 h-10 rounded-lg bg-azul-accent/10 flex items-center justify-center">
          <Icon name="package" size={20} class="text-azul-accent" />
        </div>
        <span class="text-xs uppercase tracking-wider text-text-muted">Produtos</span>
      </div>
      <p class="text-3xl font-display font-bold text-text-light">{totalProducts}</p>
    </Card>
  </div>

  <section class="card p-6 mb-8">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold text-dourado">Aprovações Pendentes</h2>
      <a href="/admin/pending" class="text-dourado text-sm hover:underline flex items-center gap-1">
        Ver todas <Icon name="arrow-right" size={14} />
      </a>
    </div>
    {pendingRegsCount === 0 ? (
      <p class="text-text-muted text-center py-8">Nenhuma aprovação pendente</p>
    ) : (
      <div class="space-y-2">
        {pendingRegs.map((p: any) => (
          <a href="/admin/pending" class="flex items-center justify-between p-3 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
            <div>
              <p class="font-medium text-text-light">{p.full_name}</p>
              <p class="text-text-muted text-sm">{p.email}</p>
            </div>
            <div class="text-text-muted text-xs">
              {new Date(p.created_at).toLocaleDateString('pt-BR')}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="card p-6">
    <h2 class="text-xl font-bold text-dourado mb-4">Vendas Recentes</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="text-text-muted border-b border-white/5">
          <tr>
            <th class="text-left py-2">Aluno</th>
            <th class="text-left py-2">Produto</th>
            <th class="text-left py-2">Valor</th>
            <th class="text-left py-2">Status</th>
            <th class="text-left py-2">Data</th>
          </tr>
        </thead>
        <tbody>
          {(recentOrders || []).map((o: any) => (
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="py-3">{o.user_name || '—'}</td>
              <td class="py-3">{o.product_name || '—'}</td>
              <td class="py-3 text-dourado font-semibold">R$ {((o.amount_cents || 0) / 100).toFixed(2)}</td>
              <td class="py-3">
                {o.status === 'approved' ? (
                  <Badge variant="success">Aprovado</Badge>
                ) : o.status === 'pending' ? (
                  <Badge variant="warning">Pendente</Badge>
                ) : (
                  <Badge variant="error">{o.status}</Badge>
                )}
              </td>
              <td class="py-3 text-text-muted">{new Date(o.created_at).toLocaleDateString('pt-BR')}</td>
            </tr>
          ))}
          {(!recentOrders || recentOrders.length === 0) && (
            <tr>
              <td colspan="5" class="py-8 text-center text-text-muted">Nenhuma venda registrada</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </section>
</AdminLayout>