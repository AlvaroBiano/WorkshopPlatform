---
import StudentLayout from '../../layouts/StudentLayout.astro'
import { db } from '@lib/turso'

const user = Astro.locals.user
if (!user) return Astro.redirect('/login')

const affiliateRows = await db.execute({
  sql: 'SELECT * FROM affiliates WHERE user_id = ?',
  args: [user.id],
})
const affiliate = affiliateRows.rows[0]
if (!affiliate) return Astro.redirect('/student')

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321'
const referralLink = `${siteUrl}/?ref=${affiliate.code}`

const totalClicksRows = await db.execute({
  sql: 'SELECT COUNT(*) as count FROM affiliate_clicks WHERE affiliate_id = ?',
  args: [affiliate.id],
})
const totalClicks = Number(totalClicksRows.rows[0]?.count || 0)

const conversionsRows = await db.execute({
  sql: 'SELECT COUNT(*) as count FROM orders WHERE affiliate_id = ? AND status = ?',
  args: [user.id, 'approved'],
})
const conversions = Number(conversionsRows.rows[0]?.count || 0)

const recentClicksRows = await db.execute({
  sql: 'SELECT * FROM affiliate_clicks WHERE affiliate_id = ? ORDER BY clicked_at DESC LIMIT 20',
  args: [affiliate.id],
})
const recentClicks = recentClicksRows.rows

const withdrawalsRows = await db.execute({
  sql: 'SELECT * FROM affiliate_withdrawals WHERE affiliate_id = ? ORDER BY requested_at DESC',
  args: [affiliate.id],
})
const withdrawals = withdrawalsRows.rows

const conversionRate = totalClicks ? ((conversions || 0) / totalClicks * 100).toFixed(2) : '0'
---

<StudentLayout title="Painel do Afiliado | WORKSHOP">
  <h1 class="text-2xl font-display font-bold text-dourado mb-2">Painel do Afiliado</h1>
  <p class="text-text-muted mb-8">Bem-vindo, {user.full_name}!</p>

  <div class="bg-azul-profundo rounded-xl border border-white/10 p-6 mb-8 bg-gradient-to-br from-dourado/10 to-transparent border-dourado/30">
    <h2 class="font-bold mb-3 text-dourado">Seu Link de Afiliado</h2>
    <div class="flex gap-2">
      <input type="text" readonly value={referralLink} id="refLink" class="w-full bg-bg-dark/50 border border-white/10 rounded-lg px-4 py-2.5 text-text-light placeholder-text-muted focus:outline-none focus:border-dourado transition-colors flex-1 font-mono text-sm" />
      <button onclick="copyLink()" class="bg-verde-principal hover:bg-verde-claro text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200 hover:scale-[1.02]">Copiar</button>
    </div>
    <p class="text-xs text-text-muted mt-2">
      Código: <strong class="text-dourado">{affiliate.code}</strong> · Comissão: <strong class="text-dourado">{affiliate.commission_pct}%</strong>
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-azul-profundo rounded-xl border border-white/10 p-5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">👆</span>
        <span class="text-xs uppercase tracking-wider text-text-muted">Cliques</span>
      </div>
      <p class="text-3xl font-display font-bold text-azul-accent">{totalClicks || 0}</p>
    </div>
    <div class="bg-azul-profundo rounded-xl border border-white/10 p-5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">🎯</span>
        <span class="text-xs uppercase tracking-wider text-text-muted">Conversões</span>
      </div>
      <p class="text-3xl font-display font-bold text-verde-claro">{conversions || 0}</p>
    </div>
    <div class="bg-azul-profundo rounded-xl border border-white/10 p-5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">📊</span>
        <span class="text-xs uppercase tracking-wider text-text-muted">Taxa Conv.</span>
      </div>
      <p class="text-3xl font-display font-bold text-dourado">{conversionRate}%</p>
    </div>
    <div class="bg-azul-profundo rounded-xl border border-white/10 p-5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl">💰</span>
        <span class="text-xs uppercase tracking-wider text-text-muted">Saldo Disp.</span>
      </div>
      <p class="text-3xl font-display font-bold text-dourado">R$ {((affiliate.balance_cents || 0) / 100).toFixed(0)}</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-azul-profundo rounded-xl border border-white/10 p-6">
      <h2 class="font-bold mb-4 text-dourado">Meus Ganhos</h2>
      <div class="space-y-3">
        <div class="flex justify-between">
          <span class="text-text-muted">Pendente (quarentena)</span>
          <span class="text-dourado font-semibold">R$ {((affiliate.balance_pending_cents || 0) / 100).toFixed(2)}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-text-muted">Disponível para saque</span>
          <span class="text-verde-claro font-semibold">R$ {((affiliate.balance_cents || 0) / 100).toFixed(2)}</span>
        </div>
        <div class="flex justify-between pt-3 border-t border-white/5">
          <span class="text-text-muted">Total ganho</span>
          <span class="text-dourado font-bold text-lg">R$ {(((affiliate.balance_cents || 0) + (affiliate.balance_pending_cents || 0)) / 100).toFixed(2)}</span>
        </div>
      </div>
      {(affiliate.balance_cents || 0) >= 10000 && (
        <button onclick="requestWithdraw()" class="bg-verde-principal hover:bg-verde-claro text-white px-6 py-3 rounded-lg font-semibold transition-all duration-200 hover:scale-[1.02] w-full mt-4">
          Solicitar Saque
        </button>
      )}
    </div>

    <div class="bg-azul-profundo rounded-xl border border-white/10 p-6">
      <h2 class="font-bold mb-4 text-dourado">Dados de Pagamento</h2>
      <div class="space-y-3 text-sm">
        <div>
          <p class="text-text-muted">Chave PIX cadastrada:</p>
          <p class="font-mono">{affiliate.pix_key || '—'}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-azul-profundo rounded-xl border border-white/10 p-6 mb-8">
    <h2 class="font-bold mb-4 text-dourado">Cliques Recentes</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="text-text-muted border-b border-white/5">
          <tr>
            <th class="text-left py-2">Data</th>
            <th class="text-left py-2">IP</th>
            <th class="text-left py-2">Origem</th>
          </tr>
        </thead>
        <tbody>
          {(recentClicks || []).map((c: any) => (
            <tr class="border-b border-white/5">
              <td class="py-2 text-text-muted">{new Date(c.clicked_at).toLocaleString('pt-BR')}</td>
              <td class="py-2 font-mono text-xs">{c.ip || '—'}</td>
              <td class="py-2 text-xs">{c.referrer?.slice(0, 40) || '—'}</td>
            </tr>
          ))}
          {(!recentClicks || recentClicks.length === 0) && (
            <tr>
              <td colspan="3" class="py-8 text-center text-text-muted">Nenhum clique registrado</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

    {(withdrawals || []).length > 0 && (
      <div class="bg-azul-profundo rounded-xl border border-white/10 p-6">
        <h2 class="font-bold mb-4 text-dourado">Histórico de Saques</h2>
        <div class="space-y-2">
          {withdrawals.map((w: any) => (
            <div class="flex justify-between items-center p-3 bg-white/5 rounded">
              <div>
                <p class="font-semibold">R$ {(w.amount_cents / 100).toFixed(2)}</p>
                <p class="text-xs text-text-muted">{new Date(w.requested_at).toLocaleDateString('pt-BR')}</p>
              </div>
              <span class:list={[
                'px-2 py-1 rounded text-xs',
                w.status === 'paid' ? 'bg-verde-claro/20 text-verde-claro' :
                w.status === 'approved' ? 'bg-azul-accent/20 text-azul-accent' :
                w.status === 'rejected' ? 'bg-red-500/20 text-red-400' :
                'bg-dourado/20 text-dourado'
              ]}>
                {w.status === 'paid' ? 'Pago' :
                 w.status === 'approved' ? 'Aprovado' :
                 w.status === 'rejected' ? 'Rejeitado' : 'Em análise'}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="bg-azul-profundo rounded-xl border border-white/10 p-6 mt-6 flex items-center justify-between">
      <div>
        <h2 class="font-bold text-dourado">Exportar Relatório</h2>
        <p class="text-text-muted text-sm">Baixe a lista completa de cliques em CSV</p>
      </div>
      <a href="/affiliate/api/export-clicks" class="bg-verde-principal hover:bg-verde-claro text-white px-6 py-3 rounded-lg font-semibold transition-colors inline-flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        Baixar CSV
      </a>
    </div>
  </div>
</StudentLayout>

<script>
  window.copyLink = () => {
    const input = document.getElementById('refLink') as HTMLInputElement
    input.select()
    navigator.clipboard.writeText(input.value)
    alert('Link copiado!')
  }

  window.requestWithdraw = async () => {
    const amount = prompt('Valor do saque (em R$, mínimo 100):')
    if (!amount) return
    const cents = Math.round(parseFloat(amount) * 100)
    if (cents < 10000) { alert('Mínimo R$ 100'); return }

    const res = await fetch('/affiliate/api/withdraw', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ amountCents: cents })
    })

    if (res.ok) {
      alert('Saque solicitado! Processaremos em até 7 dias úteis.')
      location.reload()
    } else {
      alert('Erro: ' + await res.text())
    }
  }
</script>
