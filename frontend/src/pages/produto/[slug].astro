---
import Layout from '../../layouts/Layout.astro'
import Icon from '../../components/ui/Icon.astro'
import Button from '../../components/ui/Button.astro'
import { db } from '../../lib/turso'

const slug = Astro.params.slug

const productResult = await db.execute({
  sql: `SELECT p.*, 
        (SELECT COALESCE(AVG(rating), 0) FROM reviews WHERE product_id = p.id AND status = 'approved') as avg_rating,
        (SELECT COUNT(*) FROM reviews WHERE product_id = p.id AND status = 'approved') as total_reviews
        FROM products p WHERE p.slug = ? AND p.status = 'published'`,
  args: [slug],
})

if (productResult.rows.length === 0) {
  return Astro.redirect('/')
}

const product = productResult.rows[0] as any

const modulesResult = await db.execute({
  sql: `SELECT m.*, COUNT(l.id) as lessons_count 
        FROM modules m LEFT JOIN lessons l ON m.id = l.module_id 
        WHERE m.product_id = ? GROUP BY m.id ORDER BY m.sort_order`,
  args: [product.id],
})

const reviewsResult = await db.execute({
  sql: `SELECT r.*, u.full_name FROM reviews r 
        JOIN users u ON r.user_id = u.id 
        WHERE r.product_id = ? AND r.status = 'approved' ORDER BY r.created_at DESC LIMIT 10`,
  args: [product.id],
})

const modules = modulesResult.rows as any[]
const reviews = reviewsResult.rows as any[]
const avgRating = Number(product.avg_rating || 0)
const totalReviews = Number(product.total_reviews || 0)

function renderStars(rating: number) {
  const full = Math.floor(rating)
  const half = rating % 1 >= 0.5
  let html = ''
  for (let i = 0; i < full; i++) html += '<svg class="w-5 h-5 text-dourado fill-current" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  if (half) html += '<svg class="w-5 h-5 text-dourado fill-current" viewBox="0 0 24 24"><defs><linearGradient id="half"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="transparent"/></linearGradient></defs><polygon fill="url(#half)" stroke="currentColor" points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  const empty = 5 - full - (half ? 1 : 0)
  for (let i = 0; i < empty; i++) html += '<svg class="w-5 h-5 text-text-muted" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>'
  return html
}
---

<Layout title={`${product.title} | WORKSHOP`}>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-azul-profundo via-bg-dark to-verde-principal opacity-50"></div>
    
    <div class="relative z-10 max-w-6xl mx-auto px-4 py-20">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block px-3 py-1 bg-verde-principal/20 text-verde-claro rounded-full text-sm font-medium mb-4">
            {product.type === 'course' ? 'Curso' : product.type === 'workshop' ? 'Workshop' : 'E-book'}
          </span>
          <h1 class="font-display text-4xl md:text-5xl text-dourado mb-4">{product.title}</h1>
          <p class="text-text-muted text-lg mb-6">{product.description || 'Sem descrição'}</p>
          
          <div class="flex items-center gap-2 mb-6">
            <div class="flex" set:html={renderStars(avgRating)} />
            <span class="text-text-muted">({avgRating.toFixed(1)}) {totalReviews} avaliações</span>
          </div>
          
          <div class="flex items-center gap-4 mb-8">
            <span class="text-4xl font-display font-bold text-verde-claro">
              R$ {((product.price_cents || 0) / 100).toFixed(2)}
            </span>
          </div>
          
          <div class="flex gap-4">
            <Button href={`/checkout/${product.slug}`} variant="primary" size="lg">
              Comprar Agora
            </Button>
          </div>
        </div>
        
        <div class="relative">
          {product.cover_url ? (
            <img src={product.cover_url} alt={product.title} class="rounded-xl shadow-2xl w-full" />
          ) : (
            <div class="w-full aspect-video bg-bg-card rounded-xl flex items-center justify-center">
              <Icon name="package" size={64} class="text-text-muted/30" />
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-4 bg-bg-card">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl text-dourado mb-8 text-center">Conteúdo do Programa</h2>
      
      <div class="space-y-4">
        {modules.map((m, i) => (
          <div class="bg-bg-dark rounded-lg p-4 border border-white/5">
            <div class="flex items-center gap-3 mb-2">
              <span class="w-8 h-8 rounded-full bg-dourado/20 text-dourado flex items-center justify-center font-bold text-sm">
                {i + 1}
              </span>
              <h3 class="font-bold text-text-light">{m.title}</h3>
              <span class="text-xs text-text-muted ml-auto">{m.lessons_count} aulas</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl text-dourado mb-8 text-center">Avaliações dos Alunos</h2>
      
      {reviews.length === 0 ? (
        <p class="text-center text-text-muted">Nenhuma avaliação ainda. Seja o primeiro!</p>
      ) : (
        <div class="grid md:grid-cols-2 gap-6">
          {reviews.map((review) => (
            <div class="bg-bg-card rounded-lg p-6 border border-white/5">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-full bg-dourado/20 flex items-center justify-center text-dourado font-bold">
                  {review.full_name?.charAt(0).toUpperCase() || 'A'}
                </div>
                <div>
                  <p class="font-semibold text-text-light">{review.full_name}</p>
                  <div class="flex" set:html={renderStars(review.rating)} />
                </div>
              </div>
              {review.title && <h4 class="font-bold text-dourado mb-2">{review.title}</h4>}
              {review.body && <p class="text-text-muted">{review.body}</p>}
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="py-16 px-4 bg-bg-card">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-display text-3xl text-dourado mb-4">Pronto para Começar?</h2>
      <p class="text-text-muted mb-8">Garanta seu acesso agora e comece sua jornada de transformação.</p>
      <Button href={`/checkout/${product.slug}`} variant="primary" size="lg">
        Comprar por R$ {((product.price_cents || 0) / 100).toFixed(2)}
      </Button>
    </div>
  </section>
</Layout>
