---
import AuthLayout from '../layouts/AuthLayout.astro'
import { db } from '../lib/turso'

const refCode = Astro.url.searchParams.get('ref')

let products: any[] = []
try {
  const result = await db.execute({
    sql: "SELECT id, title, price_cents FROM products WHERE status = 'published' ORDER BY created_at ASC",
    args: [],
  })
  products = result.rows as any[]
} catch (error) {
  console.error('Erro ao carregar produtos:', error)
}
---

<AuthLayout title="Cadastro | WORKSHOP - Grupo Braga & Biano">
  <div class="min-h-screen flex items-center justify-center px-4 py-12 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-azul-profundo via-bg-dark to-verde-principal opacity-40"></div>

    <div class="relative z-10 w-full max-w-lg">
      <div class="text-center mb-8">
        <h1 class="font-display text-4xl font-bold text-dourado">WORKSHOP</h1>
        <p class="text-text-muted mt-2 tracking-widest text-sm uppercase">Grupo Braga & Biano</p>
      </div>

      <div class="card p-8">
        <h2 class="text-2xl font-display text-dourado mb-1">Cadastre-se</h2>
        <p class="text-text-muted mb-6">Preencha seus dados para participar</p>

        <form id="registerForm" class="space-y-4">
          <div>
            <label for="full_name" class="block text-sm font-medium text-text-muted mb-2">Nome completo</label>
            <input id="full_name" type="text" required class="input" placeholder="Seu nome completo" />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-text-muted mb-2">E-mail</label>
            <input id="email" type="email" required class="input" placeholder="seu@email.com" />
          </div>

          <div>
            <label for="cpf" class="block text-sm font-medium text-text-muted mb-2">CPF</label>
            <input id="cpf" type="text" required class="input" placeholder="00000000000" maxlength="11" pattern="[0-9]{11}" />
          </div>

          <div>
            <label for="whatsapp" class="block text-sm font-medium text-text-muted mb-2">WhatsApp (DDI+DDD+Número)</label>
            <input id="whatsapp" type="tel" required class="input" placeholder="+5511999999999" />
          </div>

          <div>
            <label for="product" class="block text-sm font-medium text-text-muted mb-2">Workshop desejado</label>
            <select id="product" class="input" required>
              <option value="">Selecione...</option>
              {products.map(p => (
                <option value={p.id}>
                  {p.title} - R$ {(p.price_cents / 100).toFixed(2)}
                </option>
              ))}
            </select>
          </div>

          {refCode && (
            <div>
              <label class="block text-sm font-medium text-text-muted mb-2">Código de afiliado</label>
              <input type="text" class="input bg-white/5" value={refCode} readonly />
            </div>
          )}

          <div>
            <label for="payment_proof" class="block text-sm font-medium text-text-muted mb-2">
              Comprovante de pagamento (opcional)
            </label>
            <input id="payment_proof" type="url" class="input" placeholder="Link do comprovante (Google Drive, etc)" />
          </div>

          <div id="errorMsg" class="hidden p-3 rounded-lg text-sm bg-vermelho/10 border border-vermelho/30 text-vermelho"></div>
          <div id="successMsg" class="hidden p-3 rounded-lg text-sm bg-verde-claro/10 border border-verde-claro/30 text-verde-claro"></div>

          <button type="submit" id="submitBtn" class="btn btn-primary w-full">
            <span id="btnText">Enviar Cadastro</span>
            <span id="btnLoading" class="hidden">Enviando...</span>
          </button>
        </form>

        <div class="mt-6 pt-6 border-t border-white/5 text-center">
          <p class="text-text-muted text-sm">
            Já tem conta?
            <a href="/login" class="text-dourado hover:underline font-semibold">Entrar</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</AuthLayout>

<script>
  const form = document.getElementById('registerForm') as HTMLFormElement
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement
  const successMsg = document.getElementById('successMsg') as HTMLDivElement
  const btnText = document.getElementById('btnText') as HTMLSpanElement
  const btnLoading = document.getElementById('btnLoading') as HTMLSpanElement
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorMsg.classList.add('hidden')
    successMsg.classList.add('hidden')
    btnText.classList.add('hidden')
    btnLoading.classList.remove('hidden')
    submitBtn.disabled = true

    const formData = {
      full_name: (document.getElementById('full_name') as HTMLInputElement).value.trim(),
      email: (document.getElementById('email') as HTMLInputElement).value.trim().toLowerCase(),
      cpf: (document.getElementById('cpf') as HTMLInputElement).value.replace(/\D/g, ''),
      whatsapp: (document.getElementById('whatsapp') as HTMLInputElement).value.trim(),
      desired_product_id: (document.getElementById('product') as HTMLSelectElement).value,
      payment_proof_url: (document.getElementById('payment_proof') as HTMLInputElement).value.trim() || null,
      affiliate_code: new URLSearchParams(window.location.search).get('ref'),
    }

    if (formData.cpf.length !== 11) {
      errorMsg.textContent = 'CPF deve ter 11 dígitos'
      errorMsg.classList.remove('hidden')
      btnText.classList.remove('hidden')
      btnLoading.classList.add('hidden')
      submitBtn.disabled = false
      return
    }

    try {
      const response = await fetch('/api/cadastro', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData),
      })

      const data = await response.json()

      if (!response.ok) {
        throw new Error(data.error || 'Erro ao enviar cadastro')
      }

      successMsg.textContent = data.message || 'Cadastro enviado com sucesso! Aguarde a aprovação do administrador.'
      successMsg.classList.remove('hidden')
      form.reset()
      form.style.display = 'none'
    } catch (err: any) {
      errorMsg.textContent = err.message || 'Erro ao enviar cadastro'
      errorMsg.classList.remove('hidden')
    } finally {
      btnText.classList.remove('hidden')
      btnLoading.classList.add('hidden')
      submitBtn.disabled = false
    }
  })
</script>
